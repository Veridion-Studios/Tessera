<div class="mb-6">
  <%= link_to "← Back to users", admin_users_path, class: "text-sm text-zinc-400 hover:text-white transition-colors" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-4">
    <div class="rounded-2xl border border-white/5 bg-white/2 p-6">
      <h1 class="text-xl font-bold text-white mb-1"><%= @user.email %></h1>
      <div class="flex gap-2 mb-4">
        <% @user.roles.each do |role| %>
          <span class="px-2.5 py-1 rounded-full text-xs bg-white/5 border border-white/10 text-zinc-400"><%= role.capitalize %></span>
        <% end %>
      </div>
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <div class="text-xs text-zinc-500 mb-0.5">Joined</div>
          <div class="text-zinc-300"><%= @user.created_at.strftime("%B %d, %Y") %></div>
        </div>
        <div>
          <div class="text-xs text-zinc-500 mb-0.5">Identity status</div>
          <div class="text-zinc-300"><%= @user.identity_status.capitalize %></div>
        </div>
      </div>
    </div>

    <% if @developer_profile %>
      <div class="rounded-2xl border border-white/5 bg-white/2 p-6">
        <h2 class="text-sm font-semibold text-white mb-4">Developer profile</h2>
        <div class="grid grid-cols-2 gap-4 text-sm">
          <% [
            { label: "Verification", value: @developer_profile.verification_status.capitalize },
            { label: "Stripe Connect", value: @developer_profile.connect_onboarding_status.capitalize },
            { label: "GitHub", value: @developer_profile.github_username.present? ? "@#{@developer_profile.github_username}" : "Not connected" },
            { label: "Listed", value: @developer_profile.listed? ? "Yes" : "No" },
          ].each do |row| %>
            <div>
              <div class="text-xs text-zinc-500 mb-0.5"><%= row[:label] %></div>
              <div class="text-zinc-300"><%= row[:value] %></div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @submissions.any? %>
      <div class="rounded-2xl border border-white/5 bg-white/2 p-6">
        <h2 class="text-sm font-semibold text-white mb-4">Portfolio submissions</h2>
        <div class="space-y-3">
          <% @submissions.each do |sub| %>
            <div class="flex items-center justify-between gap-4">
              <div>
                <div class="text-sm text-zinc-300"><%= sub.title %></div>
                <a href="<%= sub.github_repo_url %>" target="_blank" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">
                  <%= sub.github_repo_url %> ↗
                </a>
              </div>
              <div class="flex items-center gap-2">
                <span class="px-2 py-0.5 rounded-full text-xs
                  <%= sub.status == 'approved' ? 'bg-green-500/10 text-green-400' :
                      sub.status == 'rejected' ? 'bg-red-500/10 text-red-400' :
                                                 'bg-yellow-500/10 text-yellow-400' %>">
                  <%= sub.status.capitalize %>
                </span>
                <%= link_to "Review →", admin_portfolio_submission_path(sub), class: "text-xs text-zinc-500 hover:text-white transition-colors" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="space-y-4">
    <% if @customer_profile %>
      <div class="rounded-2xl border border-white/5 bg-white/2 p-5">
        <h2 class="text-sm font-semibold text-white mb-4">Client profile</h2>
        <div class="space-y-2 text-sm">
          <div>
            <div class="text-xs text-zinc-500 mb-0.5">Identity</div>
            <div class="text-zinc-300"><%= @customer_profile.identity_status.capitalize %></div>
          </div>
          <% if @customer_profile.company_name.present? %>
            <div>
              <div class="text-xs text-zinc-500 mb-0.5">Company</div>
              <div class="text-zinc-300"><%= @customer_profile.company_name %></div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>