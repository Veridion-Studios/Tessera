<div class="mb-8">
  <h1 class="text-2xl font-bold text-white">Users</h1>
  <p class="text-zinc-400 text-sm mt-1"><%= @users.count %> total users.</p>
</div>

<div class="rounded-2xl border border-white/5 bg-white/2 overflow-hidden">
  <div class="divide-y divide-white/5">
    <% @users.each do |user| %>
      <div class="px-6 py-4 flex items-center justify-between gap-6">
        <div>
          <div class="flex items-center gap-2 mb-0.5">
            <span class="text-sm font-medium text-white"><%= user.email %></span>
            <% user.roles.each do |role| %>
              <span class="px-2 py-0.5 rounded-full text-xs bg-white/5 text-zinc-400 border border-white/10">
                <%= role.capitalize %>
              </span>
            <% end %>
          </div>
          <div class="text-xs text-zinc-600">Joined <%= user.created_at.strftime("%b %d, %Y") %></div>
        </div>
        <%= link_to "View →", admin_user_path(user), class: "text-xs text-zinc-400 hover:text-white transition-colors" %>
      </div>
    <% end %>
  </div>
</div>