<%# Locals: active_role, active_item, mobile_title (optional) %>
<div class="flex h-screen overflow-hidden bg-zinc-950" x-data="{ sidebarOpen: false }">
  <%= render "shared/sidebar", active_role: local_assigns[:active_role], active_item: local_assigns[:active_item] %>

  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <%# Mobile topbar %>
    <div class="lg:hidden flex items-center justify-between px-4 py-3 bg-zinc-950 border-b border-white/[0.04]">
      <button @click="sidebarOpen = true" class="text-zinc-500 hover:text-white p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
      </button>
      <span class="font-geist-sans text-sm font-semibold text-white"><%= local_assigns[:mobile_title] || "Tessera" %></span>
      <span class="w-7 h-7 rounded-full bg-primary/20 flex items-center justify-center text-primary text-xs font-bold"><%= current_user.email[0].upcase %></span>
    </div>

    <%# Island %>
    <main class="flex-1 overflow-y-auto p-4 lg:p-6">
      <div class="min-h-full rounded-2xl border border-white/[0.05] bg-zinc-900/50 backdrop-blur-sm overflow-auto">
        <div class="pointer-events-none fixed top-1/3 right-1/4 w-96 h-96 rounded-full bg-primary/4 blur-[120px] -z-10"></div>
        <%= yield %>
      </div>
    </main>
  </div>
</div>