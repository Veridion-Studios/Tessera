<%# Full-height sticky sidebar.
    Locals: active_role ("developer" | "customer"), active_item (symbol) %>
<% is_dev = local_assigns[:active_role] == "developer" %>
<% unread_count = current_user&.notifications&.unread&.count || 0 %>

<%# Mobile overlay %>
<div x-show="sidebarOpen"
     x-transition:enter="transition-opacity ease-out duration-200"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition-opacity ease-in duration-150"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     @click="sidebarOpen = false"
     class="fixed inset-0 bg-black/60 z-30 lg:hidden"
     style="display:none"></div>

<aside :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'"
       class="fixed lg:sticky top-0 left-0 z-40 w-64 h-screen flex flex-col border-r border-white/8 bg-zinc-950 py-6 pl-4 pr-4 transition-transform duration-200 ease-in-out">

  <%# Wordmark + close %>
  <div class="flex items-center justify-between px-3 mb-8">
    <%= link_to root_path, class: "font-geist-sans text-base font-semibold tracking-tight text-white" do %>Tessera<% end %>
    <button @click="sidebarOpen = false" class="lg:hidden text-zinc-500 hover:text-zinc-300 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
  </div>

  <%# Role badge %>
  <div class="mb-4 px-3">
    <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-zinc-500 uppercase tracking-widest">
      <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
      <%= is_dev ? "Developer" : "Client" %>
    </span>
  </div>

  <%# Main nav %>
  <nav class="flex flex-col gap-0.5 flex-1">
    <% items = is_dev ? [
      { label: "Overview",  path: developer_dashboard_path,            icon: "▦", key: :overview  },
      { label: "Portfolio", path: onboarding_developer_portfolio_path, icon: "◫", key: :portfolio },
      { label: "Projects",  path: "#",                                 icon: "⬡", key: :projects  },
      { label: "Earnings",  path: "#",                                 icon: "◈", key: :earnings  },
    ] : [
      { label: "Overview",   path: client_dashboard_path, icon: "▦", key: :overview   },
      { label: "Projects",   path: "#",                   icon: "⬡", key: :projects   },
      { label: "Developers", path: "#",                   icon: "◫", key: :developers },
      { label: "Payments",   path: "#",                   icon: "◈", key: :payments   },
    ] %>

    <% items.each do |item| %>
      <% active = local_assigns[:active_item] == item[:key] %>
      <%= link_to item[:path], class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors #{active ? 'bg-primary/10 text-primary font-medium' : 'text-zinc-400 hover:text-white hover:bg-white/5'}" do %>
        <span class="text-sm leading-none opacity-70"><%= item[:icon] %></span>
        <%= item[:label] %>
      <% end %>
    <% end %>
  </nav>

  <%# Bottom utility links %>
  <div class="flex flex-col gap-0.5 pt-4 border-t border-white/8 mb-1">

    <%# Notifications %>
    <% notif_active = local_assigns[:active_item] == :notifications %>
    <%= link_to notifications_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors #{notif_active ? 'bg-primary/10 text-primary font-medium' : 'text-zinc-400 hover:text-white hover:bg-white/5'}" do %>
      <span class="relative text-sm leading-none opacity-70">
        🔔
        <% if unread_count > 0 %>
          <span class="absolute -top-1 -right-1 h-3.5 w-3.5 rounded-full bg-primary flex items-center justify-center text-[8px] font-bold text-black leading-none"><%= unread_count > 9 ? "9+" : unread_count %></span>
        <% end %>
      </span>
      <span class="flex-1">Notifications</span>
      <% if unread_count > 0 %>
        <span class="shrink-0 px-1.5 py-0.5 rounded-full bg-primary/15 text-primary text-[10px] font-bold"><%= unread_count %></span>
      <% end %>
    <% end %>

    <%# Support - DISABLED %>
    <%# support_active = local_assigns[:active_item] == :support %>
    <%# link_to support_index_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors #{support_active ? 'bg-primary/10 text-primary font-medium' : 'text-zinc-400 hover:text-white hover:bg-white/5'}" %>
    <%# <span class="text-sm leading-none opacity-70">💬</span> %>
    <%# Support %>
    <%# end %>

    <%# Settings %>
    <% settings_active = local_assigns[:active_item] == :settings %>
    <%= link_to account_settings_path, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors #{settings_active ? 'bg-primary/10 text-primary font-medium' : 'text-zinc-400 hover:text-white hover:bg-white/5'}" do %>
      <span class="text-sm leading-none opacity-70">⚙</span>
      Settings
    <% end %>

  </div>

  <%# User section — pinned bottom %>
  <div class="relative px-1 mt-1" x-data="{ userOpen: false }" @click.outside="userOpen = false">

    <%# Dropdown — opens upward %>
    <div x-show="userOpen"
         x-transition:enter="transition ease-out duration-150"
         x-transition:enter-start="opacity-0 translate-y-1"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-100"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 translate-y-1"
         class="absolute bottom-full left-0 right-0 mb-2 rounded-xl border border-white/10 bg-zinc-900/95 backdrop-blur-sm shadow-xl shadow-black/50 z-50 overflow-hidden"
         style="display:none">

      <div class="px-4 py-3 border-b border-white/8">
        <p class="text-[11px] text-zinc-500 mb-0.5">Signed in as</p>
        <p class="text-sm text-white font-medium truncate"><%= current_user.email %></p>
        <%= link_to "Account settings", account_settings_path, class: "text-xs text-zinc-400 hover:text-primary transition-colors mt-1 block" %>
      </div>

      <% if current_user.multi_role? %>
        <div class="px-4 py-2 border-b border-white/8">
          <p class="text-[10px] text-zinc-500 uppercase tracking-widest mb-1.5">Switch to</p>
          <% if current_user.developer? && local_assigns[:active_role] != "developer" %>
            <%= link_to developer_dashboard_path, class: "flex items-center gap-2 py-1.5 text-sm text-zinc-300 hover:text-white transition-colors" do %><span>⌨️</span> Developer<% end %>
          <% end %>
          <% if current_user.customer? && local_assigns[:active_role] != "customer" %>
            <%= link_to client_dashboard_path, class: "flex items-center gap-2 py-1.5 text-sm text-zinc-300 hover:text-white transition-colors" do %><span>💼</span> Client<% end %>
          <% end %>
        </div>
      <% end %>

      <% if current_user.can_add_developer_role? || current_user.can_add_customer_role? %>
        <div class="px-4 py-2 border-b border-white/8">
          <p class="text-[10px] text-zinc-500 uppercase tracking-widest mb-1.5">Add profile</p>
          <% if current_user.can_add_developer_role? %>
            <%= link_to confirm_add_role_path(role: "developer"), class: "flex items-center gap-2 py-1.5 text-sm text-violet-400 hover:text-violet-300 transition-colors" do %><span>⌨️</span> Add Developer Profile<% end %>
          <% end %>
          <% if current_user.can_add_customer_role? %>
            <%= link_to confirm_add_role_path(role: "customer"), class: "flex items-center gap-2 py-1.5 text-sm text-indigo-400 hover:text-indigo-300 transition-colors" do %><span>💼</span> Add Client Profile<% end %>
          <% end %>
        </div>
      <% end %>

      <% if current_user.admin? %>
        <div class="px-4 py-2 border-b border-white/8">
          <%= link_to admin_root_path, class: "flex items-center gap-2 py-1.5 text-sm text-red-400 hover:text-red-300 transition-colors" do %><span>⚡</span> Admin panel<% end %>
        </div>
      <% end %>

      <div class="px-4 py-2.5">
        <%= button_to "Sign out", destroy_user_session_path, method: :delete,
            class: "text-sm text-zinc-400 hover:text-red-400 transition-colors bg-transparent border-0 cursor-pointer p-0",
            form: { class: "inline" } %>
      </div>
    </div>

    <%# Avatar trigger %>
    <button @click="userOpen = !userOpen"
            class="w-full flex items-center gap-3 px-2 py-2.5 rounded-lg hover:bg-white/5 transition-colors group">
      <span class="w-7 h-7 shrink-0 rounded-full bg-violet-500/20 border border-violet-500/30 flex items-center justify-center text-violet-300 text-xs font-bold"><%= current_user.email[0].upcase %></span>
      <div class="min-w-0 flex-1 text-left">
        <p class="text-xs font-medium text-zinc-300 truncate"><%= current_user.email.split("@").first %></p>
        <p class="text-[10px] text-zinc-500 truncate"><%= current_user.email %></p>
      </div>
      <svg class="w-3 h-3 text-zinc-500 shrink-0 group-hover:text-zinc-300 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/></svg>
    </button>
  </div>

</aside>