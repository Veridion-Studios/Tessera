<div class="flex h-screen overflow-hidden bg-zinc-950" x-data="{ sidebarOpen: false }">
  <%= render "shared/sidebar", active_role: session[:active_role], active_item: :support %>

  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <div class="lg:hidden flex items-center justify-between px-4 py-3 border-b border-white/8 bg-zinc-950/95 backdrop-blur-sm">
      <button @click="sidebarOpen = true" class="text-zinc-400 hover:text-white p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-geist-sans text-sm font-semibold text-white">Support</span>
      <span class="w-7 h-7 rounded-full bg-violet-500/20 border border-violet-500/30 flex items-center justify-center text-violet-300 text-xs font-bold"><%= current_user.email[0].upcase %></span>
    </div>

    <main class="flex-1 overflow-y-auto">
      <div class="max-w-2xl mx-auto px-6 lg:px-10 py-10">

        <div class="flex items-start justify-between mb-8">
          <div>
            <h1 class="font-geist-sans text-2xl font-semibold text-white tracking-tight">Support</h1>
            <p class="text-zinc-500 text-sm mt-1">Get help with your account or projects.</p>
          </div>
          <%= link_to "New ticket", new_support_path,
              class: "shrink-0 px-4 py-2 rounded-xl btn btn-primary text-sm font-medium" %>
        </div>

        <% if @conversations.any? %>
          <div class="rounded-xl border border-white/8 bg-zinc-900 overflow-hidden divide-y divide-white/5">
            <% @conversations.each do |conv| %>
              <%= link_to support_path(conv), class: "flex items-center gap-4 px-5 py-4 hover:bg-white/3 transition-colors" do %>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-0.5">
                    <span class="text-sm font-semibold text-zinc-100 truncate"><%= conv.subject %></span>
                    <span class="shrink-0 px-2 py-0.5 rounded-full text-[10px] font-semibold border <%= conv.status_color %>"><%= conv.status.capitalize %></span>
                  </div>
                  <p class="text-xs text-zinc-500">
                    <%= conv.messages.count %> message<%= conv.messages.count == 1 ? "" : "s" %>
                    · <%= conv.last_message_at ? "#{time_ago_in_words(conv.last_message_at)} ago" : "just opened" %>
                  </p>
                </div>
                <svg class="w-4 h-4 text-zinc-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-xl border border-dashed border-white/8 p-12 text-center">
            <div class="text-3xl mb-3">💬</div>
            <p class="text-zinc-400 text-sm font-medium mb-1">No support tickets yet</p>
            <p class="text-zinc-600 text-xs mb-5">Open a ticket and our team will get back to you within 24 hours.</p>
            <%= link_to "Open a ticket", new_support_path, class: "btn btn-primary btn-sm" %>
          </div>
        <% end %>

      </div>
    </main>
  </div>
</div>