<div class="flex h-screen overflow-hidden bg-zinc-950" x-data="{ sidebarOpen: false }">
  <%= render "shared/sidebar", active_role: session[:active_role], active_item: :support %>

  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <div class="lg:hidden flex items-center justify-between px-4 py-3 border-b border-white/8 bg-zinc-950/95 backdrop-blur-sm">
      <button @click="sidebarOpen = true" class="text-zinc-400 hover:text-white p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-geist-sans text-sm font-semibold text-white truncate max-w-[180px]"><%= @conversation.subject %></span>
      <span class="w-7 h-7 rounded-full bg-violet-500/20 border border-violet-500/30 flex items-center justify-center text-violet-300 text-xs font-bold"><%= current_user.email[0].upcase %></span>
    </div>

    <main class="flex-1 overflow-y-auto">
      <div class="max-w-2xl mx-auto px-6 lg:px-10 py-10">

        <%# Header %>
        <div class="flex items-start gap-4 mb-8">
          <%= link_to support_index_path, class: "mt-1 text-zinc-500 hover:text-zinc-300 transition-colors shrink-0" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          <% end %>
          <div class="flex-1 min-w-0">
            <h1 class="font-geist-sans text-xl font-semibold text-white truncate"><%= @conversation.subject %></h1>
            <div class="flex items-center gap-2 mt-1">
              <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold border <%= @conversation.status_color %>"><%= @conversation.status.capitalize %></span>
              <span class="text-xs text-zinc-500">Opened <%= time_ago_in_words(@conversation.created_at) %> ago</span>
            </div>
          </div>
        </div>

        <%# Message thread %>
        <div id="messages" class="space-y-4 mb-8">
          <% @messages.each do |msg| %>
            <% from_me = msg.author_id == current_user.id %>
            <div class="flex <%= from_me ? 'justify-end' : 'justify-start' %>">
              <div class="max-w-[85%]">
                <div class="flex items-center gap-2 mb-1 <%= from_me ? 'justify-end' : 'justify-start' %>">
                  <span class="text-[10px] text-zinc-500">
                    <%= from_me ? "You" : "Support" %>
                    · <%= time_ago_in_words(msg.created_at) %> ago
                  </span>
                  <% if msg.source == "email" %>
                    <span class="text-[10px] text-zinc-600 border border-white/8 px-1.5 py-0.5 rounded">via email</span>
                  <% end %>
                </div>
                <div class="px-4 py-3 rounded-2xl text-sm leading-relaxed <%= from_me ? 'bg-primary/15 border border-primary/20 text-zinc-100 rounded-tr-sm' : 'bg-zinc-800 border border-white/8 text-zinc-200 rounded-tl-sm' %>">
                  <%= msg.body %>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <%# Reply form %>
        <% if @conversation.open? %>
          <div class="rounded-xl border border-white/8 bg-zinc-900 p-4">
            <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-3">Reply</h2>
            <%= form_with url: support_messages_path(@conversation), method: :post do |f| %>
              <textarea name="message[body]" rows="3" placeholder="Type your reply…"
                        class="w-full px-4 py-2.5 rounded-xl bg-zinc-800 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/50 transition-colors resize-none mb-3"></textarea>
              <%= f.submit "Send reply →", class: "px-5 py-2.5 rounded-xl btn btn-primary text-sm font-medium cursor-pointer" %>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-xl border border-white/8 bg-zinc-900 px-5 py-4 text-center">
            <p class="text-zinc-500 text-sm">This ticket is closed.</p>
          </div>
        <% end %>

      </div>
    </main>
  </div>
</div>