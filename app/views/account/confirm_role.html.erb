<% is_dev = @role == "developer" %>

<%= render layout: "shared/auth_shell", locals: { back_path: pick_dashboard_path, back_label: "Back" } do %>
  <div class="w-full max-w-sm">
    <div class="rounded-2xl border border-white/8 bg-white/2 p-8 text-center">
      <div class="w-14 h-14 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center text-2xl mx-auto mb-5">
        <%= is_dev ? "⌨️" : "💼" %>
      </div>
      <h1 class="font-geist-sans text-xl font-semibold text-white mb-2">
        Add a <%= is_dev ? "Developer" : "Client" %> profile?
      </h1>
      <p class="text-zinc-500 text-sm leading-relaxed mb-8">
        <% if is_dev %>
          You'll go through the developer onboarding — portfolio submission, identity verification, and Stripe Connect setup.
        <% else %>
          A client profile lets you browse verified developers and request project quotes.
        <% end %>
      </p>
      <div class="flex flex-col gap-3">
        <%= button_to "Yes, add #{is_dev ? 'developer' : 'client'} profile", add_role_path,
            params: { role: @role },
            class: "w-full py-2.5 rounded-xl btn btn-primary text-sm cursor-pointer" %>
        <%= link_to "Cancel", pick_dashboard_path,
            class: "block w-full py-2.5 rounded-xl border border-white/8 hover:bg-white/5 text-zinc-500 text-sm transition-colors" %>
      </div>
    </div>
  </div>
<% end %>