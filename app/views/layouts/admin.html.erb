<!DOCTYPE html>
<html lang="en" class="dark bg-zinc-950 text-white">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Tessera Admin</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= vite_client_tag %>
    <%= vite_javascript_tag "application" %>
    <%= vite_stylesheet_tag "application" %>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  </head>
  <body class="min-h-screen bg-zinc-950 text-white antialiased">
    <% if flash[:notice] || flash[:alert] %>
      <div id="toast-container"
           x-data="{ toasts: <%= [flash[:notice] ? { type: 'notice', msg: flash[:notice] } : nil, flash[:alert] ? { type: 'alert', msg: flash[:alert] } : nil].compact.to_json.html_safe %> }"
           class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none"
           x-init="setTimeout(() => toasts = [], 4500)">
        <template x-for="(toast, i) in toasts" :key="i">
          <div x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-x-4" x-transition:enter-end="opacity-100 translate-x-0"
               :class="toast.type === 'notice' ? 'border-primary/25 text-primary' : 'border-red-500/25 text-red-400'"
               class="pointer-events-auto flex items-start gap-3 px-4 py-3 rounded-xl border bg-zinc-900 shadow-xl shadow-black/40 min-w-[260px] max-w-sm">
            <span x-text="toast.type === 'notice' ? '✓' : '⚠'" class="shrink-0 text-sm font-bold mt-0.5"></span>
            <span x-text="toast.msg" class="text-sm text-zinc-200 flex-1"></span>
            <button @click="toasts.splice(i, 1)" class="shrink-0 text-zinc-500 hover:text-zinc-300 text-xs">✕</button>
          </div>
        </template>
      </div>
    <% end %>

    <div class="flex h-screen overflow-hidden bg-zinc-950" x-data="{ sidebarOpen: false }">
      <%= render "shared/sidebar", active_role: "admin", active_item: controller.action_name == "index" && controller.controller_name == "dashboard" ? :overview : controller.controller_name.to_sym %>

      <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
        <div class="lg:hidden flex items-center justify-between px-4 py-3 bg-zinc-950 border-b border-white/[0.04]">
          <button @click="sidebarOpen = true" class="text-zinc-500 hover:text-white p-1">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
          </button>
          <span class="font-geist-sans text-sm font-semibold text-white">Admin</span>
          <span class="w-7 h-7 rounded-full bg-red-500/20 flex items-center justify-center text-red-300 text-xs font-bold"><%= current_user.email[0].upcase %></span>
        </div>

        <main class="flex-1 overflow-y-auto p-4 lg:p-6">
          <div class="min-h-full rounded-2xl border border-white/[0.05] bg-zinc-900/50 backdrop-blur-sm overflow-auto">
            <div class="pointer-events-none fixed top-1/3 right-1/4 w-96 h-96 rounded-full bg-red-500/3 blur-[120px] -z-10"></div>
            <%= yield %>
          </div>
        </main>
      </div>
    </div>
  </body>
</html>