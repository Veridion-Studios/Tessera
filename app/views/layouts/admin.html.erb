<!DOCTYPE html>
<html lang="en" class="dark bg-zinc-950 text-white">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Tessera Admin</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= vite_client_tag %>
    <%= vite_javascript_tag "application" %>
    <%= vite_stylesheet_tag "application" %>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  </head>
  <body class="min-h-screen bg-zinc-950 text-white antialiased">
    <div class="flex h-screen overflow-hidden bg-zinc-950" x-data="{ sidebarOpen: false }">

      <%# Mobile overlay %>
      <div x-show="sidebarOpen" @click="sidebarOpen = false"
           class="fixed inset-0 bg-black/60 z-30 lg:hidden" style="display:none"></div>

      <%# Sidebar %>
            <aside :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full lg:translate-x-0'"
              class="fixed lg:sticky top-0 left-0 z-40 w-56 h-screen flex flex-col border-r border-white/8 bg-zinc-950 py-6 pl-4 pr-4 transition-transform duration-200">

        <div class="px-3 mb-2 flex items-center justify-between">
          <div>
            <a href="/" class="font-geist-sans text-base font-semibold tracking-tight text-white block">Tessera</a>
            <div class="text-[10px] text-zinc-500 font-bold uppercase tracking-widest mt-0.5">Admin</div>
          </div>
          <button @click="sidebarOpen = false" class="lg:hidden text-zinc-500 hover:text-zinc-300 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <div class="mb-5 px-3">
          <span class="inline-flex items-center gap-1.5 text-[10px] font-bold text-red-400 uppercase tracking-widest">
            <span class="h-1.5 w-1.5 rounded-full bg-red-500 animate-pulse"></span>
            Internal
          </span>
        </div>

        <nav class="flex flex-col gap-0.5 flex-1">
          <% [
            { label: "Overview",    path: admin_root_path,                 icon: "▦", match: "^/admin$" },
            { label: "Users",       path: admin_users_path,                icon: "◫", match: "/admin/users" },
            { label: "Submissions", path: admin_portfolio_submissions_path, icon: "📁", match: "/admin/portfolio" },
            { label: "Support",     path: admin_support_index_path,        icon: "💬", match: "/admin/support" },
          ].each do |item| %>
            <% active = request.path.match?(item[:match]) %>
            <%= link_to item[:path], class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors #{active ? 'bg-red-500/10 text-red-400 font-medium' : 'text-zinc-400 hover:text-white hover:bg-white/5'}" do %>
              <span class="text-sm leading-none opacity-70"><%= item[:icon] %></span>
              <%= item[:label] %>
            <% end %>
          <% end %>
        </nav>

        <div class="pt-4 border-t border-white/8 px-3 flex items-center gap-3">
          <span class="w-7 h-7 rounded-full bg-red-500/20 border border-red-500/30 flex items-center justify-center text-red-300 text-xs font-bold"><%= current_user.email[0].upcase %></span>
          <div class="min-w-0 flex-1">
            <p class="text-xs font-medium text-zinc-300 truncate"><%= current_user.email.split("@").first %></p>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                class: "text-[10px] text-zinc-500 hover:text-red-400 transition-colors bg-transparent border-0 cursor-pointer p-0",
                form: { class: "inline" } %>
          </div>
        </div>
      </aside>

      <%# Content %>
      <div class="flex-1 flex flex-col min-w-0 min-h-0 overflow-hidden">

        <%# Mobile top bar %>
        <div class="lg:hidden flex items-center justify-between px-4 py-3 border-b border-white/8 bg-zinc-950/95 backdrop-blur-sm">
          <button @click="sidebarOpen = true" class="text-zinc-400 hover:text-white transition-colors p-1">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <span class="font-geist-sans text-sm font-semibold text-white">Admin</span>
          <span class="w-7 h-7 rounded-full bg-red-500/20 border border-red-500/30 flex items-center justify-center text-red-300 text-xs font-bold"><%= current_user.email[0].upcase %></span>
        </div>

        <main class="flex-1 min-h-0 overflow-y-auto px-6 lg:px-10 py-10">
          <% if flash[:notice] %>
            <div class="mb-6 rounded-xl border border-green-500/20 bg-green-500/10 px-4 py-3 text-green-400 text-sm"><%= flash[:notice] %></div>
          <% end %>
          <% if flash[:alert] %>
            <div class="mb-6 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-red-400 text-sm"><%= flash[:alert] %></div>
          <% end %>
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>