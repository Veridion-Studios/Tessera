<!DOCTYPE html>
<html lang="en" class="dark bg-zinc-950 text-white">
  <head>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&family=IBM+Plex+Sans:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet">
    <title>Tessera</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <script nonce="<%= content_security_policy_nonce %>">
      window.__CURRENT_USER = <%= (current_user ? {
        id: current_user.id
      }.to_json.html_safe : 'null') %>;
      <% if current_user %>
      <% email_hash = compute_plain_email_hash(current_user.email) %>
      <% if email_hash.present? %>
      window.__PLAIN_AUTH = {
        emailHash: '<%= email_hash %>',
        externalId: '<%= current_user.id %>'
      };
      <% end %>
      <% end %>
    </script>
    <%= vite_client_tag %>
    <%= vite_javascript_tag "application" %>
    <%= vite_stylesheet_tag "application" %>
    <%= defined?(Sentry) ? Sentry.get_trace_propagation_meta.html_safe : "" %>
  </head>
  <body class="min-h-screen bg-zinc-950 text-white antialiased">
    <%# Flash toasts — auto-dismiss after 4s %>
    <% if flash[:notice] || flash[:alert] %>
      <div id="toast-container"
           x-data="{ toasts: <%= [
             flash[:notice] ? { type: 'notice', msg: flash[:notice] } : nil,
             flash[:alert]  ? { type: 'alert',  msg: flash[:alert]  } : nil
           ].compact.to_json.html_safe %> }"
           class="fixed top-4 right-4 z-[100] flex flex-col gap-2 pointer-events-none"
           x-init="setTimeout(() => toasts = [], 4500)">
        <template x-for="(toast, i) in toasts" :key="i">
          <div x-transition:enter="transition ease-out duration-300"
               x-transition:enter-start="opacity-0 translate-x-4"
               x-transition:enter-end="opacity-100 translate-x-0"
               x-transition:leave="transition ease-in duration-200"
               x-transition:leave-start="opacity-100 translate-x-0"
               x-transition:leave-end="opacity-0 translate-x-4"
               :class="toast.type === 'notice'
                 ? 'border-primary/25 bg-zinc-900 text-primary'
                 : 'border-red-500/25 bg-zinc-900 text-red-400'"
               class="pointer-events-auto flex items-start gap-3 px-4 py-3 rounded-xl border shadow-xl shadow-black/40 min-w-[260px] max-w-sm">
            <span x-text="toast.type === 'notice' ? '✓' : '⚠'" class="shrink-0 text-sm font-bold mt-0.5"></span>
            <span x-text="toast.msg" class="text-sm text-zinc-200 flex-1"></span>
            <button @click="toasts.splice(i, 1)" class="shrink-0 text-zinc-500 hover:text-zinc-300 transition-colors text-xs">✕</button>
          </div>
        </template>
      </div>
    <% end %>

    <%= yield %>
    <!-- Sentry user feedback speed dial -->
    <div class="fab fixed bottom-6 right-6 z-40">
      <!-- a focusable div with tabindex is necessary to work on all browsers. role="button" is necessary for accessibility -->
      <div tabindex="0" role="button" class="btn btn-lg btn-circle btn-success shadow-lg" aria-label="Open support actions">
        +
      </div>

      <!-- buttons that show up when FAB is open -->
      <div class="flex items-center gap-3">
        <span class="text-xs text-zinc-300 whitespace-nowrap">Feedback</span>
        <button id="sentry-feedback-btn" type="button" class="btn btn-lg btn-circle btn-primary shadow-lg" aria-label="Open feedback modal">F</button>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-xs text-zinc-300 whitespace-nowrap">Docs</span>
        <a href="https://docs.sentry.io/platforms/javascript/user-feedback/#user-feedback-api" target="_blank" rel="noreferrer" class="btn btn-lg btn-circle btn-neutral shadow-lg" aria-label="Open docs">D</a>
      </div>
    </div>

    <!-- Sentry feedback modal (DaisyUI/Tailwind style, hidden by default) -->
    <div id="sentry-feedback-modal" class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4" aria-hidden="true">
      <div class="absolute inset-0 bg-black/70 backdrop-blur-sm"></div>
      <div class="relative w-full sm:max-w-lg bg-zinc-950 border border-white/10 rounded-t-2xl sm:rounded-2xl shadow-2xl overflow-hidden">
        <div class="px-6 py-5 border-b border-white/8 flex items-center justify-between">
          <h2 class="font-geist-sans text-base font-semibold text-white">Report a problem</h2>
          <button id="sentry-feedback-close" class="text-zinc-500 hover:text-zinc-300 transition-colors p-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <form id="sentry-feedback-form" class="px-6 py-5 space-y-4">
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2.5">Your name (optional)</label>
            <input name="sentry_name" type="text" value="<%= h(current_user&.developer_profile&.display_name || current_user&.customer_profile&.display_name || '') %>" class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none" />
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2.5">Email (optional)</label>
            <input name="sentry_email" type="email" value="<%= h(current_user&.email || '') %>" class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none" />
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2.5">Message</label>
            <textarea name="sentry_message" rows="4" class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none resize-none" required></textarea>
          </div>
          <div class="pt-2 pb-1 flex items-center gap-2">
            <button type="submit" class="ml-auto py-2.5 px-4 rounded-xl btn btn-primary text-sm font-medium">Send feedback</button>
          </div>
        </form>
      </div>
    </div>
  </body>
</html>
