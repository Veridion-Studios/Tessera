<% content_for :title, "Notifications" %>

<div class="flex h-screen overflow-hidden bg-zinc-950" x-data="{ sidebarOpen: false }">
  <%= render "shared/sidebar", active_role: session[:active_role], active_item: :notifications %>

  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <%# Mobile top bar %>
    <div class="lg:hidden flex items-center justify-between px-4 py-3 border-b border-white/8 bg-zinc-950/95 backdrop-blur-sm">
      <button @click="sidebarOpen = true" class="text-zinc-400 hover:text-white p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-geist-sans text-sm font-semibold text-white">Notifications</span>
      <span class="w-7 h-7 rounded-full bg-violet-500/20 border border-violet-500/30 flex items-center justify-center text-violet-300 text-xs font-bold"><%= current_user.email[0].upcase %></span>
    </div>

    <main class="flex-1 overflow-y-auto">
      <div class="max-w-2xl mx-auto px-6 lg:px-10 py-10">

        <div class="flex items-center justify-between mb-8">
          <div>
            <h1 class="font-geist-sans text-2xl font-semibold text-white tracking-tight">Notifications</h1>
            <p class="text-zinc-500 text-sm mt-1"><%= @notifications.count %> total</p>
          </div>
          <% if @notifications.any? %>
            <%= button_to "Mark all read", mark_all_notifications_path, method: :post,
                class: "px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-zinc-300 text-xs font-medium transition-colors cursor-pointer" %>
          <% end %>
        </div>

        <% if @notifications.any? %>
          <div class="rounded-xl border border-white/8 bg-zinc-900 overflow-hidden divide-y divide-white/5">
            <% @notifications.each do |notif| %>
              <% unread = notif.read_at.nil? %>
              <div class="flex items-start gap-4 px-5 py-4 <%= unread ? 'bg-primary/3' : '' %> hover:bg-white/3 transition-colors">
                <%# Unread dot %>
                <div class="mt-1.5 shrink-0">
                  <% if unread %>
                    <span class="h-2 w-2 rounded-full bg-primary block"></span>
                  <% else %>
                    <span class="h-2 w-2 rounded-full bg-zinc-700 block"></span>
                  <% end %>
                </div>

                <div class="flex-1 min-w-0">
                  <p class="text-sm <%= unread ? 'text-zinc-100 font-medium' : 'text-zinc-400' %> leading-snug">
                    <%= begin; notif.message; rescue; notif.type.demodulize.underscore.humanize; end %>
                  </p>
                  <p class="text-xs text-zinc-600 mt-1"><%= time_ago_in_words(notif.created_at) %> ago</p>
                </div>

                <% url = begin; notif.url; rescue; nil; end %>
                <% if url %>
                  <%= link_to "View →", url, class: "shrink-0 text-xs text-primary hover:text-primary/80 transition-colors font-medium mt-1" %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-xl border border-dashed border-white/8 p-12 text-center">
            <div class="text-3xl mb-3">🔔</div>
            <p class="text-zinc-400 text-sm font-medium mb-1">You're all caught up</p>
            <p class="text-zinc-600 text-xs">Notifications about your submissions, identity, and support tickets will appear here.</p>
          </div>
        <% end %>

      </div>
    </main>
  </div>
</div>