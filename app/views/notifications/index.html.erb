<%= render layout: "shared/dashboard_shell", locals: { active_role: session[:active_role], active_item: :notifications, mobile_title: "Notifications" } do %>
  <div class="px-6 lg:px-10 py-10">

    <div class="flex items-center justify-between mb-8">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1.5"><%= session[:active_role]&.capitalize %></p>
        <h1 class="font-geist-sans text-2xl font-semibold text-white tracking-tight">Notifications</h1>
        <p class="text-zinc-500 text-sm mt-1"><%= @notifications.count %> total</p>
      </div>
      <% if @notifications.any? %>
        <%= button_to "Mark all read", mark_all_notifications_path, method: :post,
            class: "px-4 py-2 rounded-xl bg-white/[0.05] hover:bg-white/[0.08] text-zinc-400 text-xs font-medium transition-colors cursor-pointer" %>
      <% end %>
    </div>

    <% if @notifications.any? %>
      <div class="space-y-0">
        <% @notifications.each do |notif| %>
          <% unread = notif.read_at.nil? %>
          <% url = begin; notif.url; rescue; nil; end %>
          <div class="flex items-start gap-4 py-4 border-b border-white/[0.04] last:border-0 <%= unread ? 'bg-primary/[0.02]' : '' %> -mx-2 px-2 rounded-lg">
            <span class="mt-1.5 shrink-0 h-1.5 w-1.5 rounded-full <%= unread ? 'bg-primary' : 'bg-zinc-800' %>"></span>
            <div class="flex-1 min-w-0">
              <p class="text-sm <%= unread ? 'text-zinc-100 font-medium' : 'text-zinc-400' %> leading-snug">
                <%= begin; notif.message; rescue; notif.type.demodulize.underscore.humanize; end %>
              </p>
              <p class="text-xs text-zinc-700 mt-1"><%= time_ago_in_words(notif.created_at) %> ago</p>
            </div>
            <% if url %>
              <%= link_to "View →", url, class: "shrink-0 text-xs text-primary hover:text-primary/70 transition-colors font-medium mt-1" %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center py-20 text-center">
        <p class="text-zinc-500 text-sm font-medium mb-1">All caught up</p>
        <p class="text-zinc-700 text-xs">Notifications about submissions, identity, and projects appear here.</p>
      </div>
    <% end %>

  </div>
<% end %>