<div class="flex h-screen overflow-hidden bg-zinc-950" x-data="{ sidebarOpen: false }">
  <%= render "shared/sidebar", active_role: "customer", active_item: :quotes %>

  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <div class="lg:hidden flex items-center justify-between px-4 py-3 border-b border-white/8 bg-zinc-950/95 backdrop-blur-sm">
      <button @click="sidebarOpen = true" class="text-zinc-400 hover:text-white p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-geist-sans text-sm font-semibold text-white">Quotes</span>
      <span class="w-7 h-7 rounded-full bg-violet-500/20 border border-violet-500/30 flex items-center justify-center text-violet-300 text-xs font-bold"><%= current_user.email[0].upcase %></span>
    </div>

    <main class="flex-1 overflow-y-auto">
      <div class="max-w-4xl mx-auto px-6 lg:px-10 py-10">

        <div class="flex items-start justify-between mb-10">
          <div>
            <p class="text-[11px] font-bold uppercase tracking-widest text-zinc-500 mb-2">Client</p>
            <h1 class="font-geist-sans text-3xl font-semibold text-white tracking-tight">Quotes</h1>
            <p class="text-zinc-400 text-sm mt-1">Project requests you've sent to developers.</p>
          </div>
          <%# Browse developers CTA — links to gallery when built %>
          <%= link_to "Request a quote", "#", class: "shrink-0 mt-1 btn btn-primary btn-sm" %>
        </div>

        <% if @quotes.any? %>
          <div class="space-y-3">
            <% @quotes.each do |quote| %>
              <%= link_to client_quote_path(quote), class: "group block rounded-xl border border-white/8 bg-zinc-900 hover:border-white/16 hover:bg-zinc-800/80 transition-all p-5" do %>
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2.5 mb-1">
                      <span class="text-base font-semibold text-zinc-100 group-hover:text-white transition-colors truncate"><%= quote.title %></span>
                      <span class="shrink-0 px-2.5 py-0.5 rounded-full text-[10px] font-semibold border <%= quote.status_color %>">
                        <%= quote.status_label %>
                      </span>
                    </div>
                    <p class="text-zinc-500 text-sm truncate mb-3"><%= truncate(quote.description, length: 100) %></p>
                    <div class="flex flex-wrap items-center gap-4 text-xs text-zinc-500">
                      <span class="flex items-center gap-1.5">
                        <span class="text-zinc-600">To</span>
                        <span class="text-zinc-300 font-medium"><%= quote.developer.email.split("@").first %></span>
                      </span>
                      <span class="flex items-center gap-1.5">
                        <span class="text-zinc-600">Budget</span>
                        <span class="text-zinc-300"><%= quote.budget_display %></span>
                      </span>
                      <span class="flex items-center gap-1.5">
                        <span class="text-zinc-600">Timeline</span>
                        <span class="text-zinc-300"><%= quote.timeline %></span>
                      </span>
                      <span class="text-zinc-600"><%= time_ago_in_words(quote.created_at) %> ago</span>
                    </div>
                  </div>
                  <div class="shrink-0 flex flex-col items-end gap-2">
                    <% unread = quote.thread_messages.where(read_by_customer: false).count %>
                    <% if unread > 0 %>
                      <span class="px-2 py-0.5 rounded-full bg-primary/15 border border-primary/25 text-primary text-[10px] font-bold"><%= unread %> new</span>
                    <% end %>
                    <svg class="w-4 h-4 text-zinc-600 group-hover:text-zinc-400 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-xl border border-dashed border-white/8 p-16 text-center">
            <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl mx-auto mb-4">💬</div>
            <h3 class="text-zinc-200 font-semibold text-sm mb-1">No quotes yet</h3>
            <p class="text-zinc-500 text-sm mb-6 max-w-xs mx-auto">Browse verified developers and send a project request to get a quote.</p>
            <%= link_to "Browse developers", "#", class: "btn btn-primary btn-sm" %>
          </div>
        <% end %>

      </div>
    </main>
  </div>
</div>