<div class="flex h-screen overflow-hidden bg-zinc-950" x-data="{ sidebarOpen: false, showWithdraw: false, showCounter: false }">
  <%= render "shared/sidebar", active_role: "customer", active_item: :quotes %>

  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <div class="lg:hidden flex items-center justify-between px-4 py-3 border-b border-white/8 bg-zinc-950/95 backdrop-blur-sm">
      <button @click="sidebarOpen = true" class="text-zinc-400 hover:text-white p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <span class="font-geist-sans text-sm font-semibold text-white truncate max-w-[200px]"><%= @quote.title %></span>
      <span class="w-7 h-7 rounded-full bg-violet-500/20 border border-violet-500/30 flex items-center justify-center text-violet-300 text-xs font-bold"><%= current_user.email[0].upcase %></span>
    </div>

    <main class="flex-1 overflow-y-auto">
      <div class="max-w-4xl mx-auto px-6 lg:px-10 py-10">

        <%# Back + header %>
        <div class="flex items-start gap-4 mb-8">
          <%= link_to client_quotes_path, class: "mt-1.5 text-zinc-500 hover:text-zinc-300 transition-colors shrink-0" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          <% end %>
          <div class="flex-1 min-w-0">
            <h1 class="font-geist-sans text-2xl font-semibold text-white truncate"><%= @quote.title %></h1>
            <div class="flex flex-wrap items-center gap-2 mt-1.5">
              <span class="px-2.5 py-0.5 rounded-full text-[10px] font-semibold border <%= @quote.status_color %>"><%= @quote.status_label %></span>
              <span class="text-xs text-zinc-500">Sent to <span class="text-zinc-300"><%= @quote.developer.email.split("@").first %></span></span>
              <span class="text-xs text-zinc-600"><%= time_ago_in_words(@quote.created_at) %> ago</span>
            </div>
          </div>
          <% if @quote.open? %>
            <button @click="showWithdraw = true"
                    class="shrink-0 px-3 py-1.5 rounded-lg bg-zinc-800 hover:bg-zinc-700 border border-white/10 text-zinc-400 hover:text-zinc-200 text-xs font-medium transition-colors">
              Withdraw
            </button>
          <% end %>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

          <%# Left — thread %>
          <div class="lg:col-span-2 space-y-4">

            <%# Project brief card %>
            <div class="rounded-xl border border-white/8 bg-zinc-900 p-5">
              <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-4">Project brief</h2>
              <p class="text-zinc-300 text-sm leading-relaxed mb-4"><%= @quote.description %></p>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                <div class="rounded-lg bg-zinc-800 border border-white/5 px-3 py-2.5">
                  <p class="text-[10px] text-zinc-500 mb-0.5">Budget</p>
                  <p class="text-sm font-semibold text-zinc-200"><%= @quote.budget_display %></p>
                </div>
                <div class="rounded-lg bg-zinc-800 border border-white/5 px-3 py-2.5">
                  <p class="text-[10px] text-zinc-500 mb-0.5">Timeline</p>
                  <p class="text-sm font-semibold text-zinc-200"><%= @quote.timeline %></p>
                </div>
                <div class="rounded-lg bg-zinc-800 border border-white/5 px-3 py-2.5">
                  <p class="text-[10px] text-zinc-500 mb-0.5">Type</p>
                  <p class="text-sm font-semibold text-zinc-200 capitalize"><%= @quote.engagement_type %></p>
                </div>
              </div>
              <% if @quote.tech_tags.any? %>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <% @quote.tech_tags.each do |tag| %>
                    <span class="px-2.5 py-1 rounded-full bg-primary/8 border border-primary/15 text-primary text-xs"><%= tag %></span>
                  <% end %>
                </div>
              <% end %>
            </div>

            <%# Message thread %>
            <div class="rounded-xl border border-white/8 bg-zinc-900 overflow-hidden">
              <div class="px-5 py-4 border-b border-white/8">
                <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">Thread</h2>
              </div>

              <div class="divide-y divide-white/5">
                <% @messages.each do |msg| %>
                  <% from_me = msg.author_id == current_user.id %>
                  <% is_system = msg.system? %>

                  <% if is_system %>
                    <div class="px-5 py-3 flex items-center justify-center">
                      <span class="text-xs text-zinc-600 italic"><%= msg.body %></span>
                    </div>
                  <% elsif msg.proposal? %>
                    <div class="px-5 py-4 bg-violet-500/3 border-l-2 border-violet-500/40">
                      <div class="flex items-center gap-2 mb-2">
                        <span class="text-xs font-bold text-violet-400 uppercase tracking-wider">Counter-proposal</span>
                        <span class="text-xs text-zinc-500">from <%= msg.from_developer? ? "developer" : "you" %></span>
                      </div>
                      <% if msg.proposed_amount %>
                        <p class="text-sm text-zinc-300 mb-1">Proposed amount: <span class="font-semibold text-white">$<%= number_with_delimiter(msg.proposed_amount.to_i) %></span></p>
                      <% end %>
                      <% if msg.proposed_timeline %>
                        <p class="text-sm text-zinc-300 mb-1">Timeline: <span class="font-semibold text-white"><%= msg.proposed_timeline %></span></p>
                      <% end %>
                      <% if msg.body.present? %>
                        <p class="text-sm text-zinc-400 mt-2 leading-relaxed"><%= msg.body %></p>
                      <% end %>
                    </div>
                  <% elsif msg.kind == "acceptance" %>
                    <div class="px-5 py-4 bg-green-500/3 border-l-2 border-green-500/40">
                      <span class="text-xs font-bold text-green-400 uppercase tracking-wider block mb-1">Accepted</span>
                      <p class="text-sm text-zinc-300"><%= msg.body %></p>
                    </div>
                  <% elsif msg.kind == "decline" %>
                    <div class="px-5 py-4 bg-red-500/3 border-l-2 border-red-500/40">
                      <span class="text-xs font-bold text-red-400 uppercase tracking-wider block mb-1">Declined</span>
                      <p class="text-sm text-zinc-300"><%= msg.body %></p>
                    </div>
                  <% else %>
                    <div class="px-5 py-4">
                      <div class="flex items-center gap-2 mb-2">
                        <span class="w-6 h-6 rounded-full <%= from_me ? 'bg-blue-500/20 border border-blue-500/30 text-blue-300' : 'bg-violet-500/20 border border-violet-500/30 text-violet-300' %> flex items-center justify-center text-[10px] font-bold"><%= msg.author.email[0].upcase %></span>
                        <span class="text-xs font-medium <%= from_me ? 'text-zinc-300' : 'text-zinc-400' %>"><%= from_me ? "You" : "Developer" %></span>
                        <span class="text-xs text-zinc-600"><%= time_ago_in_words(msg.created_at) %> ago</span>
                      </div>
                      <p class="text-sm text-zinc-300 leading-relaxed"><%= msg.body %></p>
                    </div>
                  <% end %>
                <% end %>
              </div>

              <%# Reply box %>
              <% if @quote.open? %>
                <div class="px-5 py-4 border-t border-white/8 bg-zinc-950/50">
                  <%= form_with url: message_client_quote_path(@quote), method: :post, class: "flex gap-3 items-end" do |f| %>
                    <textarea name="body" rows="2" placeholder="Send a message…"
                              class="flex-1 px-4 py-2.5 rounded-xl bg-zinc-800 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/50 transition-colors resize-none"></textarea>
                    <%= f.submit "Send", class: "shrink-0 px-4 py-2.5 rounded-xl btn btn-primary text-sm font-medium cursor-pointer" %>
                  <% end %>
                </div>
              <% end %>
            </div>

          </div>

          <%# Right — meta + milestones %>
          <div class="space-y-4">

            <%# Accepted terms %>
            <% if @quote.accepted? %>
              <div class="rounded-xl border border-green-500/20 bg-green-500/5 p-5">
                <div class="flex items-center gap-2 mb-3">
                  <span class="h-2 w-2 rounded-full bg-green-500"></span>
                  <h3 class="text-xs font-bold uppercase tracking-widest text-green-400">Agreed terms</h3>
                </div>
                <% if @quote.agreed_amount %>
                  <div class="mb-2"><p class="text-[10px] text-zinc-500 mb-0.5">Amount</p><p class="text-sm font-semibold text-white">$<%= number_with_delimiter(@quote.agreed_amount.to_i) %></p></div>
                <% end %>
                <% if @quote.agreed_timeline %>
                  <div class="mb-2"><p class="text-[10px] text-zinc-500 mb-0.5">Timeline</p><p class="text-sm font-semibold text-white"><%= @quote.agreed_timeline %></p></div>
                <% end %>
                <% if @quote.estimated_start_date %>
                  <div><p class="text-[10px] text-zinc-500 mb-0.5">Starts</p><p class="text-sm font-semibold text-white"><%= @quote.estimated_start_date.strftime("%b %d, %Y") %></p></div>
                <% end %>
              </div>
            <% end %>

            <%# Milestones %>
            <div class="rounded-xl border border-white/8 bg-zinc-900 p-5">
              <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-4">Milestones</h3>
              <% if @milestones.any? %>
                <div class="space-y-2.5">
                  <% @milestones.each_with_index do |ms, i| %>
                    <div class="flex items-start gap-3">
                      <span class="w-5 h-5 rounded-full bg-zinc-800 border border-white/10 flex items-center justify-center text-[10px] text-zinc-500 shrink-0 mt-0.5"><%= i + 1 %></span>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between gap-2">
                          <p class="text-sm text-zinc-200 font-medium truncate"><%= ms.title %></p>
                          <span class="shrink-0 text-xs font-semibold text-zinc-300">$<%= number_with_delimiter(ms.amount.to_i) %></span>
                        </div>
                        <% if ms.due_date %>
                          <p class="text-xs text-zinc-500 mt-0.5">Due <%= ms.due_date.strftime("%b %d") %></p>
                        <% end %>
                        <span class="inline-block mt-1 px-2 py-0.5 rounded-full text-[10px] font-semibold border <%= ms.status_color %>"><%= ms.status.capitalize %></span>
                      </div>
                    </div>
                  <% end %>
                </div>
                <div class="mt-4 pt-3 border-t border-white/8 flex items-center justify-between">
                  <span class="text-xs text-zinc-500">Total</span>
                  <span class="text-sm font-bold text-white">$<%= number_with_delimiter(@milestones.sum(:amount).to_i) %></span>
                </div>
              <% else %>
                <p class="text-zinc-600 text-xs">No milestones proposed yet. The developer may propose a milestone breakdown during negotiation.</p>
              <% end %>
            </div>

            <%# Expires %>
            <% if @quote.expires_at && @quote.open? %>
              <div class="rounded-xl border border-white/5 bg-zinc-900/50 px-4 py-3">
                <p class="text-[10px] text-zinc-600 uppercase tracking-widest mb-0.5">Expires</p>
                <p class="text-xs text-zinc-400"><%= @quote.expires_at.strftime("%b %d, %Y") %></p>
              </div>
            <% end %>

          </div>
        </div>

      </div>
    </main>
  </div>

  <%# Withdraw confirmation modal %>
  <div x-show="showWithdraw" x-transition class="fixed inset-0 z-50 flex items-center justify-center p-4" style="display:none">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" @click="showWithdraw = false"></div>
    <div class="relative w-full max-w-sm bg-zinc-950 border border-white/10 rounded-2xl shadow-2xl p-6">
      <h3 class="font-geist-sans text-lg font-semibold text-white mb-2">Withdraw this request?</h3>
      <p class="text-zinc-400 text-sm mb-6">The developer will be notified and the request will be closed. This cannot be undone.</p>
      <div class="flex gap-3">
        <%= button_to "Withdraw", withdraw_client_quote_path(@quote), method: :post,
            class: "flex-1 py-2.5 rounded-xl bg-red-500/10 hover:bg-red-500/20 border border-red-500/20 text-red-400 text-sm font-medium transition-colors cursor-pointer" %>
        <button @click="showWithdraw = false"
                class="flex-1 py-2.5 rounded-xl bg-zinc-800 hover:bg-zinc-700 border border-white/10 text-zinc-300 text-sm font-medium transition-colors">
          Cancel
        </button>
      </div>
    </div>
  </div>

</div>