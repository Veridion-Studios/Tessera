<div class="min-h-screen bg-zinc-950" x-data="{ selected: null }">

  <%# Top bar — no sidebar %>
  <div class="sticky top-0 z-40 bg-zinc-950/90 backdrop-blur-sm border-b border-white/[0.05]">
    <div class="flex items-center gap-4 px-6 py-4">
      <%= link_to developer_dashboard_path, class: "flex items-center gap-1.5 text-xs text-zinc-500 hover:text-white transition-colors mr-2" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
        Dashboard
      <% end %>

      <div class="h-4 w-px bg-white/10"></div>

      <span class="font-geist-sans text-sm font-semibold text-white">Clients</span>
      <span class="text-xs text-zinc-600"><%= @contact_data.count %> contact<%= @contact_data.count == 1 ? "" : "s" %></span>

      <div class="ml-auto flex items-center gap-3">
        <%# Search %>
        <%= form_with url: developer_crm_path, method: :get, data: { turbo: false }, class: "flex items-center" do |f| %>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-zinc-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
            <%= f.search_field :q, value: params[:q], placeholder: "Search clients...",
                class: "w-48 pl-8 pr-4 py-2 rounded-xl bg-white/[0.05] text-white text-xs placeholder-zinc-600 focus:outline-none focus:ring-1 focus:ring-primary/30 transition-all focus:w-64" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex">

    <%# ── Contact list ──────────────────────────────────────────── %>
    <div class="w-full lg:w-80 xl:w-96 shrink-0 border-r border-white/[0.05] min-h-screen">

      <%# Status buckets %>
      <% [:active, :prospect, :past].each do |bucket| %>
        <% contacts = @contact_data.select { |c| c[:status] == bucket } %>
        <% next if contacts.empty? %>

        <div class="px-4 pt-6 pb-2">
          <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-700">
            <%= bucket == :active ? "Active" : bucket == :prospect ? "Prospects" : "Past clients" %>
            · <%= contacts.count %>
          </p>
        </div>

        <% contacts.each do |contact| %>
          <button @click="selected = selected === '<%= contact[:user].id %>' ? null : '<%= contact[:user].id %>'"
                  class="w-full text-left px-4 py-4 border-b border-white/[0.04] hover:bg-white/[0.03] transition-colors"
                  :class="selected === '<%= contact[:user].id %>' ? 'bg-white/[0.05]' : ''">
            <div class="flex items-start gap-3">
              <div class="w-9 h-9 rounded-full bg-primary/15 flex items-center justify-center shrink-0 text-primary font-bold text-sm">
                <%= (contact[:profile]&.display_name&.first || contact[:user].email.first).upcase %>
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center justify-between gap-2">
                  <span class="text-sm font-medium text-white truncate">
                    <%= contact[:profile]&.display_name || contact[:user].email.split("@").first %>
                  </span>
                  <% if contact[:status] == :active %>
                    <span class="shrink-0 h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
                  <% end %>
                </div>
                <div class="text-xs text-zinc-600 truncate"><%= contact[:user].email %></div>
                <div class="flex items-center gap-3 mt-1.5 text-[11px] text-zinc-700">
                  <span><%= contact[:projects].count %> project<%= contact[:projects].count == 1 ? "" : "s" %></span>
                  <% if contact[:total_value] > 0 %>
                    <span>$<%= number_with_delimiter(contact[:total_value].to_i) %> total</span>
                  <% end %>
                  <% if contact[:last_activity] %>
                    <span class="ml-auto"><%= time_ago_in_words(contact[:last_activity]) %> ago</span>
                  <% end %>
                </div>
              </div>
            </div>
          </button>
        <% end %>
      <% end %>

      <% if @contact_data.empty? %>
        <div class="flex flex-col items-center justify-center py-24 text-center px-6">
          <p class="text-zinc-500 text-sm">No clients yet.</p>
          <p class="text-zinc-700 text-xs mt-1">They'll appear here once you receive a quote request.</p>
        </div>
      <% end %>
    </div>

    <%# ── Contact detail panel ──────────────────────────────────── %>
    <div class="flex-1 min-w-0">

      <%# Default empty state %>
      <div x-show="selected === null" class="flex flex-col items-center justify-center h-full min-h-[60vh] text-center px-8">
        <div class="w-16 h-16 rounded-2xl bg-white/[0.03] border border-white/[0.06] flex items-center justify-center text-2xl mb-4">🤝</div>
        <p class="text-zinc-400 text-sm font-medium mb-1">Select a client</p>
        <p class="text-zinc-700 text-xs">Click any contact on the left to see their full relationship history.</p>
      </div>

      <%# Per-contact panels %>
      <% @contact_data.each do |contact| %>
        <div x-show="selected === '<%= contact[:user].id %>'" x-cloak class="p-8">

          <%# Header %>
          <div class="flex items-start gap-5 mb-8">
            <div class="w-14 h-14 rounded-full bg-primary/15 flex items-center justify-center text-primary font-bold text-xl shrink-0">
              <%= (contact[:profile]&.display_name&.first || contact[:user].email.first).upcase %>
            </div>
            <div>
              <h2 class="font-geist-sans text-xl font-semibold text-white">
                <%= contact[:profile]&.display_name || contact[:user].email.split("@").first %>
              </h2>
              <p class="text-zinc-500 text-sm"><%= contact[:user].email %></p>
              <% if contact[:profile]&.company_name.present? %>
                <p class="text-zinc-600 text-xs mt-0.5"><%= contact[:profile].company_name %></p>
              <% end %>
              <div class="flex items-center gap-3 mt-2 text-xs text-zinc-600">
                <span class="flex items-center gap-1.5">
                  <span class="h-1.5 w-1.5 rounded-full <%= contact[:status] == :active ? 'bg-primary' : contact[:status] == :prospect ? 'bg-yellow-500' : 'bg-zinc-700' %>"></span>
                  <%= contact[:status].to_s.capitalize %>
                </span>
                <% if contact[:user].identity_status == "verified" %>
                  <span class="flex items-center gap-1 text-primary">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                    Identity verified
                  </span>
                <% end %>
              </div>
            </div>
          </div>

          <%# Stats row %>
          <div class="grid grid-cols-3 gap-3 mb-8">
            <div class="p-4 rounded-xl bg-white/[0.03]">
              <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-2">Projects</div>
              <div class="font-geist-sans text-2xl font-semibold text-white"><%= contact[:projects].count %></div>
            </div>
            <div class="p-4 rounded-xl bg-white/[0.03]">
              <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-2">Total value</div>
              <div class="font-geist-sans text-2xl font-semibold text-white">$<%= number_with_delimiter(contact[:total_value].to_i) %></div>
            </div>
            <div class="p-4 rounded-xl bg-white/[0.03]">
              <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-2">Quotes sent</div>
              <div class="font-geist-sans text-2xl font-semibold text-white"><%= contact[:quotes].count %></div>
            </div>
          </div>

          <%# Projects with this client %>
          <% if contact[:projects].any? %>
            <div class="mb-8">
              <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-600 mb-3">Projects</h3>
              <div class="space-y-2">
                <% contact[:projects].order(created_at: :desc).each do |project| %>
                  <%= link_to developer_project_path(project), class: "flex items-center gap-4 p-4 rounded-xl bg-white/[0.03] hover:bg-white/[0.06] transition-colors" do %>
                    <div class="min-w-0 flex-1">
                      <div class="text-sm font-medium text-white"><%= project.title %></div>
                      <div class="text-xs text-zinc-600 mt-0.5"><%= project.status.capitalize %> · $<%= number_with_delimiter(project.total_amount.to_i) %></div>
                    </div>
                    <div class="shrink-0 w-20 h-1.5 rounded-full bg-white/10 overflow-hidden">
                      <div class="h-full bg-primary rounded-full" style="width:<%= project.completion_percentage %>%"></div>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>

          <%# Quote history %>
          <% if contact[:quotes].any? %>
            <div>
              <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-600 mb-3">Quote history</h3>
              <div class="space-y-1">
                <% contact[:quotes].order(created_at: :desc).each do |quote| %>
                  <%= link_to developer_quote_path(quote), class: "flex items-center gap-4 py-3 border-b border-white/[0.04] last:border-0 hover:text-white transition-colors" do %>
                    <div class="min-w-0 flex-1">
                      <div class="text-sm text-zinc-300 truncate"><%= quote.title %></div>
                      <div class="text-[11px] text-zinc-600 mt-0.5"><%= quote.created_at.strftime("%b %d, %Y") %></div>
                    </div>
                    <span class="shrink-0 text-[10px] font-semibold uppercase tracking-wide
                      <%= quote.status == 'accepted' ? 'text-primary' : quote.status == 'declined' ? 'text-red-400' : 'text-zinc-500' %>">
                      <%= quote.status %>
                    </span>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>

        </div>
      <% end %>

    </div>
  </div>
</div>