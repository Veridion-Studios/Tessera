<%= render layout: "shared/dashboard_shell", locals: { active_role: "developer", active_item: :quotes, mobile_title: "Quotes" } do %>
  <div class="px-6 lg:px-10 py-10">

    <div class="flex items-start justify-between mb-8">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1.5">Developer</p>
        <h1 class="font-geist-sans text-2xl font-semibold text-white tracking-tight">Quote requests</h1>
        <p class="text-zinc-500 text-sm mt-1">Project requests from clients.</p>
      </div>
    </div>

    <div class="flex gap-1 mb-6 border-b border-white/[0.06]">
      <%= link_to developer_quotes_path(status: "open"),
          class: "px-4 py-2.5 text-sm font-medium border-b-2 transition-colors -mb-px #{@status == 'open' ? 'border-primary text-white' : 'border-transparent text-zinc-500 hover:text-zinc-300'}" do %>
        Open
        <% open_count = current_user.received_quote_requests.active.count %>
        <% if open_count > 0 %>
          <span class="ml-1.5 px-1.5 py-0.5 rounded-full bg-primary/15 text-primary text-[10px] font-bold"><%= open_count %></span>
        <% end %>
      <% end %>
      <%= link_to developer_quotes_path(status: "closed"),
          class: "px-4 py-2.5 text-sm font-medium border-b-2 transition-colors -mb-px #{@status == 'closed' ? 'border-primary text-white' : 'border-transparent text-zinc-500 hover:text-zinc-300'}" do %>
        Closed
      <% end %>
    </div>

    <% if @quotes.any? %>
      <div class="space-y-2">
        <% @quotes.each do |quote| %>
          <% unread = quote.thread_messages.where(read_by_developer: false).count %>
          <%= link_to developer_quote_path(quote), class: "group flex items-center gap-4 py-4 border-b border-white/[0.04] last:border-0 hover:bg-white/[0.02] -mx-2 px-2 rounded-lg transition-colors" do %>
            <span class="w-9 h-9 shrink-0 rounded-full bg-primary/15 flex items-center justify-center text-primary text-sm font-bold"><%= quote.customer.email[0].upcase %></span>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 mb-0.5">
                <span class="text-sm font-medium text-white truncate"><%= quote.title %></span>
                <% if unread > 0 %>
                  <span class="shrink-0 px-1.5 py-0.5 rounded-full bg-primary/15 text-primary text-[10px] font-bold"><%= unread %> new</span>
                <% end %>
              </div>
              <div class="text-xs text-zinc-600">
                <%= quote.customer.email.split("@").first %>
                · <%= quote.budget_display %>
                · <%= time_ago_in_words(quote.created_at) %> ago
              </div>
            </div>
            <span class="shrink-0 text-[10px] font-bold uppercase tracking-wide text-zinc-600"><%= quote.status %></span>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center py-20 text-center">
        <p class="text-zinc-500 text-sm font-medium mb-1">No <%= @status %> requests</p>
        <p class="text-zinc-700 text-xs"><%= @status == "open" ? "Quote requests from clients appear here." : "Closed requests will appear here." %></p>
      </div>
    <% end %>

  </div>
<% end %>