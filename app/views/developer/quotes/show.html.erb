<%= render layout: "shared/dashboard_shell", locals: { active_role: "developer", active_item: :quotes, mobile_title: @quote.title } do %>
  <div class="px-6 lg:px-10 py-10" x-data="{ showAccept: false, showDecline: false, showCounter: false, showMilestone: false }">
    <main class="flex-1 overflow-y-auto">
      <div class="max-w-4xl mx-auto px-6 lg:px-10 py-10">

        <%# Header %>
        <div class="flex items-start gap-4 mb-8">
          <%= link_to developer_quotes_path, class: "mt-1.5 text-zinc-500 hover:text-zinc-300 transition-colors shrink-0" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          <% end %>
          <div class="flex-1 min-w-0">
            <h1 class="font-geist-sans text-2xl font-semibold text-white truncate"><%= @quote.title %></h1>
            <div class="flex flex-wrap items-center gap-2 mt-1.5">
              <span class="px-2.5 py-0.5 rounded-full text-[10px] font-semibold border <%= @quote.status_color %>"><%= @quote.status_label %></span>
              <span class="text-xs text-zinc-500">From <span class="text-zinc-300"><%= @quote.customer.email.split("@").first %></span></span>
              <span class="text-xs text-zinc-600"><%= time_ago_in_words(@quote.created_at) %> ago</span>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2 space-y-4">

            <%# Brief %>
            <div class="rounded-xl border border-white/8 bg-zinc-900 p-5">
              <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-4">Project brief</h2>
              <p class="text-zinc-300 text-sm leading-relaxed mb-4"><%= @quote.description %></p>
              <div class="grid grid-cols-3 gap-3 mb-3">
                <div class="rounded-lg bg-zinc-800 border border-white/5 px-3 py-2.5">
                  <p class="text-[10px] text-zinc-500 mb-0.5">Budget</p>
                  <p class="text-sm font-semibold text-zinc-200"><%= @quote.budget_display %></p>
                </div>
                <div class="rounded-lg bg-zinc-800 border border-white/5 px-3 py-2.5">
                  <p class="text-[10px] text-zinc-500 mb-0.5">Timeline</p>
                  <p class="text-sm font-semibold text-zinc-200"><%= @quote.timeline %></p>
                </div>
                <div class="rounded-lg bg-zinc-800 border border-white/5 px-3 py-2.5">
                  <p class="text-[10px] text-zinc-500 mb-0.5">Type</p>
                  <p class="text-sm font-semibold text-zinc-200 capitalize"><%= @quote.engagement_type %></p>
                </div>
              </div>
              <% if @quote.tech_tags.any? %>
                <div class="flex flex-wrap gap-1.5">
                  <% @quote.tech_tags.each do |tag| %>
                    <span class="px-2.5 py-1 rounded-full bg-primary/8 border border-primary/15 text-primary text-xs"><%= tag %></span>
                  <% end %>
                </div>
              <% end %>
            </div>

            <%# Action buttons — only when open %>
            <% if @quote.open? %>
              <div class="grid grid-cols-3 gap-3">
                <button @click="showAccept = true"
                        class="py-2.5 rounded-xl bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 text-green-400 text-sm font-medium transition-colors">
                  ✓ Accept
                </button>
                <button @click="showCounter = true"
                        class="py-2.5 rounded-xl bg-violet-500/10 hover:bg-violet-500/20 border border-violet-500/20 text-violet-400 text-sm font-medium transition-colors">
                  ↔ Counter
                </button>
                <button @click="showDecline = true"
                        class="py-2.5 rounded-xl bg-red-500/10 hover:bg-red-500/20 border border-red-500/20 text-red-400 text-sm font-medium transition-colors">
                  ✕ Decline
                </button>
              </div>
            <% end %>

            <%# Thread %>
            <div class="rounded-xl border border-white/8 bg-zinc-900 overflow-hidden">
              <div class="px-5 py-4 border-b border-white/8">
                <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">Thread</h2>
              </div>
              <div class="divide-y divide-white/5">
                <% @messages.each do |msg| %>
                  <% from_me = msg.author_id == current_user.id %>
                  <% if msg.system? %>
                    <div class="px-5 py-3 flex justify-center">
                      <span class="text-xs text-zinc-600 italic"><%= msg.body %></span>
                    </div>
                  <% elsif msg.proposal? %>
                    <div class="px-5 py-4 bg-violet-500/3 border-l-2 border-violet-500/40">
                      <div class="flex items-center gap-2 mb-2">
                        <span class="text-xs font-bold text-violet-400 uppercase tracking-wider">Counter-proposal</span>
                        <span class="text-xs text-zinc-500">from <%= from_me ? "you" : "client" %></span>
                      </div>
                      <% if msg.proposed_amount %>
                        <p class="text-sm text-zinc-300 mb-1">Proposed: <span class="font-semibold text-white">$<%= number_with_delimiter(msg.proposed_amount.to_i) %></span></p>
                      <% end %>
                      <% if msg.proposed_timeline %>
                        <p class="text-sm text-zinc-300 mb-1">Timeline: <span class="font-semibold text-white"><%= msg.proposed_timeline %></span></p>
                      <% end %>
                      <% if msg.body.present? %>
                        <p class="text-sm text-zinc-400 mt-2 leading-relaxed"><%= msg.body %></p>
                      <% end %>
                    </div>
                  <% elsif msg.kind == "acceptance" %>
                    <div class="px-5 py-4 bg-green-500/3 border-l-2 border-green-500/40">
                      <span class="text-xs font-bold text-green-400 uppercase tracking-wider block mb-1">Accepted</span>
                      <p class="text-sm text-zinc-300"><%= msg.body %></p>
                    </div>
                  <% elsif msg.kind == "decline" %>
                    <div class="px-5 py-4 bg-red-500/3 border-l-2 border-red-500/40">
                      <span class="text-xs font-bold text-red-400 uppercase tracking-wider block mb-1">Declined</span>
                      <p class="text-sm text-zinc-300"><%= msg.body %></p>
                    </div>
                  <% else %>
                    <div class="px-5 py-4">
                      <div class="flex items-center gap-2 mb-2">
                        <span class="w-6 h-6 rounded-full <%= from_me ? 'bg-violet-500/20 border border-violet-500/30 text-violet-300' : 'bg-blue-500/20 border border-blue-500/30 text-blue-300' %> flex items-center justify-center text-[10px] font-bold"><%= msg.author.email[0].upcase %></span>
                        <span class="text-xs font-medium text-zinc-300"><%= from_me ? "You" : "Client" %></span>
                        <span class="text-xs text-zinc-600"><%= time_ago_in_words(msg.created_at) %> ago</span>
                      </div>
                      <p class="text-sm text-zinc-300 leading-relaxed"><%= msg.body %></p>
                    </div>
                  <% end %>
                <% end %>
              </div>
              <% if @quote.open? %>
                <div class="px-5 py-4 border-t border-white/8 bg-zinc-950/50">
                  <%= form_with url: message_developer_quote_path(@quote), method: :post, class: "flex gap-3 items-end" do |f| %>
                    <textarea name="body" rows="2" placeholder="Send a message to the client…"
                              class="flex-1 px-4 py-2.5 rounded-xl bg-zinc-800 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/50 transition-colors resize-none"></textarea>
                    <%= f.submit "Send", class: "shrink-0 px-4 py-2.5 rounded-xl btn btn-primary text-sm font-medium cursor-pointer" %>
                  <% end %>
                </div>
              <% end %>
            </div>

          </div>

          <%# Right panel %>
          <div class="space-y-4">

            <%# Client info %>
            <div class="rounded-xl border border-white/8 bg-zinc-900 p-5">
              <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-3">Client</h3>
              <div class="flex items-center gap-3">
                <span class="w-9 h-9 rounded-full bg-blue-500/20 border border-blue-500/30 flex items-center justify-center text-blue-300 text-sm font-bold"><%= @quote.customer.email[0].upcase %></span>
                <div>
                  <p class="text-sm font-medium text-zinc-200"><%= @quote.customer.customer_profile&.display_name || @quote.customer.email.split("@").first %></p>
                  <p class="text-xs text-zinc-500"><%= @quote.customer.email %></p>
                  <% if @quote.customer.identity_verified? %>
                    <span class="inline-flex items-center gap-1 mt-1 text-[10px] text-green-400"><span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>Identity verified</span>
                  <% end %>
                </div>
              </div>
            </div>

            <%# Agreed terms %>
            <% if @quote.accepted? %>
              <div class="rounded-xl border border-green-500/20 bg-green-500/5 p-5">
                <div class="flex items-center gap-2 mb-3">
                  <span class="h-2 w-2 rounded-full bg-green-500"></span>
                  <h3 class="text-xs font-bold uppercase tracking-widest text-green-400">Agreed terms</h3>
                </div>
                <% if @quote.agreed_amount %>
                  <div class="mb-2"><p class="text-[10px] text-zinc-500 mb-0.5">Amount</p><p class="text-sm font-semibold text-white">$<%= number_with_delimiter(@quote.agreed_amount.to_i) %></p></div>
                <% end %>
                <% if @quote.agreed_timeline %>
                  <div class="mb-2"><p class="text-[10px] text-zinc-500 mb-0.5">Timeline</p><p class="text-sm font-semibold text-white"><%= @quote.agreed_timeline %></p></div>
                <% end %>
                <% if @quote.estimated_start_date %>
                  <div><p class="text-[10px] text-zinc-500 mb-0.5">Start date</p><p class="text-sm font-semibold text-white"><%= @quote.estimated_start_date.strftime("%b %d, %Y") %></p></div>
                <% end %>
              </div>
            <% end %>

            <%# Milestones %>
            <div class="rounded-xl border border-white/8 bg-zinc-900 p-5">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-500">Milestones</h3>
                <% if @quote.open? || @quote.accepted? %>
                  <button @click="showMilestone = true" class="text-xs text-primary hover:text-primary/80 transition-colors font-medium">+ Add</button>
                <% end %>
              </div>
              <% if @milestones.any? %>
                <div class="space-y-2.5">
                  <% @milestones.each_with_index do |ms, i| %>
                    <div class="flex items-start gap-3">
                      <span class="w-5 h-5 rounded-full bg-zinc-800 border border-white/10 flex items-center justify-center text-[10px] text-zinc-500 shrink-0 mt-0.5"><%= i + 1 %></span>
                      <div class="flex-1 min-w-0">
                        <div class="flex justify-between gap-2">
                          <p class="text-sm text-zinc-200 font-medium truncate"><%= ms.title %></p>
                          <span class="shrink-0 text-xs font-semibold text-zinc-300">$<%= number_with_delimiter(ms.amount.to_i) %></span>
                        </div>
                        <span class="inline-block mt-1 px-2 py-0.5 rounded-full text-[10px] font-semibold border <%= ms.status_color %>"><%= ms.status.capitalize %></span>
                      </div>
                    </div>
                  <% end %>
                </div>
                <div class="mt-4 pt-3 border-t border-white/8 flex items-center justify-between">
                  <span class="text-xs text-zinc-500">Total</span>
                  <span class="text-sm font-bold text-white">$<%= number_with_delimiter(@milestones.sum(:amount).to_i) %></span>
                </div>
              <% else %>
                <p class="text-zinc-600 text-xs">Propose a milestone breakdown so the client can see the project phases and payment schedule.</p>
              <% end %>
            </div>

          </div>
        </div>
      </div>
    </main>

  <%# ===== MODALS ===== %>

  <%# Accept modal %>
  <div x-show="showAccept" x-transition class="fixed inset-0 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4" style="display:none">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" @click="showAccept = false"></div>
    <div x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95" x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
         class="relative w-full sm:max-w-md bg-zinc-950 border border-white/10 rounded-t-2xl sm:rounded-2xl shadow-2xl overflow-hidden">
      <div class="sm:hidden flex justify-center pt-3 pb-1"><div class="w-8 h-1 rounded-full bg-white/15"></div></div>
      <div class="px-6 py-5 border-b border-white/8 flex items-center justify-between">
        <h3 class="font-geist-sans text-base font-semibold text-white">Accept quote request</h3>
        <button @click="showAccept = false" class="text-zinc-500 hover:text-zinc-300 transition-colors p-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <%= form_with url: accept_developer_quote_path(@quote), method: :post, class: "px-6 py-5 space-y-4" do |f| %>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Agreed amount ($)</label>
            <input type="number" name="agreed_amount" placeholder="e.g. 8500" min="0" step="0.01"
                   class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-green-500/50 transition-colors">
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Agreed timeline</label>
            <input type="text" name="agreed_timeline" placeholder="e.g. 6 weeks"
                   class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-green-500/50 transition-colors">
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Start date</label>
            <input type="date" name="start_date"
                   class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 text-sm focus:outline-none focus:border-green-500/50 transition-colors">
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">End date</label>
            <input type="date" name="end_date"
                   class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 text-sm focus:outline-none focus:border-green-500/50 transition-colors">
          </div>
        </div>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Note to client (optional)</label>
          <textarea name="note" rows="2" placeholder="A short note to accompany your acceptance…"
                    class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-green-500/50 transition-colors resize-none"></textarea>
        </div>
        <div class="flex gap-3 pt-1">
          <%= f.submit "Accept quote →", class: "flex-1 py-3 rounded-xl bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 text-green-400 text-sm font-semibold transition-colors cursor-pointer" %>
          <button type="button" @click="showAccept = false" class="px-4 py-3 rounded-xl bg-zinc-800 hover:bg-zinc-700 border border-white/10 text-zinc-400 text-sm font-medium transition-colors">Cancel</button>
        </div>
      <% end %>
    </div>
  </div>

  <%# Decline modal %>
  <div x-show="showDecline" x-transition class="fixed inset-0 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4" style="display:none">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" @click="showDecline = false"></div>
    <div class="relative w-full sm:max-w-md bg-zinc-950 border border-white/10 rounded-t-2xl sm:rounded-2xl shadow-2xl overflow-hidden">
      <div class="sm:hidden flex justify-center pt-3 pb-1"><div class="w-8 h-1 rounded-full bg-white/15"></div></div>
      <div class="px-6 py-5 border-b border-white/8 flex items-center justify-between">
        <h3 class="font-geist-sans text-base font-semibold text-white">Decline this request</h3>
        <button @click="showDecline = false" class="text-zinc-500 hover:text-zinc-300 transition-colors p-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <%= form_with url: decline_developer_quote_path(@quote), method: :post, class: "px-6 py-5 space-y-4" do |f| %>
        <p class="text-zinc-400 text-sm">Let the client know why — they'll be notified. This is optional but recommended.</p>
        <textarea name="reason" rows="3" placeholder="e.g. Outside my current availability, or the scope is outside my expertise…"
                  class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-red-500/50 transition-colors resize-none"></textarea>
        <div class="flex gap-3 pt-1">
          <%= f.submit "Decline request", class: "flex-1 py-3 rounded-xl bg-red-500/10 hover:bg-red-500/20 border border-red-500/20 text-red-400 text-sm font-semibold transition-colors cursor-pointer" %>
          <button type="button" @click="showDecline = false" class="px-4 py-3 rounded-xl bg-zinc-800 hover:bg-zinc-700 border border-white/10 text-zinc-400 text-sm font-medium transition-colors">Cancel</button>
        </div>
      <% end %>
    </div>
  </div>

  <%# Counter-proposal modal %>
  <div x-show="showCounter" x-transition class="fixed inset-0 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4" style="display:none">
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" @click="showCounter = false"></div>
    <div class="relative w-full sm:max-w-md bg-zinc-950 border border-white/10 rounded-t-2xl sm:rounded-2xl shadow-2xl overflow-hidden">
      <div class="sm:hidden flex justify-center pt-3 pb-1"><div class="w-8 h-1 rounded-full bg-white/15"></div></div>
      <div class="px-6 py-5 border-b border-white/8 flex items-center justify-between">
        <h3 class="font-geist-sans text-base font-semibold text-white">Send a counter-proposal</h3>
        <button @click="showCounter = false" class="text-zinc-500 hover:text-zinc-300 transition-colors p-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <%= form_with url: counter_developer_quote_path(@quote), method: :post, class: "px-6 py-5 space-y-4 max-h-[75vh] overflow-y-auto" do |f| %>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Your price ($)</label>
            <input type="number" name="proposed_amount" placeholder="e.g. 12000" min="0" step="0.01"
                   class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-violet-500/50 transition-colors">
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Your timeline</label>
            <input type="text" name="proposed_timeline" placeholder="e.g. 8–10 weeks"
                   class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-violet-500/50 transition-colors">
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Proposed start</label>
            <input type="date" name="proposed_start_date"
                   class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 text-sm focus:outline-none focus:border-violet-500/50 transition-colors">
          </div>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Proposed end</label>
            <input type="date" name="proposed_end_date"
                   class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 text-sm focus:outline-none focus:border-violet-500/50 transition-colors">
          </div>
        </div>
        <div>
          <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2">Explain your counter</label>
          <textarea name="body" rows="3" placeholder="Explain your reasoning — what changes you're proposing and why…"
                    class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-violet-500/50 transition-colors resize-none"></textarea>
        </div>
        <div class="flex gap-3 pt-1">
          <%= f.submit "Send counter-proposal →", class: "flex-1 py-3 rounded-xl bg-violet-500/10 hover:bg-violet-500/20 border border-violet-500/20 text-violet-400 text-sm font-semibold transition-colors cursor-pointer" %>
          <button type="button" @click="showCounter = false" class="px-4 py-3 rounded-xl bg-zinc-800 hover:bg-zinc-700 border border-white/10 text-zinc-400 text-sm font-medium transition-colors">Cancel</button>
        </div>
      <% end %>
    </div>
  </div>

  </div>
<% end %>