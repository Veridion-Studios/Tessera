<%= render layout: "shared/dashboard_shell", locals: { active_role: "developer", active_item: :projects } do %>
  <div class="px-6 lg:px-10 py-10">

    <div class="flex items-start justify-between mb-8">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1.5">Developer</p>
        <h1 class="font-geist-sans text-2xl font-semibold text-white tracking-tight">Projects</h1>
        <p class="text-zinc-500 text-sm mt-1">Your active and completed engagements.</p>
      </div>
    </div>

    <%# Active %>
    <div class="mb-10">
      <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-600 mb-4">Active · <%= @active.count %></h2>
      <% if @active.any? %>
        <div class="space-y-3">
          <% @active.each do |project| %>
            <%= link_to developer_project_path(project), class: "flex items-center gap-5 p-5 rounded-xl bg-white/[0.03] hover:bg-white/[0.06] transition-colors" do %>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2.5 mb-1">
                  <span class="text-sm font-semibold text-white"><%= project.title %></span>
                  <% if project.escrow_status == "funded" %>
                    <span class="text-[10px] font-semibold text-primary uppercase tracking-wide">Funded</span>
                  <% end %>
                </div>
                <div class="text-xs text-zinc-500">
                  Client: <%= project.customer.customer_profile&.display_name || project.customer.email.split("@").first %>
                  · <%= project.milestones.where(status: "paid").count %>/<%= project.milestones.count %> milestones paid
                  · $<%= number_with_delimiter(project.amount_released.to_i) %> released
                </div>
                <% if project.due_date.present? %>
                  <div class="text-[11px] text-zinc-600 mt-1">Due <%= project.due_date.strftime("%b %d, %Y") %></div>
                <% end %>
              </div>

              <div class="shrink-0 flex flex-col items-end gap-2">
                <div class="text-sm font-semibold text-zinc-200">$<%= number_with_delimiter(project.total_amount.to_i) %></div>
                <div class="w-24 h-1.5 rounded-full bg-white/10 overflow-hidden">
                  <div class="h-full bg-primary rounded-full transition-all" style="width:<%= project.completion_percentage %>%"></div>
                </div>
                <div class="text-[11px] text-zinc-600"><%= project.completion_percentage %>% complete</div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="p-8 rounded-xl bg-white/[0.02] text-center">
          <p class="text-zinc-500 text-sm">No active projects. When a quote is accepted and funded it appears here.</p>
        </div>
      <% end %>
    </div>

    <%# Paused %>
    <% if @paused.any? %>
      <div class="mb-10">
        <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-600 mb-4">Paused · <%= @paused.count %></h2>
        <div class="space-y-2">
          <% @paused.each do |project| %>
            <%= link_to developer_project_path(project), class: "flex items-center gap-4 p-4 rounded-xl bg-white/[0.02] hover:bg-white/[0.04] transition-colors opacity-70" do %>
              <div class="min-w-0 flex-1">
                <div class="text-sm font-medium text-zinc-300"><%= project.title %></div>
                <div class="text-xs text-zinc-600">Paused</div>
              </div>
              <div class="text-sm font-semibold text-zinc-500">$<%= number_with_delimiter(project.total_amount.to_i) %></div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Completed %>
    <div>
      <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-600 mb-4">Completed · <%= @completed.count %></h2>
      <% if @completed.any? %>
        <div class="space-y-1">
          <% @completed.each do |project| %>
            <div class="flex items-center gap-4 py-3.5 border-b border-white/[0.04] last:border-0">
              <div class="min-w-0 flex-1">
                <div class="text-sm text-zinc-300"><%= project.title %></div>
                <div class="text-xs text-zinc-600">
                  <%= project.customer.customer_profile&.display_name || project.customer.email.split("@").first %>
                  · <%= project.completed_at&.strftime("%b %Y") %>
                </div>
              </div>
              <div class="text-sm font-semibold text-zinc-400">$<%= number_with_delimiter(project.amount_released.to_i) %></div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-zinc-600 text-sm">No completed projects yet.</p>
      <% end %>
    </div>

  </div>
<% end %>