<%= render layout: "shared/dashboard_shell", locals: { active_role: "developer", active_item: :agency_files } do %>
  <div class="px-6 lg:px-10 py-10">

    <div class="flex items-center justify-between mb-8">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-1.5">Agency · <%= @agency.name %></p>
        <h1 class="font-geist-sans text-2xl font-semibold text-base-content tracking-tight">Files</h1>
      </div>
    </div>

    <%# Upload form %>
    <div class="rounded-xl border border-base-content/[0.07] bg-base-content/[0.02] p-5 mb-8">
      <h2 class="text-xs font-semibold text-base-content/50 uppercase tracking-widest mb-4">Upload file</h2>
      <%= form_with url: developer_agency_files_path, method: :post, multipart: true, class: "flex flex-col sm:flex-row gap-3 items-end" do |f| %>
        <input name="agency_file[label]" placeholder="Label (e.g. Q4 Contract)" required
               class="flex-1 px-4 py-2.5 rounded-xl bg-base-100 border border-base-content/10 text-base-content text-sm placeholder-base-content/30 focus:outline-none focus:border-primary/40 transition-colors" />
        <select name="agency_file[visibility]"
                class="px-4 py-2.5 rounded-xl bg-base-100 border border-base-content/10 text-base-content text-sm focus:outline-none focus:border-primary/40 transition-colors">
          <option value="internal">🔒 Internal</option>
          <option value="client">👥 Client-visible</option>
        </select>
        <input type="file" name="agency_file[attachment]" required
               class="text-sm text-base-content/60 file:mr-3 file:px-3 file:py-2 file:rounded-lg file:border-0 file:text-xs file:font-medium file:bg-primary/10 file:text-primary hover:file:bg-primary/20 cursor-pointer" />
        <button type="submit" class="px-5 py-2.5 rounded-xl bg-primary text-primary-content text-sm font-medium hover:opacity-90 transition-opacity whitespace-nowrap">Upload</button>
      <% end %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <%# Internal files %>
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-3">Internal 🔒</p>
        <% if @internal_files.any? %>
          <div class="rounded-xl border border-base-content/[0.06] overflow-hidden divide-y divide-base-content/[0.04]">
            <% @internal_files.each do |f| %>
              <div class="flex items-center gap-3 px-5 py-3.5">
                <svg class="w-5 h-5 shrink-0 text-base-content/30" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
                <div class="min-w-0 flex-1">
                  <div class="text-sm font-medium text-base-content truncate"><%= f.label %></div>
                  <div class="text-xs text-base-content/40">
                    <%= f.uploader.email.split("@").first %> · <%= f.created_at.strftime("%b %d") %>
                  </div>
                </div>
                <% if f.attachment.attached? %>
                  <%= link_to rails_blob_path(f.attachment, disposition: "attachment"),
                        class: "text-xs text-primary hover:opacity-70 shrink-0 font-medium" do %>Download<% end %>
                <% end %>
                <%= button_to developer_agency_file_path(f), method: :delete,
                      data: { confirm: "Remove this file?" },
                      class: "text-base-content/20 hover:text-error transition-colors text-sm ml-1" do %>✕<% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-xl border border-dashed border-base-content/10 py-10 text-center">
            <p class="text-xs text-base-content/30">No internal files yet.</p>
          </div>
        <% end %>
      </div>

      <%# Client files %>
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-3">Client-visible 👥</p>
        <% if @client_files.any? %>
          <div class="rounded-xl border border-base-content/[0.06] overflow-hidden divide-y divide-base-content/[0.04]">
            <% @client_files.each do |f| %>
              <div class="flex items-center gap-3 px-5 py-3.5">
                <svg class="w-5 h-5 shrink-0 text-secondary/50" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
                <div class="min-w-0 flex-1">
                  <div class="text-sm font-medium text-base-content truncate"><%= f.label %></div>
                  <div class="text-xs text-base-content/40">
                    <%= f.uploader.email.split("@").first %> · <%= f.created_at.strftime("%b %d") %>
                  </div>
                </div>
                <% if f.attachment.attached? %>
                  <%= link_to rails_blob_path(f.attachment, disposition: "attachment"),
                        class: "text-xs text-primary hover:opacity-70 shrink-0 font-medium" do %>Download<% end %>
                <% end %>
                <%= button_to developer_agency_file_path(f), method: :delete,
                      data: { confirm: "Remove this file?" },
                      class: "text-base-content/20 hover:text-error transition-colors text-sm ml-1" do %>✕<% end %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-xl border border-dashed border-base-content/10 py-10 text-center">
            <p class="text-xs text-base-content/30">No client-facing files yet.</p>
          </div>
        <% end %>
      </div>

    </div>
  </div>
<% end %>
