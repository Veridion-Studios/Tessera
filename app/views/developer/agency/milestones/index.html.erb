<%= render layout: "shared/dashboard_shell", locals: { active_role: "developer", active_item: :agency_milestones } do %>
  <div class="px-6 lg:px-10 py-10">

    <div class="flex items-center justify-between mb-8">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-1.5">Agency · <%= @agency.name %></p>
        <h1 class="font-geist-sans text-2xl font-semibold text-base-content tracking-tight">Milestones</h1>
      </div>
    </div>

    <%# Add milestone form %>
    <div class="rounded-xl border border-base-content/[0.07] bg-base-content/[0.02] p-5 mb-6">
      <h2 class="text-xs font-semibold text-base-content/60 uppercase tracking-widest mb-4">Add milestone</h2>
      <%= form_with url: developer_agency_milestones_path, method: :post, class: "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3" do |f| %>
        <input name="agency_milestone[title]" placeholder="Title" required
               class="col-span-2 px-4 py-2.5 rounded-xl bg-base-100 border border-base-content/10 text-base-content text-sm placeholder-base-content/30 focus:outline-none focus:border-primary/40 transition-colors" />
        <input name="agency_milestone[due_date]" type="date"
               class="px-4 py-2.5 rounded-xl bg-base-100 border border-base-content/10 text-base-content text-sm focus:outline-none focus:border-primary/40 transition-colors" />
        <select name="agency_milestone[status]"
                class="px-4 py-2.5 rounded-xl bg-base-100 border border-base-content/10 text-base-content text-sm focus:outline-none focus:border-primary/40 transition-colors">
          <option value="planned">Planned</option>
          <option value="in_progress">In Progress</option>
          <option value="completed">Completed</option>
        </select>
        <textarea name="agency_milestone[description]" placeholder="Description (optional)" rows="2"
                  class="col-span-2 px-4 py-2.5 rounded-xl bg-base-100 border border-base-content/10 text-base-content text-sm placeholder-base-content/30 focus:outline-none focus:border-primary/40 transition-colors resize-none"></textarea>
        <div class="col-span-2 flex justify-end">
          <button type="submit" class="px-5 py-2.5 rounded-xl bg-primary text-primary-content text-sm font-medium hover:opacity-90 transition-opacity">Add milestone</button>
        </div>
      <% end %>
    </div>

    <%# Milestones list %>
    <% if @milestones.any? %>
      <div class="rounded-xl border border-base-content/[0.06] overflow-hidden">
        <% @milestones.each_with_index do |m, i| %>
          <div class="flex items-start gap-4 px-5 py-4 <%= i < @milestones.length - 1 ? 'border-b border-base-content/[0.04]' : '' %> hover:bg-base-content/[0.02] transition-colors">
            <%# Status dot %>
            <div class="mt-1 shrink-0">
              <% dot_color = case m.status
                             when "completed"   then "bg-success"
                             when "in_progress" then "bg-primary animate-pulse"
                             when "cancelled"   then "bg-base-content/20"
                             else m.overdue? ? "bg-error" : "bg-base-content/20"
                             end %>
              <span class="block w-2.5 h-2.5 rounded-full <%= dot_color %>"></span>
            </div>

            <div class="min-w-0 flex-1">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <div class="text-sm font-medium text-base-content"><%= m.title %></div>
                  <% if m.description.present? %>
                    <div class="text-xs text-base-content/40 mt-0.5"><%= m.description %></div>
                  <% end %>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <% if m.due_date %>
                    <span class="text-xs <%= m.overdue? ? 'text-error font-medium' : 'text-base-content/40' %>">
                      <%= m.due_date.strftime("%b %d, %Y") %>
                    </span>
                  <% end %>
                  <span class="text-[10px] font-bold uppercase tracking-wide px-2 py-0.5 rounded-full
                    <%= case m.status
                        when 'completed'   then 'bg-success/10 text-success'
                        when 'in_progress' then 'bg-primary/10 text-primary'
                        when 'cancelled'   then 'bg-base-content/10 text-base-content/40'
                        else 'bg-base-content/[0.06] text-base-content/40'
                        end %>">
                    <%= m.status.tr("_"," ") %>
                  </span>
                </div>
              </div>
            </div>

            <%# Quick status update form %>
            <div class="shrink-0 flex items-center gap-1">
              <% unless m.status == "completed" %>
                <%= button_to developer_agency_milestone_path(m), method: :patch,
                      params: { agency_milestone: { status: m.status == "in_progress" ? "completed" : "in_progress" } },
                      class: "text-[10px] px-2.5 py-1 rounded-lg border border-base-content/10 text-base-content/50 hover:text-base-content hover:border-base-content/20 transition-colors" do %>
                  <%= m.status == "in_progress" ? "Mark done" : "Start" %>
                <% end %>
              <% end %>
              <%= button_to developer_agency_milestone_path(m), method: :delete,
                    data: { confirm: "Remove this milestone?" },
                    class: "text-[10px] px-2 py-1 rounded-lg text-base-content/30 hover:text-error transition-colors" do %>✕<% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-xl border border-dashed border-base-content/10 py-16 text-center">
        <p class="text-base-content/30 text-sm">No milestones yet.</p>
        <p class="text-base-content/20 text-xs mt-1">Use the form above to add your first one.</p>
      </div>
    <% end %>

  </div>
<% end %>
