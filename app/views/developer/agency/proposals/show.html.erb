<%= render layout: "shared/dashboard_shell", locals: { active_role: "developer", active_item: :agency_proposals } do %>
  <div class="px-6 lg:px-10 py-10 max-w-2xl">

    <div class="mb-6">
      <%= link_to "← Proposals", developer_agency_proposals_path,
            class: "text-xs text-base-content/40 hover:text-base-content transition-colors" %>
    </div>

    <div class="flex items-start justify-between gap-4 mb-8">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-1.5">Proposal</p>
        <h1 class="font-geist-sans text-xl font-semibold text-base-content"><%= @quote_request.title %></h1>
      </div>
      <span class="text-[10px] font-bold uppercase tracking-wide px-3 py-1.5 rounded-full shrink-0
        <%= case @proposal.status
            when 'draft'     then 'bg-base-content/[0.06] text-base-content/50'
            when 'submitted' then 'bg-primary/10 text-primary'
            when 'accepted'  then 'bg-success/10 text-success'
            when 'declined'  then 'bg-error/10 text-error'
            when 'withdrawn' then 'bg-base-content/[0.04] text-base-content/30'
            end %>">
        <%= @proposal.status %>
      </span>
    </div>

    <%# Edit form if draft %>
    <% if @proposal.editable? %>
      <%= form_with model: @proposal, url: developer_agency_proposal_path(@proposal), method: :patch, class: "space-y-5 mb-8" do |f| %>
        <div class="rounded-xl border border-base-content/[0.07] bg-base-content/[0.02] p-5 space-y-4">
          <h2 class="text-xs font-semibold text-base-content/50 uppercase tracking-widest">Edit proposal</h2>
          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-2">Pitch</label>
            <%= f.text_area :pitch, rows: 6, placeholder: "Describe your team's approach, experience, and why you're the right fit…",
                  class: "w-full px-4 py-3 rounded-xl bg-base-100 border border-base-content/10 text-base-content text-sm placeholder-base-content/30 focus:outline-none focus:border-primary/40 transition-colors resize-none" %>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-2">Proposed amount</label>
              <div class="flex items-center gap-1">
                <span class="text-base-content/40 text-sm px-2">$</span>
                <%= f.number_field :proposed_amount, min: 0, step: 1, placeholder: "0",
                      class: "flex-1 px-4 py-2.5 rounded-xl bg-base-100 border border-base-content/10 text-base-content text-sm focus:outline-none focus:border-primary/40 font-geist-mono" %>
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-2">Timeline</label>
              <%= f.text_field :proposed_timeline, placeholder: "e.g. 6–8 weeks",
                    class: "w-full px-4 py-2.5 rounded-xl bg-base-100 border border-base-content/10 text-base-content text-sm placeholder-base-content/30 focus:outline-none focus:border-primary/40" %>
            </div>
          </div>
          <div class="flex gap-3 justify-end pt-2">
            <button type="submit" class="px-5 py-2.5 rounded-xl bg-base-content/[0.06] text-base-content text-sm font-medium hover:bg-base-content/10 transition-colors">Save draft</button>
            <%= button_to "Submit proposal", submit_developer_agency_proposal_path(@proposal), method: :post,
                  class: "px-5 py-2.5 rounded-xl bg-primary text-primary-content text-sm font-medium hover:opacity-90 transition-opacity" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <%# Read-only view %>
      <div class="rounded-xl border border-base-content/[0.06] bg-base-content/[0.02] p-5 mb-6">
        <% if @proposal.pitch.present? %>
          <div class="mb-5">
            <p class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-2">Pitch</p>
            <p class="text-sm text-base-content/80 leading-relaxed whitespace-pre-wrap"><%= @proposal.pitch %></p>
          </div>
        <% end %>
        <div class="grid grid-cols-2 gap-4 pt-4 border-t border-base-content/[0.05]">
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-1">Amount</p>
            <p class="text-base-content font-geist-mono text-sm">
              <%= @proposal.proposed_amount ? "$#{number_with_delimiter(@proposal.proposed_amount.to_i)}" : "—" %>
            </p>
          </div>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-1">Timeline</p>
            <p class="text-base-content text-sm"><%= @proposal.proposed_timeline.presence || "—" %></p>
          </div>
          <% if @proposal.submitted_at %>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-1">Submitted</p>
              <p class="text-base-content/60 text-sm"><%= @proposal.submitted_at.strftime("%B %d, %Y") %></p>
            </div>
          <% end %>
        </div>
      </div>
      <% if @proposal.status == "submitted" %>
        <div class="flex justify-end">
          <%= button_to withdraw_developer_agency_proposal_path(@proposal), method: :post,
                data: { confirm: "Withdraw this proposal?" },
                class: "text-sm px-4 py-2 rounded-xl border border-error/20 text-error/60 hover:border-error/40 hover:text-error transition-colors" do %>
            Withdraw proposal
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%# Original quote request details %>
    <div class="mt-8 rounded-xl border border-base-content/[0.06] bg-base-content/[0.02] p-5">
      <p class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-4">Quote request details</p>
      <h3 class="text-sm font-semibold text-base-content mb-2"><%= @quote_request.title %></h3>
      <p class="text-sm text-base-content/60 leading-relaxed"><%= @quote_request.description %></p>
      <% if @quote_request.budget.present? %>
        <div class="mt-4 text-xs text-base-content/40">Budget: <span class="font-geist-mono text-base-content/60"><%= @quote_request.budget %></span></div>
      <% end %>
    </div>

  </div>
<% end %>
