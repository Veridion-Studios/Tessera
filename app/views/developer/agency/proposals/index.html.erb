<%= render layout: "shared/dashboard_shell", locals: { active_role: "developer", active_item: :agency_proposals } do %>
  <div class="px-6 lg:px-10 py-10">

    <div class="flex items-center justify-between mb-8">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-1.5">Agency · <%= @agency.name %></p>
        <h1 class="font-geist-sans text-2xl font-semibold text-base-content tracking-tight">Proposals</h1>
        <p class="text-sm text-base-content/40 mt-1">Bid on client projects as a team.</p>
      </div>
    </div>

    <%# Summary %>
    <div class="flex items-center gap-4 mb-8">
      <div class="px-4 py-2.5 rounded-xl bg-base-content/[0.03] border border-base-content/[0.05] text-sm">
        <span class="font-semibold text-base-content"><%= @draft_count %></span>
        <span class="text-base-content/40 ml-1">draft<%= @draft_count == 1 ? "" : "s" %></span>
      </div>
      <div class="px-4 py-2.5 rounded-xl bg-primary/5 border border-primary/10 text-sm">
        <span class="font-semibold text-primary"><%= @submitted_count %></span>
        <span class="text-base-content/40 ml-1">submitted</span>
      </div>
    </div>

    <% if @proposals.any? %>
      <div class="rounded-xl border border-base-content/[0.06] overflow-hidden divide-y divide-base-content/[0.04]">
        <% @proposals.each do |p| %>
          <div class="flex items-start gap-4 px-5 py-4 hover:bg-base-content/[0.02] transition-colors">
            <div class="min-w-0 flex-1">
              <%= link_to developer_agency_proposal_path(p), class: "text-sm font-medium text-base-content hover:text-primary transition-colors" do %>
                <%= p.quote_request.title %>
              <% end %>
              <div class="text-xs text-base-content/40 mt-0.5 flex items-center gap-2">
                <% if p.proposed_amount %>
                  <span class="font-geist-mono">$<%= number_with_delimiter(p.proposed_amount.to_i) %></span>
                  <span>·</span>
                <% end %>
                <% if p.proposed_timeline.present? %>
                  <span><%= p.proposed_timeline %></span>
                  <span>·</span>
                <% end %>
                <span><%= time_ago_in_words(p.created_at) %> ago</span>
              </div>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <span class="text-[10px] font-bold uppercase tracking-wide px-2.5 py-1 rounded-full
                <%= case p.status
                    when 'draft'      then 'bg-base-content/[0.06] text-base-content/50'
                    when 'submitted'  then 'bg-primary/10 text-primary'
                    when 'accepted'   then 'bg-success/10 text-success'
                    when 'declined'   then 'bg-error/10 text-error'
                    when 'withdrawn'  then 'bg-base-content/[0.04] text-base-content/30'
                    end %>">
                <%= p.status %>
              </span>
              <% if p.status == "draft" %>
                <%= button_to submit_developer_agency_proposal_path(p), method: :post,
                      class: "text-xs px-3 py-1.5 rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-colors font-medium" do %>Submit<% end %>
                <%= link_to "Edit", developer_agency_proposal_path(p),
                      class: "text-xs px-3 py-1.5 rounded-lg border border-base-content/10 text-base-content/50 hover:text-base-content hover:border-base-content/20 transition-colors" %>
              <% end %>
              <% if p.status == "submitted" %>
                <%= button_to withdraw_developer_agency_proposal_path(p), method: :post,
                      data: { confirm: "Withdraw this proposal?" },
                      class: "text-xs px-3 py-1.5 rounded-lg border border-error/20 text-error/60 hover:border-error/40 hover:text-error transition-colors" do %>Withdraw<% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-xl border border-dashed border-base-content/10 py-20 text-center">
        <p class="text-base-content/30 text-sm">No proposals yet.</p>
        <p class="text-base-content/20 text-xs mt-1.5">Browse open quote requests and submit team bids.</p>
        <%= link_to "Browse quote requests →", developer_quotes_path, class: "inline-block mt-4 text-xs text-primary hover:opacity-70" %>
      </div>
    <% end %>

  </div>
<% end %>
