<%= render layout: "shared/dashboard_shell", locals: { active_role: "developer", active_item: :agency_revenue } do %>
  <div class="px-6 lg:px-10 py-10">

    <div class="flex items-center justify-between mb-8">
      <div>
        <p class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-1.5">Agency · <%= @agency.name %></p>
        <h1 class="font-geist-sans text-2xl font-semibold text-base-content tracking-tight">Revenue Splits</h1>
        <p class="text-sm text-base-content/40 mt-1">Automatically distribute payments through Stripe Connect.</p>
      </div>
    </div>

    <%# Overview cards %>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-8">
      <div class="p-5 rounded-xl bg-primary/5 border border-primary/10">
        <div class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-2">Total Revenue</div>
        <div class="font-geist-sans text-2xl font-semibold text-primary">$<%= number_with_delimiter(@total_revenue.to_i) %></div>
      </div>
      <div class="p-5 rounded-xl bg-base-content/[0.03] border border-base-content/[0.05]">
        <div class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-2">This Month</div>
        <div class="font-geist-sans text-2xl font-semibold text-base-content">$<%= number_with_delimiter(@this_month.to_i) %></div>
      </div>
      <div class="p-5 rounded-xl <%= @unallocated_pct > 0.1 ? 'bg-warning/5 border-warning/10' : 'bg-success/5 border-success/10' %> border">
        <div class="text-[10px] font-bold uppercase tracking-widest text-base-content/40 mb-2">Unallocated</div>
        <div class="font-geist-sans text-2xl font-semibold <%= @unallocated_pct > 0.1 ? 'text-warning' : 'text-success' %>"><%= @unallocated_pct %>%</div>
        <div class="text-[11px] text-base-content/30 mt-1">
          <%= @total_pct %>% allocated of 100%
        </div>
      </div>
    </div>

    <% if @unallocated_pct > 0.1 %>
      <div class="mb-6 flex items-center gap-3 px-4 py-3 rounded-xl bg-warning/5 border border-warning/20">
        <span class="text-warning text-sm">⚠</span>
        <p class="text-sm text-base-content/60">
          <strong class="text-base-content"><%= @unallocated_pct %>%</strong> of revenue is unallocated. Adjust splits below to reach 100%.
        </p>
      </div>
    <% end %>

    <%# Visual split bar %>
    <div class="mb-8">
      <div class="h-3 rounded-full overflow-hidden flex bg-base-content/10">
        <% colors = %w[bg-primary bg-secondary bg-accent bg-info bg-success bg-warning] %>
        <% @memberships.each_with_index do |m, i| %>
          <% pct = ((m.revenue_share_pct || 0) * 100).round(1) %>
          <% next if pct <= 0 %>
          <div class="<%= colors[i % colors.length] %> h-full transition-all" style="width:<%= pct %>%"
               title="<%= m.display_name %>: <%= pct %>%"></div>
        <% end %>
      </div>
      <div class="flex flex-wrap gap-x-4 gap-y-1 mt-2">
        <% @memberships.each_with_index do |m, i| %>
          <% pct = ((m.revenue_share_pct || 0) * 100).round(1) %>
          <span class="flex items-center gap-1.5 text-xs text-base-content/50">
            <span class="w-2 h-2 rounded-full <%= colors[i % colors.length] %>"></span>
            <%= m.display_name %> <span class="text-base-content/30"><%= pct %>%</span>
          </span>
        <% end %>
      </div>
    </div>

    <%# Split editor %>
    <%= form_with url: developer_agency_update_revenue_path, method: :post, class: "space-y-3" do |f| %>
      <div class="rounded-xl border border-base-content/[0.06] overflow-hidden">
        <div class="grid grid-cols-12 px-5 py-3 border-b border-base-content/[0.05] bg-base-content/[0.02]">
          <span class="col-span-6 text-[10px] font-bold uppercase tracking-widest text-base-content/40">Member</span>
          <span class="col-span-4 text-[10px] font-bold uppercase tracking-widest text-base-content/40">Revenue share</span>
          <span class="col-span-2 text-[10px] font-bold uppercase tracking-widest text-base-content/40">Est. this month</span>
        </div>
        <% @memberships.each_with_index do |m, i| %>
          <% pct = ((m.revenue_share_pct || 0) * 100).round(1) %>
          <% est = (@this_month * (m.revenue_share_pct || 0)).round(2) %>
          <div class="grid grid-cols-12 items-center px-5 py-4 <%= i < @memberships.length - 1 ? 'border-b border-base-content/[0.04]' : '' %>">
            <div class="col-span-6 flex items-center gap-3">
              <span class="w-7 h-7 rounded-full bg-primary/15 flex items-center justify-center text-primary text-xs font-bold shrink-0"><%= m.user.email[0].upcase %></span>
              <div>
                <div class="text-sm font-medium text-base-content"><%= m.display_name %></div>
                <div class="text-xs text-base-content/40 capitalize"><%= m.role %></div>
              </div>
            </div>
            <div class="col-span-4">
              <div class="flex items-center gap-2">
                <input type="number" name="splits[<%= m.id %>]"
                       value="<%= pct %>"
                       min="0" max="100" step="0.1"
                       class="w-24 px-3 py-1.5 rounded-xl bg-base-100 border border-base-content/10 text-base-content text-sm text-right focus:outline-none focus:border-primary/40 font-geist-mono" />
                <span class="text-sm text-base-content/40">%</span>
              </div>
            </div>
            <div class="col-span-2">
              <span class="text-sm font-geist-mono text-base-content/60">$<%= number_with_delimiter(est) %></span>
            </div>
          </div>
        <% end %>
      </div>

      <div class="flex items-center justify-between pt-2">
        <p class="text-xs text-base-content/30">Payments are automatically distributed via Stripe Connect when milestones are approved.</p>
        <button type="submit" class="px-5 py-2.5 rounded-xl bg-primary text-primary-content text-sm font-medium hover:opacity-90 transition-opacity ml-4 shrink-0">Save splits</button>
      </div>
    <% end %>

  </div>
<% end %>
