<% clients = User.joins(:customer_profile).where.not(id: current_user.id).order(:email) %>

<%= form_with model: subscription, url: subscription.persisted? ? developer_subscription_path(subscription) : developer_subscriptions_path,
    method: subscription.persisted? ? :patch : :post, class: "space-y-5" do |f| %>

  <div class="p-5 rounded-xl bg-white/[0.02] border border-white/[0.05] space-y-4">
    <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">Details</h2>
    <div>
      <%= f.label :name, "Plan name", class: "block text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-2" %>
      <%= f.text_field :name, placeholder: "e.g. Monthly retainer, Hosting + support",
          class: "w-full px-3 py-2.5 rounded-xl bg-zinc-800 border border-white/10 text-zinc-100 text-sm focus:outline-none focus:border-primary/50 transition-colors" %>
    </div>
    <div>
      <%= f.label :description, "Description (optional)", class: "block text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-2" %>
      <%= f.text_area :description, rows: 2, placeholder: "What's included…",
          class: "w-full px-3 py-2.5 rounded-xl bg-zinc-800 border border-white/10 text-zinc-100 text-sm focus:outline-none focus:border-primary/50 transition-colors resize-none" %>
    </div>
  </div>

  <div class="p-5 rounded-xl bg-white/[0.02] border border-white/[0.05] space-y-4">
    <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">Client & billing</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :client_id, "Client", class: "block text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-2" %>
        <%= f.select :client_id,
            clients.map { |u| [u.customer_profile&.display_name || u.email.split("@").first, u.id] },
            { include_blank: "Select client…" },
            class: "w-full px-3 py-2.5 rounded-xl bg-zinc-800 border border-white/10 text-zinc-100 text-sm focus:outline-none focus:border-primary/50 transition-colors" %>
      </div>
      <div>
        <%= f.label :interval, "Billing interval", class: "block text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-2" %>
        <%= f.select :interval, [["Weekly","week"],["Monthly","month"],["Yearly","year"]],
            {},
            class: "w-full px-3 py-2.5 rounded-xl bg-zinc-800 border border-white/10 text-zinc-100 text-sm focus:outline-none focus:border-primary/50 transition-colors" %>
      </div>
      <div>
        <%= f.label :amount, "Amount", class: "block text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-2" %>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500 text-sm">$</span>
          <%= f.number_field :amount, min: 0, step: 0.01, placeholder: "0.00",
              class: "w-full pl-7 pr-3 py-2.5 rounded-xl bg-zinc-800 border border-white/10 text-zinc-100 text-sm focus:outline-none focus:border-primary/50 transition-colors" %>
        </div>
      </div>
      <div>
        <%= f.label :currency, "Currency", class: "block text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-2" %>
        <%= f.select :currency, [["USD","usd"],["GBP","gbp"],["EUR","eur"]],
            {},
            class: "w-full px-3 py-2.5 rounded-xl bg-zinc-800 border border-white/10 text-zinc-100 text-sm focus:outline-none focus:border-primary/50 transition-colors" %>
      </div>
    </div>
  </div>

  <div class="p-5 rounded-xl bg-white/[0.02] border border-white/[0.05] space-y-4">
    <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500">Notes</h2>
    <%= f.text_area :notes, rows: 3, placeholder: "Internal notes — not visible to client…",
        class: "w-full px-3 py-2.5 rounded-xl bg-zinc-800 border border-white/10 text-zinc-100 text-sm focus:outline-none focus:border-primary/50 transition-colors resize-none" %>
  </div>

  <div class="flex items-center gap-3 pt-1">
    <%= f.submit subscription.persisted? ? "Save changes" : "Create subscription",
        class: "px-5 py-2.5 rounded-xl btn btn-primary text-sm font-medium cursor-pointer" %>
    <%= link_to "Cancel",
        subscription.persisted? ? developer_subscription_path(subscription) : developer_subscriptions_path,
        class: "px-4 py-2.5 text-sm text-zinc-500 hover:text-zinc-300 transition-colors" %>
  </div>

<% end %>