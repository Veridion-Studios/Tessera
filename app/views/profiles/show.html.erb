<%= render "shared/home_navbar" %>

<div class="min-h-screen">
  <div class="mx-auto max-w-7xl px-6 sm:px-12 py-10">

    <%= link_to gallery_path, class: "inline-flex items-center gap-2 text-xs text-zinc-600 hover:text-zinc-400 transition-colors mb-10" do %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      Gallery
    <% end %>

    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">

      <%# ── Identity column ──────────────────────────────────── %>
      <aside class="w-full lg:w-64 shrink-0">
        <div class="sticky top-6">

          <%# Avatar %>
          <div class="w-14 h-14 rounded-full bg-primary/15 flex items-center justify-center mb-5">
            <span class="font-geist-sans font-bold text-primary text-xl leading-none">
              <%= (@profile.display_name&.first || @user.email.first).upcase %>
            </span>
          </div>

          <h1 class="font-geist-sans text-xl font-semibold text-white leading-snug mb-0.5">
            <%= @profile.display_name || @user.email.split("@").first %>
          </h1>
          <% if @user.username.present? %>
            <p class="font-geist-mono text-xs text-zinc-600 mb-4">@<%= @user.username %></p>
          <% end %>

          <%# Availability %>
          <% if @profile.availability == "open" %>
            <p class="flex items-center gap-1.5 text-[11px] text-primary mb-4">
              <span class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>Available for work
            </p>
          <% elsif @profile.availability == "busy" %>
            <p class="flex items-center gap-1.5 text-[11px] text-yellow-500 mb-4">
              <span class="h-1.5 w-1.5 rounded-full bg-yellow-500"></span>Busy
            </p>
          <% end %>

          <%# Verified pill — minimal %>
          <div class="flex items-center gap-1.5 mb-6 text-[11px] text-zinc-500">
            <svg class="w-3 h-3 text-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Tessera verified developer
          </div>

          <%# Meta %>
          <div class="space-y-2.5 mb-6 text-sm">
            <% if @profile.location.present? %>
              <div class="flex items-center gap-2 text-zinc-500">
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                <span><%= @profile.location %></span>
              </div>
            <% end %>
            <% if @profile.hourly_rate.present? %>
              <div class="text-zinc-500">$<%= @profile.hourly_rate.to_i %>/hr</div>
            <% end %>
            <% if @profile.github_username.present? %>
              <a href="https://github.com/<%= @profile.github_username %>" target="_blank" rel="noopener noreferrer"
                 class="flex items-center gap-2 text-zinc-500 hover:text-white transition-colors">
                <svg class="w-3.5 h-3.5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                @<%= @profile.github_username %>
              </a>
            <% end %>
            <% if @profile.website_url.present? %>
              <a href="<%= @profile.website_url %>" target="_blank" rel="noopener noreferrer"
                 class="flex items-center gap-2 text-zinc-500 hover:text-white transition-colors truncate">
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
                <span class="truncate"><%= @profile.website_url.gsub(/\Ahttps?:\/\//, "") %></span>
              </a>
            <% end %>
          </div>

          <%# Skill tags — plain text %>
          <% if @profile.skill_tags.any? %>
            <div class="flex flex-wrap gap-x-3 gap-y-1 mb-6">
              <% @profile.skill_tags.each do |tag| %>
                <span class="text-xs text-zinc-500"><%= tag %></span>
              <% end %>
            </div>
          <% end %>

          <%# CTAs %>
          <div class="flex flex-col gap-2">
            <% if current_user&.customer? %>
              <%= link_to "Request a quote", new_client_quote_path(developer_id: @user.id),
                  class: "block w-full text-center py-2.5 rounded-xl btn btn-primary text-sm" %>
            <% elsif !current_user %>
              <%= link_to "Request a quote", join_path(role: "customer"),
                  class: "block w-full text-center py-2.5 rounded-xl btn btn-primary text-sm" %>
            <% end %>
            <button disabled
              class="w-full py-2.5 rounded-xl text-zinc-700 text-sm flex items-center justify-center gap-2 cursor-not-allowed">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z"/></svg>
              Save to library <span class="text-[10px]">· soon</span>
            </button>
          </div>
        </div>
      </aside>

      <%# ── Content ──────────────────────────────────────────── %>
      <main class="flex-1 min-w-0 space-y-12">

        <% if @profile.bio.present? %>
          <section>
            <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-4">About</h2>
            <p class="text-zinc-300 text-sm leading-relaxed whitespace-pre-line max-w-prose"><%= @profile.bio %></p>
          </section>
        <% end %>

        <section>
          <h2 class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-6">Portfolio</h2>
          <% if @submissions.empty? %>
            <p class="text-zinc-600 text-sm">No approved projects yet.</p>
          <% else %>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <% @submissions.each do |sub| %>
                <article>
                  <%# Project header %>
                  <div class="flex items-start justify-between gap-3 mb-3">
                    <h3 class="font-semibold text-white text-sm leading-snug"><%= sub.title %></h3>
                    <div class="flex items-center gap-2.5 shrink-0">
                      <a href="<%= sub.github_repo_url %>" target="_blank" rel="noopener noreferrer"
                         class="text-zinc-600 hover:text-white transition-colors" title="GitHub">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                      </a>
                      <% if sub.project_demo_url.present? %>
                        <a href="<%= sub.project_demo_url %>" target="_blank" rel="noopener noreferrer"
                           class="text-zinc-600 hover:text-white transition-colors" title="Live demo">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
                        </a>
                      <% end %>
                    </div>
                  </div>

                  <div class="font-geist-mono text-[11px] text-zinc-700 truncate mb-3 pl-3 border-l border-white/[0.06]">
                    <%= sub.github_repo_url.gsub("https://github.com/", "") %>
                  </div>

                  <% if sub.description.present? %>
                    <p class="text-zinc-500 text-xs leading-relaxed mb-3 line-clamp-3"><%= sub.description %></p>
                  <% end %>

                  <% if sub.tech_tags.any? %>
                    <div class="flex flex-wrap gap-x-3 gap-y-1">
                      <% sub.tech_tags.each do |tag| %>
                        <span class="text-[11px] text-zinc-600"><%= tag %></span>
                      <% end %>
                    </div>
                  <% end %>
                </article>
              <% end %>
            </div>
          <% end %>
        </section>

      </main>
    </div>
  </div>
</div>