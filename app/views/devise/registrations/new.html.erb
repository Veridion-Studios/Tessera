<% role = resource.initial_role.presence || params.dig(resource_name, "role").presence || params[:role].presence || "customer" %>
<% role = "customer" unless %w[customer developer].include?(role) %>
<% is_dev = role == "developer" %>
<% accent = is_dev ? "violet" : "indigo" %>

<div class="min-h-screen bg-zinc-950 flex flex-col items-center justify-center px-6 py-16">
  <a href="/" class="text-lg font-semibold tracking-tight text-white mb-12">Tessera</a>

  <div class="w-full max-w-md">
    <div class="mb-8 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 mb-4 rounded-full border border-<%= accent %>-500/30 bg-<%= accent %>-500/10 text-<%= accent %>-300 text-xs font-medium">
        <%= is_dev ? "⌨️ Developer account" : "💼 Client account" %>
      </div>
      <h1 class="text-2xl font-bold text-white">Create your account</h1>
      <p class="text-zinc-400 text-sm mt-1">
        <%= is_dev ? "Get verified and start taking on projects." : "Find and hire verified developers." %>
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= hidden_field_tag "#{resource_name}[role]", role %>

      <% if resource.errors.any? %>
        <div class="mb-6 rounded-xl border border-red-500/20 bg-red-500/10 p-4">
          <p class="text-red-400 text-sm font-medium mb-1">Please fix the following:</p>
          <ul class="text-red-400 text-sm list-disc list-inside space-y-1">
            <% resource.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <%= f.label :email, class: "block text-sm text-zinc-300 mb-1.5 font-medium" %>
          <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "you@example.com",
              class: "w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white placeholder-zinc-500 text-sm focus:outline-none focus:border-#{accent}-500/50 focus:ring-1 focus:ring-#{accent}-500/30 transition-colors" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm text-zinc-300 mb-1.5 font-medium" %>
          <%= f.password_field :password,
              autocomplete: "new-password",
              placeholder: "At least 8 characters",
              class: "w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white placeholder-zinc-500 text-sm focus:outline-none focus:border-#{accent}-500/50 focus:ring-1 focus:ring-#{accent}-500/30 transition-colors" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm password", class: "block text-sm text-zinc-300 mb-1.5 font-medium" %>
          <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              placeholder: "Repeat your password",
              class: "w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white placeholder-zinc-500 text-sm focus:outline-none focus:border-#{accent}-500/50 focus:ring-1 focus:ring-#{accent}-500/30 transition-colors" %>
        </div>
      </div>

      <div class="mt-6">
        <%= f.submit "Create account",
            class: "w-full py-2.5 rounded-xl bg-#{accent}-600 hover:bg-#{accent}-500 text-white font-semibold text-sm transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <p class="mt-6 text-center text-zinc-500 text-sm">
      Already have an account? <%= link_to "Sign in", new_user_session_path, class: "text-zinc-300 hover:text-white transition-colors" %>
    </p>
    <p class="mt-2 text-center text-zinc-600 text-xs">
      <%= link_to "← Back", join_path, class: "hover:text-zinc-400 transition-colors" %>
    </p>
  </div>
</div>