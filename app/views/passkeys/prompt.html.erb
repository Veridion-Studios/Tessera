<div class="min-h-screen bg-zinc-950 flex flex-col items-center justify-center px-6 py-16"
     x-data="passkeyPrompt()"
     x-init="init()">

  <a href="/" class="text-lg font-semibold tracking-tight text-white mb-12">Tessera</a>

  <div class="w-full max-w-md text-center">
    <div class="w-16 h-16 rounded-2xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center text-3xl mx-auto mb-6">🔑</div>
    <h1 class="text-2xl font-bold text-white mb-2">Add a passkey?</h1>
    <p class="text-zinc-400 text-sm leading-relaxed mb-8">
      Passkeys let you sign in with Face ID, Touch ID, or your device PIN — no password needed. You can always add one later in account settings.
    </p>

    <div x-show="error" class="mb-4 rounded-xl border border-red-500/20 bg-red-500/10 px-4 py-3 text-red-400 text-sm" x-text="error"></div>
    <div x-show="success" class="mb-4 rounded-xl border border-green-500/20 bg-green-500/10 px-4 py-3 text-green-400 text-sm">Passkey added! You're all set.</div>

    <div class="flex flex-col gap-3" x-show="!success">
      <div x-show="!labelling">
        <button @click="labelling = true"
          class="w-full py-2.5 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold text-sm transition-colors">
          Set up passkey
        </button>
      </div>

      <div x-show="labelling" class="space-y-3">
        <input x-model="label" type="text" placeholder='Name this passkey e.g. "MacBook Touch ID"'
          class="w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white placeholder-zinc-500 text-sm focus:outline-none focus:border-violet-500/50 transition-colors" />
        <button @click="createPasskey()"
          :disabled="loading"
          class="w-full py-2.5 rounded-xl bg-violet-600 hover:bg-violet-500 disabled:opacity-50 text-white font-semibold text-sm transition-colors">
          <span x-text="loading ? 'Waiting for your device...' : 'Continue'"></span>
        </button>
      </div>

      <%= link_to "Skip for now", pick_dashboard_path,
          class: "block w-full py-2.5 rounded-xl border border-white/10 hover:bg-white/5 text-zinc-400 font-medium text-sm transition-colors" %>
    </div>

    <div x-show="success" class="mt-4">
      <%= link_to "Continue to dashboard →", pick_dashboard_path,
          class: "block w-full py-2.5 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold text-sm transition-colors" %>
    </div>
  </div>
</div>

<script>
function passkeyPrompt() {
  return {
    labelling: false,
    label: "",
    loading: false,
    error: null,
    success: false,

    init() {},

    async createPasskey() {
      this.loading = true;
      this.error = null;

      try {
        const optRes = await fetch("<%= passkey_options_path %>", {
          method: "POST",
          headers: {
            "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content,
            "Content-Type": "application/json"
          }
        });
        const options = await optRes.json();

        options.challenge = this.toBuffer(options.challenge);
        options.user.id   = this.toBuffer(options.user.id);
        if (options.excludeCredentials) {
          options.excludeCredentials = options.excludeCredentials.map(c => ({
            ...c, id: this.toBuffer(c.id)
          }));
        }

        const credential = await navigator.credentials.create({ publicKey: options });

        const credJson = {
          id:    credential.id,
          rawId: this.bufferToBase64(credential.rawId),
          type:  credential.type,
          response: {
            clientDataJSON:    this.bufferToBase64(credential.response.clientDataJSON),
            attestationObject: this.bufferToBase64(credential.response.attestationObject)
          }
        };

        const saveRes = await fetch("<%= create_passkey_path %>", {
          method: "POST",
          headers: {
            "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content,
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ credential: credJson, label: this.label })
        });

        const result = await saveRes.json();
        if (result.error) throw new Error(result.error);

        this.success = true;
      } catch(e) {
        this.error = e.message || "Something went wrong. Try again.";
      } finally {
        this.loading = false;
      }
    },

    toBuffer(val) {
      if (typeof val === "string") {
        const normalized = val.replace(/-/g, '+').replace(/_/g, '/');
        const padded = normalized + "=".repeat((4 - (normalized.length % 4)) % 4);
        const str = atob(padded);
        return Uint8Array.from(str, c => c.charCodeAt(0));
      }
      if (val instanceof ArrayBuffer) return new Uint8Array(val);
      if (ArrayBuffer.isView(val))    return new Uint8Array(val.buffer);
      if (Array.isArray(val))         return new Uint8Array(val);
      if (val && typeof val === "object" && Array.isArray(val.data)) {
        return new Uint8Array(val.data);
      }
      return val;
    },

    bufferToBase64(buffer) {
      return btoa(String.fromCharCode(...new Uint8Array(buffer)))
        .replace(/\+/g, '-').replace(/\//g, '_');
    }
  }
}
</script>