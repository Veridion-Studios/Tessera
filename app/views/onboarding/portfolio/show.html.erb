<% @profile = current_user.developer_profile %>

<%= render layout: "shared/auth_shell" do %>
  <div class="w-full max-w-2xl">
    <%= render "onboarding/steps", current_step: :portfolio, profile: @profile %>

    <div class="mb-8">
      <h1 class="font-geist-sans text-2xl font-semibold text-white mb-2">Submit your portfolio</h1>
      <p class="text-zinc-500 text-sm">Add at least one public project. Our team will review and approve before you move on.</p>
    </div>

    <div class="rounded-2xl border <%= @profile.github_connected? ? 'border-primary/20 bg-primary/5' : 'border-white/8 bg-white/2' %> p-5 mb-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-sm">⌥</div>
          <div>
            <div class="text-sm font-medium text-white">GitHub</div>
            <div class="text-xs text-zinc-500">
              <% if @profile.github_connected? %>Connected as <span class="text-primary">@<%= @profile.github_username %></span><% else %>Connect your GitHub to show public repos<% end %>
            </div>
          </div>
        </div>
        <%= button_to(@profile.github_connected? ? "Refresh GitHub Access" : "Connect GitHub", github_auth_path, method: :post,
            class: "px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-white text-xs font-medium transition-colors") %>
      </div>
    </div>

    <div class="rounded-2xl border border-white/8 bg-white/2 p-6 mb-8">
      <h2 class="text-sm font-semibold text-white mb-4">Add a project</h2>
      <%= form_with model: @submission, url: onboarding_portfolio_path, class: "space-y-4" do |f| %>
        <% if @submission.errors.any? %>
          <div class="rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-red-400 text-sm">
            <% @submission.errors.full_messages.each do |msg| %><div><%= msg %></div><% end %>
          </div>
        <% end %>

        <div>
          <%= f.label :title, "Project title", class: "block text-sm text-zinc-400 mb-1.5" %>
          <%= f.text_field :title, placeholder: "My awesome app",
              class: "w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/50 transition-colors" %>
        </div>

        <div data-github-repo-picker data-github-repo-source="<%= onboarding_portfolio_github_repos_path %>">
          <%= f.label :github_repo_url, "GitHub Project", class: "block text-sm text-zinc-400 mb-1.5" %>
          <%= f.hidden_field :github_repo_url, data: { github_repo_picker_target: "value" } %>
          <input type="text" placeholder="Search your GitHub repos..."
                 data-github-repo-picker-target="input"
                 value="<%= @submission.github_repo_url %>"
                 autocomplete="off"
                 class="w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/50 transition-colors">
          <div data-github-repo-picker-target="results"
               class="hidden mt-2 rounded-xl border border-white/10 bg-zinc-900/95 backdrop-blur-sm max-h-64 overflow-y-auto"></div>
          <p class="text-xs text-zinc-600 mt-1.5">Type to search public and private repositories from your connected GitHub account.</p>
        </div>

        <div>
          <%= f.label :project_demo_url, "Project Demo URL", class: "block text-sm text-zinc-400 mb-1.5" %>
          <%= f.url_field :project_demo_url, placeholder: "https://your-demo.example.com",
              class: "w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/50 transition-colors" %>
        </div>

        <div>
          <%= f.label :description, "What did you build?", class: "block text-sm text-zinc-400 mb-1.5" %>
          <%= f.text_area :description, rows: 3, placeholder: "Describe the project, your role, and any notable challenges...",
              class: "w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/50 transition-colors resize-none" %>
        </div>

        <div>
          <label class="block text-sm text-zinc-400 mb-2">Tech tags</label>
          <div class="flex flex-wrap gap-2">
            <% @tech_tags.each do |tag| %>
              <label class="cursor-pointer">
                <%= f.check_box :tech_tags, { multiple: true, checked: @submission.tech_tags.include?(tag) }, tag, false %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs border border-white/8 bg-white/3 text-zinc-500 hover:border-primary/30 hover:text-primary transition-colors has-[:checked]:border-primary/30 has-[:checked]:bg-primary/10 has-[:checked]:text-primary">
                  <%= tag %>
                </span>
              </label>
            <% end %>
          </div>
        </div>

        <%= f.submit "Submit project →", class: "w-full py-2.5 rounded-xl btn btn-primary text-sm cursor-pointer" %>
      <% end %>
    </div>

    <% if @submissions.any? %>
      <h2 class="text-sm font-semibold text-white mb-3">Submitted projects</h2>
      <div class="space-y-3 mb-6">
        <% @submissions.each do |sub| %>
          <div class="rounded-xl border border-white/5 bg-white/2 p-4 flex items-start justify-between gap-4">
            <div>
              <div class="text-sm font-medium text-white mb-0.5"><%= sub.title %></div>
              <div class="text-xs text-zinc-600 truncate max-w-xs"><%= sub.github_repo_url %></div>
              <% if sub.project_demo_url.present? %>
                <a href="<%= sub.project_demo_url %>" target="_blank" class="text-xs text-primary hover:text-primary/80 transition-colors mt-1 block">Demo ↗</a>
              <% end %>
              <% if sub.tech_tags.any? %>
                <div class="flex flex-wrap gap-1 mt-2">
                  <% sub.tech_tags.each do |tag| %>
                    <span class="px-2 py-0.5 rounded-full bg-white/5 text-zinc-500 text-xs"><%= tag %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
            <span class="shrink-0 px-2.5 py-1 rounded-full text-xs font-medium
              <%= sub.status == 'approved' ? 'bg-primary/10 text-primary border border-primary/20' :
                  sub.status == 'rejected' ? 'bg-red-500/10 text-red-400 border border-red-500/20' :
                                             'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20' %>">
              <%= sub.status.capitalize %>
            </span>
          </div>
        <% end %>
      </div>
      <% if @profile.portfolio_approved? %>
        <%= link_to "Continue to identity verification →", onboarding_identity_path,
            class: "block w-full text-center py-2.5 rounded-xl btn btn-primary text-sm" %>
      <% else %>
        <p class="text-center text-zinc-600 text-xs">Waiting for team approval before you can continue.</p>
      <% end %>
    <% end %>
  </div>
<% end %>