<% @profile = current_user.developer_profile %>

<div class="min-h-screen bg-zinc-950 px-6 py-16">
  <div class="max-w-2xl mx-auto">
    <a href="/" class="text-lg font-semibold tracking-tight text-white block mb-12">Tessera</a>

    <%= render "onboarding/steps", current_step: :portfolio, profile: @profile %>

    <div class="mb-8">
      <h1 class="text-2xl font-bold text-white mb-2">Submit your portfolio</h1>
      <p class="text-zinc-400 text-sm">Add at least one public project. Our team will review and approve before you move on.</p>
    </div>

    <%# GitHub connection %>
    <div class="rounded-2xl border <%= @profile.github_connected? ? 'border-green-500/20 bg-green-500/5' : 'border-white/10 bg-white/2' %> p-5 mb-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-sm">⌥</div>
          <div>
            <div class="text-sm font-medium text-white">GitHub</div>
            <div class="text-xs text-zinc-400">
              <% if @profile.github_connected? %>
                Connected as <span class="text-green-400">@<%= @profile.github_username %></span>
              <% else %>
                Connect your GitHub to show public repos
              <% end %>
            </div>
          </div>
        </div>
        <% unless @profile.github_connected? %>
          <%= button_to "Connect GitHub", github_auth_path, method: :post,
              class: "px-4 py-2 rounded-lg bg-white/5 hover:bg-white/10 border border-white/10 text-white text-xs font-medium transition-colors" %>
        <% end %>
      </div>
    </div>

    <%# Submission form %>
    <div class="rounded-2xl border border-white/10 bg-white/2 p-6 mb-8">
      <h2 class="text-sm font-semibold text-white mb-4">Add a project</h2>

      <%= form_with model: @submission, url: onboarding_portfolio_path, class: "space-y-4" do |f| %>
        <% if @submission.errors.any? %>
          <div class="rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-red-400 text-sm">
            <% @submission.errors.full_messages.each do |msg| %>
              <div><%= msg %></div>
            <% end %>
          </div>
        <% end %>

        <div>
          <%= f.label :title, "Project title", class: "block text-sm text-zinc-300 mb-1.5 font-medium" %>
          <%= f.text_field :title, placeholder: "My awesome app",
              class: "w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white placeholder-zinc-500 text-sm focus:outline-none focus:border-violet-500/50 focus:ring-1 focus:ring-violet-500/30 transition-colors" %>
        </div>

        <div>
          <%= f.label :project_url, "Project URL", class: "block text-sm text-zinc-300 mb-1.5 font-medium" %>
          <%= f.url_field :project_url, placeholder: "https://github.com/you/project",
              class: "w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white placeholder-zinc-500 text-sm focus:outline-none focus:border-violet-500/50 focus:ring-1 focus:ring-violet-500/30 transition-colors" %>
        </div>

        <div>
          <%= f.label :description, "What did you build?", class: "block text-sm text-zinc-300 mb-1.5 font-medium" %>
          <%= f.text_area :description, rows: 3, placeholder: "Describe the project, your role, and any notable challenges...",
              class: "w-full px-4 py-2.5 rounded-xl bg-white/5 border border-white/10 text-white placeholder-zinc-500 text-sm focus:outline-none focus:border-violet-500/50 focus:ring-1 focus:ring-violet-500/30 transition-colors resize-none" %>
        </div>

        <div>
          <label class="block text-sm text-zinc-300 mb-2 font-medium">Tech tags</label>
          <div class="flex flex-wrap gap-2">
            <% @tech_tags.each do |tag| %>
              <label class="cursor-pointer">
                <%= f.check_box :tech_tags, { multiple: true, checked: @submission.tech_tags.include?(tag) }, tag, false %>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs border border-white/10 bg-white/5 text-zinc-400 hover:border-violet-500/40 hover:text-violet-300 transition-colors has-[:checked]:border-violet-500/40 has-[:checked]:bg-violet-500/10 has-[:checked]:text-violet-300">
                  <%= tag %>
                </span>
              </label>
            <% end %>
          </div>
        </div>

        <%= f.submit "Submit project →",
            class: "w-full py-2.5 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold text-sm transition-colors cursor-pointer" %>
      <% end %>
    </div>

    <%# Existing submissions %>
    <% if @submissions.any? %>
      <h2 class="text-sm font-semibold text-white mb-3">Submitted projects</h2>
      <div class="space-y-3">
        <% @submissions.each do |sub| %>
          <div class="rounded-xl border border-white/5 bg-white/2 p-4 flex items-start justify-between gap-4">
            <div>
              <div class="text-sm font-medium text-white mb-0.5"><%= sub.title %></div>
              <div class="text-xs text-zinc-500 truncate max-w-xs"><%= sub.project_url %></div>
              <% if sub.tech_tags.any? %>
                <div class="flex flex-wrap gap-1 mt-2">
                  <% sub.tech_tags.each do |tag| %>
                    <span class="px-2 py-0.5 rounded-full bg-white/5 text-zinc-400 text-xs"><%= tag %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
            <span class="shrink-0 px-2.5 py-1 rounded-full text-xs font-medium
              <%= sub.status == 'approved' ? 'bg-green-500/10 text-green-400 border border-green-500/20' :
                  sub.status == 'rejected' ? 'bg-red-500/10 text-red-400 border border-red-500/20' :
                                             'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20' %>">
              <%= sub.status.capitalize %>
            </span>
          </div>
        <% end %>
      </div>

      <% if @profile.portfolio_approved? %>
        <div class="mt-6">
          <%= link_to "Continue to identity verification →", onboarding_identity_path,
              class: "block w-full text-center py-2.5 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold text-sm transition-colors" %>
        </div>
      <% else %>
        <p class="mt-4 text-center text-zinc-500 text-xs">Waiting for team approval before you can continue.</p>
      <% end %>
    <% end %>
  </div>
</div>