<% @profile = current_user.developer_profile %>

<%= render layout: "shared/auth_shell" do %>
  <div class="w-full max-w-lg">
    <%= render "onboarding/steps", current_step: :identity, profile: @profile %>

    <% if current_user.identity_status == "verified" %>
      <div class="rounded-2xl border border-primary/20 bg-primary/5 p-8 mb-6 text-center">
        <div class="text-3xl mb-3">✓</div>
        <h1 class="font-geist-sans text-xl font-semibold text-white mb-2">Identity verified</h1>
        <p class="text-zinc-500 text-sm">Your identity has been confirmed by Stripe.</p>
      </div>
      <%= link_to "Continue to Stripe Connect →", onboarding_connect_path,
          class: "block w-full text-center py-2.5 rounded-xl btn btn-primary text-sm" %>
    <% else %>
      <div class="mb-8 text-center">
        <div class="w-14 h-14 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center text-2xl mx-auto mb-4">🪪</div>
        <h1 class="font-geist-sans text-2xl font-semibold text-white mb-2">Verify your identity</h1>
        <p class="text-zinc-500 text-sm leading-relaxed max-w-sm mx-auto">We use Stripe Identity to verify who you are. This is required before you can receive payments. It takes about 2 minutes.</p>
      </div>

      <div class="rounded-2xl border border-white/8 bg-white/2 p-6 mb-6 space-y-3">
        <% ["Government-issued ID (passport, driver's license, or ID card)", "A short selfie or camera verification", "Processed securely by Stripe — we never see your documents"].each do |item| %>
          <div class="flex items-start gap-3 text-sm text-zinc-400">
            <span class="mt-0.5 h-px w-4 shrink-0 bg-primary/60"></span>
            <%= item %>
          </div>
        <% end %>
      </div>

      <% if current_user.identity_status == "pending" %>
        <p class="text-yellow-400 text-sm mb-4 text-center">Verification in progress. If you already completed it, click below to check.</p>
        <%= link_to "Check verification status", onboarding_identity_refresh_path,
            class: "block w-full text-center py-2.5 rounded-xl border border-white/10 hover:bg-white/5 text-zinc-400 text-sm font-medium transition-colors mb-3" %>
      <% end %>

      <%= button_to "Start identity verification →", onboarding_identity_start_path,
          class: "w-full py-2.5 rounded-xl btn btn-primary text-sm cursor-pointer" %>
    <% end %>
  </div>
<% end %>