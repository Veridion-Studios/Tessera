<% @profile = current_user.developer_profile %>

<div class="min-h-screen bg-zinc-950 px-6 py-16">
  <div class="max-w-lg mx-auto text-center">
    <a href="/" class="text-lg font-semibold tracking-tight text-white block mb-12">Tessera</a>

    <%= render "onboarding/steps", current_step: :identity, profile: @profile %>

    <% if current_user.identity_status == "verified" %>
      <div class="rounded-2xl border border-green-500/20 bg-green-500/5 p-8 mb-6">
        <div class="text-3xl mb-3">✓</div>
        <h1 class="text-xl font-bold text-white mb-2">Identity verified</h1>
        <p class="text-zinc-400 text-sm">Your identity has been confirmed by Stripe.</p>
      </div>
      <%= link_to "Continue to Stripe Connect →", onboarding_connect_path,
          class: "block w-full text-center py-2.5 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold text-sm transition-colors" %>
    <% else %>
      <div class="mb-8">
        <div class="w-14 h-14 rounded-2xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center text-2xl mx-auto mb-4">🪪</div>
        <h1 class="text-2xl font-bold text-white mb-2">Verify your identity</h1>
        <p class="text-zinc-400 text-sm leading-relaxed">We use Stripe Identity to verify who you are. This is required before you can receive payments. It takes about 2 minutes.</p>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/2 p-6 mb-6 text-left space-y-3">
        <% [
          "Government-issued ID (passport, driver's license, or ID card)",
          "A short selfie or camera verification",
          "Processed securely by Stripe — we never see your documents",
        ].each do |item| %>
          <div class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="shrink-0 w-5 h-5 rounded-full bg-violet-500/15 border border-violet-500/30 flex items-center justify-center text-violet-400 text-xs mt-0.5">✓</span>
            <%= item %>
          </div>
        <% end %>
      </div>

      <% if current_user.identity_status == "pending" %>
        <p class="text-yellow-400 text-sm mb-4">Verification in progress. If you already completed it, click below to check.</p>
        <%= link_to "Check verification status", onboarding_identity_refresh_path,
            class: "block w-full text-center py-2.5 rounded-xl border border-violet-500/30 text-violet-300 hover:bg-violet-500/10 text-sm font-medium transition-colors mb-3" %>
      <% end %>

      <%= button_to "Start identity verification →", onboarding_identity_start_path,
          class: "w-full py-2.5 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold text-sm transition-colors cursor-pointer" %>
    <% end %>
  </div>
</div>