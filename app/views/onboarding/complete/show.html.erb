<%= render layout: "shared/auth_shell" do %>
  <div class="text-center max-w-sm w-full">
    <div class="w-16 h-16 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center text-3xl mx-auto mb-6">🎉</div>
    <h1 class="font-geist-sans text-3xl font-semibold text-white mb-3">You're all set up</h1>
    <p class="text-zinc-500 text-sm leading-relaxed mb-8">
      Your portfolio has been submitted for final team review. Once approved, your profile will go live and you'll start receiving quote requests.
    </p>

    <div class="rounded-2xl border border-white/8 bg-white/2 p-6 text-left space-y-3 mb-8">
      <% [
        { label: "Identity verified",       done: current_user.identity_status == "verified" },
        { label: "Stripe Connect active",   done: current_user.developer_profile.connect_onboarding_status == "active" },
        { label: "Portfolio under review",  done: true },
      ].each do |item| %>
        <div class="flex items-center gap-3 text-sm">
          <span class="h-1.5 w-1.5 rounded-full <%= item[:done] ? 'bg-primary' : 'bg-zinc-700' %>"></span>
          <span class="<%= item[:done] ? 'text-zinc-300' : 'text-zinc-600' %>"><%= item[:label] %></span>
        </div>
      <% end %>
    </div>

    <%= link_to "Go to dashboard →", developer_dashboard_path,
        class: "block w-full text-center py-2.5 rounded-xl btn btn-primary text-sm" %>
  </div>
<% end %>