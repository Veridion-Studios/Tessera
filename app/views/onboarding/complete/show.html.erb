<div class="min-h-screen bg-zinc-950 flex flex-col items-center justify-center px-6 py-16 text-center">
  <a href="/" class="text-lg font-semibold tracking-tight text-white block mb-12">Tessera</a>

  <div class="w-16 h-16 rounded-2xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center text-3xl mx-auto mb-6">🎉</div>
  <h1 class="text-3xl font-bold text-white mb-3">You're all set up</h1>
  <p class="text-zinc-400 text-sm leading-relaxed max-w-sm mb-8">
    Your portfolio has been submitted for final team review. Once approved, your profile will go live and you'll start receiving quote requests.
  </p>

  <div class="rounded-2xl border border-white/10 bg-white/2 p-6 max-w-sm w-full text-left space-y-3 mb-8">
    <% [
      { label: "Identity verified", done: current_user.identity_status == "verified" },
      { label: "Stripe Connect active", done: current_user.developer_profile.connect_onboarding_status == "active" },
      { label: "Portfolio under review", done: true },
    ].each do |item| %>
      <div class="flex items-center gap-3 text-sm">
        <span class="w-2 h-2 rounded-full <%= item[:done] ? 'bg-green-400' : 'bg-zinc-600' %>"></span>
        <span class="<%= item[:done] ? 'text-zinc-300' : 'text-zinc-600' %>"><%= item[:label] %></span>
      </div>
    <% end %>
  </div>

  <%= link_to "Go to dashboard →", dashboard_path,
      class: "px-6 py-2.5 rounded-xl bg-violet-600 hover:bg-violet-500 text-white font-semibold text-sm transition-colors" %>
</div>