<% @profile = current_user.developer_profile %>

<%= render layout: "shared/auth_shell" do %>
  <div class="w-full max-w-lg">
    <%= render "onboarding/steps", current_step: :connect, profile: @profile %>

    <% if @profile.connect_onboarding_status == "active" %>
      <div class="rounded-2xl border border-primary/20 bg-primary/5 p-8 mb-6 text-center">
        <div class="text-3xl mb-3">✓</div>
        <h1 class="font-geist-sans text-xl font-semibold text-white mb-2">Stripe Connect active</h1>
        <p class="text-zinc-500 text-sm">You're all set to receive payments directly to your account.</p>
      </div>
      <%= link_to "Finish setup →", onboarding_complete_path,
          class: "block w-full text-center py-2.5 rounded-xl btn btn-primary text-sm" %>
    <% else %>
      <div class="mb-8 text-center">
        <div class="w-14 h-14 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center text-2xl mx-auto mb-4">💳</div>
        <h1 class="font-geist-sans text-2xl font-semibold text-white mb-2">Set up payouts</h1>
        <p class="text-zinc-500 text-sm leading-relaxed max-w-sm mx-auto">Connect your bank account via Stripe so milestone payments go directly to you.</p>
      </div>

      <div class="rounded-2xl border border-white/8 bg-white/2 p-6 mb-6 space-y-3">
        <% ["Direct bank transfers per milestone", "Stripe Express — fast, secure, industry standard", "Platform fee is deducted automatically"].each do |item| %>
          <div class="flex items-start gap-3 text-sm text-zinc-400">
            <span class="mt-0.5 h-px w-4 shrink-0 bg-primary/60"></span>
            <%= item %>
          </div>
        <% end %>
      </div>

      <% if @profile.stripe_connect_id.present? %>
        <p class="text-yellow-400 text-sm mb-4 text-center">Your setup was started but not completed. Click below to continue.</p>
      <% end %>

      <%= button_to "Connect with Stripe →", onboarding_connect_start_path,
          class: "w-full py-2.5 rounded-xl btn btn-primary text-sm cursor-pointer" %>
    <% end %>
  </div>
<% end %>