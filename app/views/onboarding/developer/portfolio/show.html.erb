<% @profile = current_user.developer_profile %>

<%= render layout: "shared/onboarding_shell", locals: { role: :developer } do %>
  <div class="w-full max-w-2xl" x-data="portfolioPage()">

    <%= render "onboarding/developer/steps", current_step: :portfolio, profile: @profile %>

    <div class="mb-8">
      <h1 class="font-geist-sans text-2xl font-semibold text-white mb-2">Submit your portfolio</h1>
      <p class="text-zinc-400 text-sm">Add at least one project. Our team reviews and approves before you continue.</p>
    </div>

    <%# GitHub banner %>
    <div class="rounded-xl border <%= @profile.github_connected? ? 'border-primary/20 bg-primary/5' : 'border-white/8 bg-zinc-900' %> p-4 mb-6">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-white/8 border border-white/12 flex items-center justify-center font-geist-mono text-xs text-zinc-300">G</div>
          <div>
            <div class="text-sm font-medium text-zinc-100">GitHub</div>
            <div class="text-xs text-zinc-400 mt-0.5">
              <% if @profile.github_connected? %>Connected as <span class="text-primary">@<%= @profile.github_username %></span><% else %>Connect to browse your repositories<% end %>
            </div>
          </div>
        </div>
        <%= button_to(@profile.github_connected? ? "Refresh access" : "Connect GitHub", github_auth_path, method: :post,
            class: "px-3 py-1.5 rounded-lg bg-white/8 hover:bg-white/12 border border-white/12 text-zinc-200 text-xs font-medium transition-colors") %>
      </div>
    </div>

    <%# Project cards grid %>
    <% if @submissions.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6">
        <% @submissions.each do |sub| %>
          <button type="button"
                  @click="openEdit(<%= sub.to_json(only: [:id, :title, :github_repo_url, :project_demo_url, :description, :tech_tags, :status]).to_json.html_safe %>)"
                  class="group rounded-xl border border-white/8 bg-zinc-900 hover:border-white/16 hover:bg-zinc-800/80 p-4 text-left transition-all">
            <div class="flex items-start justify-between gap-2 mb-3">
              <div class="text-sm font-semibold text-zinc-100 group-hover:text-white transition-colors leading-snug"><%= sub.title %></div>
              <span class="shrink-0 mt-0.5 px-2 py-0.5 rounded-full text-[10px] font-semibold
                <%= sub.status == 'approved' ? 'bg-primary/10 text-primary border border-primary/20' :
                    sub.status == 'rejected' ? 'bg-red-500/10 text-red-400 border border-red-500/20' :
                                               'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20' %>">
                <%= sub.status.capitalize %>
              </span>
            </div>
            <% if sub.github_repo_url.present? %>
              <div class="flex items-center gap-1.5 mb-2">
                <span class="text-zinc-600 font-geist-mono text-[10px]">⎇</span>
                <span class="text-zinc-500 text-xs truncate font-geist-mono"><%= sub.github_repo_url.gsub("https://github.com/", "") %></span>
              </div>
            <% end %>
            <% if sub.tech_tags.any? %>
              <div class="flex flex-wrap gap-1 mt-2">
                <% sub.tech_tags.first(4).each do |tag| %>
                  <span class="px-2 py-0.5 rounded-full bg-white/5 border border-white/8 text-zinc-400 text-[10px]"><%= tag %></span>
                <% end %>
                <% if sub.tech_tags.size > 4 %>
                  <span class="px-2 py-0.5 rounded-full bg-white/5 border border-white/8 text-zinc-500 text-[10px]">+<%= sub.tech_tags.size - 4 %></span>
                <% end %>
              </div>
            <% end %>
            <div class="mt-3 text-[10px] text-zinc-600 group-hover:text-zinc-500 transition-colors font-medium">Click to edit →</div>
          </button>
        <% end %>

        <%# Add new card %>
        <button type="button" @click="openAdd()"
                class="group rounded-xl border border-dashed border-white/8 hover:border-primary/25 hover:bg-primary/3 p-4 flex flex-col items-center justify-center gap-2 transition-all min-h-[120px]">
          <div class="w-8 h-8 rounded-full bg-white/5 border border-white/10 group-hover:border-primary/30 flex items-center justify-center text-zinc-500 group-hover:text-primary transition-colors text-lg leading-none">+</div>
          <span class="text-xs text-zinc-500 group-hover:text-primary transition-colors font-medium">Add project</span>
        </button>
      </div>
    <% else %>
      <%# Empty state %>
      <div class="rounded-xl border border-dashed border-white/8 p-10 mb-6 flex flex-col items-center text-center">
        <div class="w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-2xl mb-4">📁</div>
        <h3 class="text-zinc-200 font-semibold text-sm mb-1">No projects yet</h3>
        <p class="text-zinc-500 text-xs mb-5 max-w-xs">Add your first project to start building your portfolio. Our team reviews each submission.</p>
        <button type="button" @click="openAdd()"
                class="px-5 py-2.5 rounded-xl btn btn-primary text-sm font-medium">
          Add first project
        </button>
      </div>
    <% end %>

    <%# If projects exist, show the add button and continue CTA %>
    <% if @submissions.any? %>
      <% if @profile.portfolio_approved? %>
        <%= link_to "Continue to Stripe Connect →", onboarding_developer_connect_path,
            class: "block w-full text-center py-3 rounded-xl btn btn-primary text-sm font-medium" %>
      <% else %>
        <p class="text-center text-zinc-500 text-xs mt-2">Waiting for team review before you can continue.</p>
      <% end %>
    <% end %>


    <%# ============================================================
        ADD PROJECT MODAL
        ============================================================ %>
    <div x-show="showAdd"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @keydown.escape.window="showAdd = false"
         class="fixed inset-0 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4"
         style="display:none">

      <%# Backdrop %>
      <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" @click="showAdd = false"></div>

      <%# Panel %>
      <div x-transition:enter="transition ease-out duration-250"
           x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
           x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
           x-transition:leave="transition ease-in duration-150"
           x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
           x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
           class="relative w-full sm:max-w-lg bg-zinc-950 border border-white/10 rounded-t-2xl sm:rounded-2xl shadow-2xl overflow-hidden">

        <%# Drag handle (mobile) %>
        <div class="sm:hidden flex justify-center pt-3 pb-1">
          <div class="w-8 h-1 rounded-full bg-white/15"></div>
        </div>

        <div class="px-6 py-5 border-b border-white/8 flex items-center justify-between">
          <h2 class="font-geist-sans text-base font-semibold text-white">Add project</h2>
          <button @click="showAdd = false" class="text-zinc-500 hover:text-zinc-300 transition-colors p-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <%= form_with model: @submission, url: onboarding_developer_portfolio_path, class: "px-6 py-5 space-y-5 max-h-[75vh] overflow-y-auto" do |f| %>
          <% if @submission.errors.any? %>
            <div class="rounded-xl border border-red-500/20 bg-red-500/10 p-4 text-red-400 text-sm space-y-1">
              <% @submission.errors.full_messages.each do |msg| %><div><%= msg %></div><% end %>
            </div>
          <% end %>

          <div>
            <%= f.label :title, "Project title", class: "block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2" %>
            <%= f.text_field :title, placeholder: "My awesome app",
                class: "w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/50 transition-colors" %>
          </div>

          <div data-github-repo-picker data-github-repo-source="<%= onboarding_developer_portfolio_github_repos_path %>">
            <%= f.label :github_repo_url, "GitHub repository", class: "block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2" %>
            <%= f.hidden_field :github_repo_url, data: { github_repo_picker_target: "value" } %>
            <input type="text" placeholder="Search repos…"
                   data-github-repo-picker-target="input"
                   autocomplete="off"
                   class="w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/50 transition-colors">
            <div data-github-repo-picker-target="results"
                 class="hidden mt-1.5 rounded-xl border border-white/10 bg-zinc-900/95 backdrop-blur-sm max-h-52 overflow-y-auto"></div>
          </div>

          <div>
            <%= f.label :project_demo_url, "Demo URL", class: "block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2" %>
            <%= f.url_field :project_demo_url, placeholder: "https://your-demo.example.com",
                class: "w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/50 transition-colors" %>
          </div>

          <div>
            <%= f.label :description, "What did you build?", class: "block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2" %>
            <%= f.text_area :description, rows: 3, placeholder: "Describe the project, your role, and challenges…",
                class: "w-full px-4 py-2.5 rounded-xl bg-zinc-900 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/50 transition-colors resize-none" %>
          </div>

          <div>
            <label class="block text-[10px] font-bold uppercase tracking-widest text-zinc-400 mb-2.5">Tech stack</label>
            <div class="flex flex-wrap gap-2">
              <% @tech_tags.each do |tag| %>
                <label class="cursor-pointer">
                  <%= f.check_box :tech_tags, { multiple: true, checked: @submission.tech_tags.include?(tag) }, tag, false %>
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-xs border border-white/8 bg-white/3 text-zinc-400 hover:border-primary/30 hover:text-primary transition-colors has-[:checked]:border-primary/30 has-[:checked]:bg-primary/10 has-[:checked]:text-primary">
                    <%= tag %>
                  </span>
                </label>
              <% end %>
            </div>
          </div>

          <div class="pt-2 pb-1">
            <%= f.submit "Submit project", class: "w-full py-3 rounded-xl btn btn-primary text-sm font-medium cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>


    <%# ============================================================
        EDIT PROJECT MODAL  (read-only view of submitted project)
        ============================================================ %>
    <div x-show="showEdit"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-150"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @keydown.escape.window="showEdit = false"
         class="fixed inset-0 z-50 flex items-end sm:items-center justify-center p-0 sm:p-4"
         style="display:none">

      <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" @click="showEdit = false"></div>

      <div x-transition:enter="transition ease-out duration-250"
           x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
           x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
           x-transition:leave="transition ease-in duration-150"
           x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
           x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
           class="relative w-full sm:max-w-lg bg-zinc-950 border border-white/10 rounded-t-2xl sm:rounded-2xl shadow-2xl overflow-hidden">

        <div class="sm:hidden flex justify-center pt-3 pb-1">
          <div class="w-8 h-1 rounded-full bg-white/15"></div>
        </div>

        <div class="px-6 py-5 border-b border-white/8 flex items-center justify-between">
          <h2 class="font-geist-sans text-base font-semibold text-white" x-text="editProject.title || 'Project'"></h2>
          <button @click="showEdit = false" class="text-zinc-500 hover:text-zinc-300 transition-colors p-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <div class="px-6 py-5 space-y-5 max-h-[70vh] overflow-y-auto">

          <%# Status badge %>
          <div class="flex items-center gap-2">
            <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">Status</span>
            <span :class="{
              'bg-primary/10 text-primary border-primary/20': editProject.status === 'approved',
              'bg-red-500/10 text-red-400 border-red-500/20': editProject.status === 'rejected',
              'bg-yellow-500/10 text-yellow-400 border-yellow-500/20': editProject.status === 'pending'
            }" class="px-2.5 py-0.5 rounded-full text-xs font-semibold border capitalize" x-text="editProject.status"></span>
          </div>

          <div x-show="editProject.github_repo_url">
            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-1.5">Repository</p>
            <a :href="editProject.github_repo_url" target="_blank"
               class="inline-flex items-center gap-1.5 text-sm text-primary hover:text-primary/80 transition-colors font-geist-mono">
              <span x-text="(editProject.github_repo_url || '').replace('https://github.com/', '')"></span>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>

          <div x-show="editProject.project_demo_url">
            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-1.5">Demo</p>
            <a :href="editProject.project_demo_url" target="_blank"
               class="inline-flex items-center gap-1.5 text-sm text-primary hover:text-primary/80 transition-colors">
              <span x-text="editProject.project_demo_url"></span>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>

          <div x-show="editProject.description">
            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-1.5">Description</p>
            <p class="text-sm text-zinc-300 leading-relaxed" x-text="editProject.description"></p>
          </div>

          <div x-show="editProject.tech_tags && editProject.tech_tags.length">
            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-2">Tech stack</p>
            <div class="flex flex-wrap gap-1.5">
              <template x-for="tag in editProject.tech_tags" :key="tag">
                <span class="px-2.5 py-1 rounded-full bg-primary/8 border border-primary/15 text-primary text-xs" x-text="tag"></span>
              </template>
            </div>
          </div>

          <div x-show="editProject.status === 'pending'" class="rounded-xl border border-yellow-500/20 bg-yellow-500/5 px-4 py-3">
            <p class="text-yellow-400 text-xs leading-relaxed">This project is under review. You'll be notified once our team has approved or provided feedback.</p>
          </div>

          <div x-show="editProject.status === 'rejected'" class="rounded-xl border border-red-500/20 bg-red-500/5 px-4 py-3">
            <p class="text-red-400 text-xs leading-relaxed">This project was not approved. Please review the requirements and submit a new project.</p>
          </div>

        </div>

        <div class="px-6 py-4 border-t border-white/8">
          <button @click="showEdit = false"
                  class="w-full py-2.5 rounded-xl border border-white/10 hover:bg-white/5 text-zinc-300 text-sm font-medium transition-colors">
            Close
          </button>
        </div>
      </div>
    </div>

  </div>
<% end %>

<script>
  function portfolioPage() {
    return {
      showAdd: <%= @submission.errors.any? ? 'true' : 'false' %>,
      showEdit: false,
      editProject: {},
      openAdd() { this.showAdd = true },
      openEdit(project) {
        this.editProject = project;
        this.showEdit = true;
      }
    }
  }
</script>