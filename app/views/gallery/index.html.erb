<%= render "shared/home_navbar" %>

<div class="min-h-screen">

  <%# ── Header ─────────────────────────────────────────────────── %>
  <div class="border-b border-white/5 px-6 sm:px-12 py-14">
    <div class="mx-auto max-w-7xl">
      <p class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-3">Developer gallery</p>
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <h1 class="font-geist-sans text-3xl sm:text-4xl font-semibold text-white [text-wrap:balance]">
          Find your next developer
        </h1>
        <p class="text-zinc-500 text-sm"><%= @total_count %> verified <%= @total_count == 1 ? "developer" : "developers" %></p>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-6 sm:px-12 py-10">
    <div class="flex flex-col lg:flex-row gap-12">

      <%# ── Filters sidebar ──────────────────────────────────────── %>
      <aside class="w-full lg:w-48 shrink-0" x-data="{ open: false }">

        <%# Mobile filter toggle %>
        <button @click="open = !open"
          class="lg:hidden w-full flex items-center justify-between py-2 text-sm text-zinc-400 border-b border-white/5 mb-6">
          <span class="flex items-center gap-2">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/></svg>
            Filters
          </span>
          <svg class="w-3.5 h-3.5 transition-transform" :class="open ? 'rotate-180' : ''" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
        </button>

        <%= form_with url: gallery_path, method: :get,
            data: { turbo: false },
            class: "lg:block space-y-7",
            ":class": "open ? 'block' : 'hidden lg:block'" do |f| %>

          <div>
            <%= f.search_field :q, value: params[:q],
                placeholder: "Search...",
                class: "w-full px-0 py-1.5 bg-transparent border-0 border-b border-white/8 text-white placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/40 transition-colors" %>
          </div>

          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-3">Availability</p>
            <label class="flex items-center gap-2.5 cursor-pointer group">
              <%= f.check_box :availability, { checked: params[:availability] == "open", class: "checkbox checkbox-primary checkbox-xs" }, "open", "" %>
              <span class="text-sm text-zinc-500 group-hover:text-white transition-colors">Available now</span>
            </label>
          </div>

          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-3">Tech stack</p>
            <div class="space-y-2">
              <% @tech_tags.each do |tag| %>
                <label class="flex items-center gap-2.5 cursor-pointer group">
                  <%= check_box_tag "tags[]", tag,
                      Array(params[:tags]).include?(tag),
                      class: "checkbox checkbox-primary checkbox-xs" %>
                  <span class="text-sm text-zinc-500 group-hover:text-white transition-colors"><%= tag %></span>
                </label>
              <% end %>
            </div>
          </div>

          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-3">Sort by</p>
            <%= f.select :sort,
                [["Newest", "newest"], ["Rate ↑", "rate_asc"], ["Rate ↓", "rate_desc"]],
                { selected: params[:sort] || "newest" },
                class: "w-full py-1 bg-transparent border-0 border-b border-white/8 text-zinc-400 text-sm focus:outline-none focus:border-primary/40 transition-colors" %>
          </div>

          <div class="flex flex-col gap-2 pt-1">
            <%= f.submit "Apply filters", class: "w-full py-2 rounded-lg btn btn-primary btn-sm cursor-pointer text-xs" %>
            <% if params[:q].present? || params[:tags].present? || params[:availability].present? %>
              <%= link_to "Clear", gallery_path, class: "text-center text-xs text-zinc-600 hover:text-zinc-400 transition-colors py-1" %>
            <% end %>
          </div>

        <% end %>
      </aside>

      <%# ── Grid ────────────────────────────────────────────────── %>
      <div class="flex-1 min-w-0">
        <% if @profiles.empty? %>
          <div class="flex flex-col items-center justify-center py-24 text-center">
            <p class="text-white font-medium mb-1">No developers found</p>
            <p class="text-zinc-500 text-sm mb-4">Try adjusting your filters or search query.</p>
            <%= link_to "Clear filters", gallery_path, class: "text-primary text-sm hover:text-primary/80 transition-colors" %>
          </div>
        <% else %>
          <%# Divider-separated list on mobile, grid on sm+ %>
          <div class="divide-y divide-white/[0.04] sm:divide-y-0 sm:grid sm:grid-cols-2 xl:grid-cols-3 sm:gap-1">
            <% @profiles.each do |profile| %>
              <%= render "gallery/developer_card", profile: profile %>
            <% end %>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>