<% user = profile.user %>
<% approved_submissions = user.portfolio_submissions.select { |s| s.status == "approved" } %>
<% first_sub = approved_submissions.first %>

<article class="group relative flex flex-col bg-transparent hover:bg-white/[0.03] rounded-2xl transition-all duration-200 overflow-hidden">
  <%= link_to developer_profile_path(username: user.username), class: "absolute inset-0 z-10", aria: { label: "View #{profile.display_name}'s profile" } do %><% end %>

  <div class="p-5 flex-1 flex flex-col gap-5">

    <%# ── Identity row ──────────────────────────────────── %>
    <div class="flex items-start justify-between gap-3">
      <div class="flex items-center gap-3.5">
        <div class="w-10 h-10 rounded-full bg-primary/15 flex items-center justify-center shrink-0">
          <span class="font-geist-sans font-bold text-primary text-sm leading-none">
            <%= (profile.display_name&.first || user.email.first).upcase %>
          </span>
        </div>
        <div>
          <div class="font-semibold text-white text-sm leading-snug">
            <%= profile.display_name&.split&.first || user.email.split("@").first %>
          </div>
          <% if profile.location.present? %>
            <div class="text-xs text-zinc-600 mt-0.5"><%= profile.location %></div>
          <% elsif user.username.present? %>
            <div class="font-geist-mono text-[11px] text-zinc-600 mt-0.5">@<%= user.username %></div>
          <% end %>
        </div>
      </div>

      <%# Availability — dot only, no pill border %>
      <% if profile.availability == "open" %>
        <span class="flex items-center gap-1.5 text-[11px] text-primary shrink-0 mt-0.5">
          <span class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
          Available
        </span>
      <% elsif profile.availability == "busy" %>
        <span class="flex items-center gap-1.5 text-[11px] text-yellow-500 shrink-0 mt-0.5">
          <span class="h-1.5 w-1.5 rounded-full bg-yellow-500"></span>
          Busy
        </span>
      <% end %>
    </div>

    <%# ── Tagline ─────────────────────────────────────── %>
    <% if profile.tagline.present? %>
      <p class="text-zinc-400 text-sm leading-relaxed line-clamp-2 -mt-1"><%= profile.tagline %></p>
    <% end %>

    <%# ── Featured project — no inner box, just a left rule ── %>
    <% if first_sub %>
      <div class="pl-3 border-l border-primary/20">
        <div class="text-xs font-medium text-zinc-300 truncate mb-0.5"><%= first_sub.title %></div>
        <div class="font-geist-mono text-[10px] text-zinc-600 truncate">
          <%= first_sub.github_repo_url.gsub("https://github.com/", "") %>
        </div>
        <% if first_sub.tech_tags.any? %>
          <div class="flex flex-wrap gap-1 mt-2">
            <% first_sub.tech_tags.first(3).each do |tag| %>
              <span class="text-[10px] text-zinc-600"><%= tag %><%= tag == first_sub.tech_tags.first(3).last ? "" : " ·" %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Skill chips — minimal, no border ──────────────── %>
    <% if profile.skill_tags.any? %>
      <div class="flex flex-wrap gap-x-3 gap-y-1">
        <% profile.skill_tags.first(5).each do |tag| %>
          <span class="text-[11px] text-zinc-500"><%= tag %></span>
        <% end %>
        <% if profile.skill_tags.length > 5 %>
          <span class="text-[11px] text-zinc-700">+<%= profile.skill_tags.length - 5 %></span>
        <% end %>
      </div>
    <% end %>

  </div>

  <%# ── Footer — clean rule, no filled background ─────── %>
  <div class="px-5 pb-4 pt-3 flex items-center justify-between gap-2 border-t border-white/[0.04]">
    <div class="text-[11px] text-zinc-600">
      <%= approved_submissions.count %> <%= approved_submissions.count == 1 ? "project" : "projects" %>
      <% if profile.hourly_rate.present? %>
        <span class="text-zinc-800 mx-1">·</span>$<%= profile.hourly_rate.to_i %>/hr
      <% end %>
    </div>

    <% if current_user&.customer? %>
      <%= link_to new_client_quote_path(developer_id: user.id),
          class: "relative z-20 text-[11px] font-medium text-primary hover:text-primary/70 transition-colors" do %>
        Request quote →
      <% end %>
    <% elsif !current_user %>
      <%= link_to join_path(role: "customer"),
          class: "relative z-20 text-[11px] font-medium text-primary hover:text-primary/70 transition-colors" do %>
        Request quote →
      <% end %>
    <% end %>
  </div>
</article>