<div class="flex h-screen overflow-hidden bg-zinc-950" x-data="{ sidebarOpen: false }">
  <%= render "shared/sidebar", active_role: "developer", active_item: :overview %>

  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">

    <%# Mobile topbar %>
    <div class="lg:hidden flex items-center justify-between px-4 py-3 border-b border-white/[0.06] bg-zinc-950">
      <button @click="sidebarOpen = true" class="text-zinc-500 hover:text-white p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
      </button>
      <span class="font-geist-sans text-sm font-semibold text-white">Tessera</span>
      <span class="w-7 h-7 rounded-full bg-primary/20 flex items-center justify-center text-primary text-xs font-bold"><%= current_user.email[0].upcase %></span>
    </div>

    <%# Scrollable area with island %>
    <main class="flex-1 overflow-y-auto p-4 lg:p-6">
      <div class="h-full rounded-2xl border border-white/[0.05] bg-zinc-900/50 backdrop-blur-sm overflow-auto">
        <div class="max-w-4xl mx-auto px-6 lg:px-10 py-10">

          <%# Ambient glow behind the island %>
          <div class="pointer-events-none fixed top-1/3 right-1/4 w-96 h-96 rounded-full bg-primary/5 blur-[100px] -z-10"></div>

          <%# Onboarding nudge %>
          <% unless @profile.fully_verified? %>
            <% next_path = case @profile.onboarding_step
               when 0, 1 then onboarding_identity_path
               when 2    then onboarding_developer_portfolio_path
               when 3    then onboarding_developer_connect_path
               else           onboarding_developer_complete_path
               end %>
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 px-5 py-4 rounded-xl bg-yellow-500/5 border border-yellow-500/15 mb-8">
              <div>
                <div class="text-yellow-400 font-semibold text-sm mb-0.5">Complete your onboarding</div>
                <p class="text-zinc-400 text-sm">You won't appear in the gallery or receive quote requests until your profile is fully verified.</p>
              </div>
              <%= link_to "Continue →", next_path, class: "shrink-0 self-start sm:self-auto px-4 py-2 rounded-lg bg-yellow-500/10 hover:bg-yellow-500/20 border border-yellow-500/20 text-yellow-300 text-xs font-medium transition-colors" %>
            </div>
          <% end %>

          <%# Header %>
          <div class="flex items-start justify-between mb-8">
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1.5">Developer</p>
              <h1 class="font-geist-sans text-2xl font-semibold text-white tracking-tight">Overview</h1>
              <p class="text-zinc-500 text-sm mt-1">Welcome back, <span class="text-zinc-300"><%= current_user.email.split("@").first %></span>.</p>
            </div>
            <% if @profile.fully_verified? %>
              <span class="flex items-center gap-1.5 text-[11px] font-medium text-primary">
                <span class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>Listed
              </span>
            <% else %>
              <span class="flex items-center gap-1.5 text-[11px] font-medium text-zinc-600">
                <span class="h-1.5 w-1.5 rounded-full bg-zinc-700"></span>Not listed
              </span>
            <% end %>
          </div>

          <%# Status strip %>
          <div class="grid grid-cols-3 gap-3 mb-8">
            <% [
              { label: "Identity",  ok: current_user.identity_status == "verified",
                value: current_user.identity_status.tr("_", " ").capitalize, path: onboarding_identity_path },
              { label: "Stripe",    ok: @profile.connect_onboarding_status == "active",
                value: @profile.connect_onboarding_status.capitalize, path: onboarding_developer_connect_path },
              { label: "Portfolio", ok: @profile.portfolio_approved?,
                value: @profile.portfolio_approved? ? "Approved" : @profile.portfolio_submitted? ? "In review" : "Not submitted",
                path: onboarding_developer_portfolio_path },
            ].each do |s| %>
              <%= link_to s[:path], class: "p-4 rounded-xl #{s[:ok] ? 'bg-primary/5' : 'bg-white/[0.03]'} hover:bg-white/[0.06] transition-colors" do %>
                <div class="flex items-center justify-between mb-2.5">
                  <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-600"><%= s[:label] %></span>
                  <span class="h-1.5 w-1.5 rounded-full <%= s[:ok] ? 'bg-primary' : 'bg-yellow-500' %>"></span>
                </div>
                <div class="text-sm font-semibold <%= s[:ok] ? 'text-primary' : 'text-yellow-400' %>"><%= s[:value] %></div>
              <% end %>
            <% end %>
          </div>

          <%# Active projects %>
          <% active_projects = Project.where(developer: current_user, status: "active") %>
          <div class="mb-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-sm font-semibold text-white">Active projects</h2>
              <%= link_to "All projects →", developer_dashboard_path, class: "text-xs text-primary hover:text-primary/70 transition-colors" %>
            </div>
            <% if active_projects.any? %>
              <div class="space-y-2">
                <% active_projects.limit(3).each do |project| %>
                  <%= link_to developer_project_path(project), class: "flex items-center justify-between gap-4 p-4 rounded-xl bg-white/[0.03] hover:bg-white/[0.06] transition-colors" do %>
                    <div class="min-w-0">
                      <div class="text-sm font-medium text-white truncate"><%= project.title %></div>
                      <div class="text-xs text-zinc-500 mt-0.5">
                        <%= project.milestones.where(status: "paid").count %>/<%= project.milestones.count %> milestones ·
                        $<%= project.amount_released.to_i %> released
                      </div>
                    </div>
                    <div class="shrink-0 text-right">
                      <div class="text-xs font-medium text-zinc-400"><%= project.completion_percentage %>%</div>
                      <div class="mt-1 w-16 h-1 rounded-full bg-white/10 overflow-hidden">
                        <div class="h-full bg-primary rounded-full transition-all" style="width:<%= project.completion_percentage %>%"></div>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <p class="text-zinc-600 text-sm">No active projects. When a quote is accepted it becomes a project.</p>
            <% end %>
          </div>

          <%# Quote requests %>
          <div class="mb-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-sm font-semibold text-white">Quote requests</h2>
              <%= link_to "View all →", developer_quotes_path, class: "text-xs text-primary hover:text-primary/70 transition-colors" %>
            </div>
            <% pending = current_user.received_quote_requests.where(status: "submitted").count %>
            <% if pending > 0 %>
              <div class="flex items-center gap-4 p-4 rounded-xl bg-primary/5">
                <span class="font-geist-sans text-2xl font-semibold text-primary"><%= pending %></span>
                <div>
                  <div class="text-sm font-medium text-white">Open request<%= pending == 1 ? "" : "s" %></div>
                  <div class="text-xs text-zinc-500">Awaiting your response</div>
                </div>
                <%= link_to "Review →", developer_quotes_path, class: "ml-auto text-xs font-medium text-primary hover:text-primary/70 transition-colors" %>
              </div>
            <% else %>
              <p class="text-zinc-600 text-sm">No open quote requests yet.</p>
            <% end %>
          </div>

          <%# Portfolio %>
          <div>
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-sm font-semibold text-white">Portfolio</h2>
              <%= link_to "Add project →", onboarding_developer_portfolio_path, class: "text-xs text-primary hover:text-primary/70 transition-colors" %>
            </div>
            <% if @submissions.any? %>
              <div class="space-y-1">
                <% @submissions.first(4).each do |sub| %>
                  <div class="flex items-center justify-between gap-4 py-3 border-b border-white/[0.04] last:border-0">
                    <div class="min-w-0">
                      <div class="text-sm text-zinc-200 truncate"><%= sub.title %></div>
                      <div class="font-geist-mono text-[11px] text-zinc-600 truncate"><%= sub.github_repo_url.gsub("https://github.com/", "") %></div>
                    </div>
                    <span class="shrink-0 text-[10px] font-semibold uppercase tracking-wide
                      <%= sub.status == 'approved' ? 'text-primary' : sub.status == 'rejected' ? 'text-red-400' : 'text-yellow-500' %>">
                      <%= sub.status %>
                    </span>
                  </div>
                <% end %>
              </div>
            <% else %>
              <p class="text-zinc-600 text-sm"><%= link_to "Submit your first project →", onboarding_developer_portfolio_path, class: "text-primary hover:text-primary/70 transition-colors" %></p>
            <% end %>
          </div>

        </div>
      </div>
    </main>
  </div>
</div>