<div class="min-h-screen bg-zinc-950 px-6 py-10">
  <div class="max-w-4xl mx-auto">

    <%# Nav %>
    <header class="flex items-center justify-between mb-12">
      <a href="/" class="text-lg font-semibold tracking-tight text-white">Tessera</a>
      <div class="flex items-center gap-4 text-sm text-zinc-400">
        <span><%= current_user.email %></span>
        <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete },
            class: "hover:text-white transition-colors" %>
      </div>
    </header>

    <% if current_user.developer? %>
      <% unless @profile.fully_verified? %>
        <%# Onboarding banner %>
        <div class="rounded-2xl border border-yellow-500/20 bg-yellow-500/5 p-5 mb-8 flex items-start justify-between gap-4">
          <div>
            <div class="text-yellow-400 font-semibold text-sm mb-1">⚠ Complete your onboarding</div>
            <p class="text-zinc-400 text-sm">You can't receive quotes or appear in the gallery until your profile is fully verified.</p>
          </div>
          <% step_path = case @profile.onboarding_step
             when 1 then onboarding_portfolio_path
             when 2 then onboarding_identity_path
             when 3 then onboarding_connect_path
             else        onboarding_complete_path
             end %>
          <%= link_to "Continue setup →", step_path,
              class: "shrink-0 px-4 py-2 rounded-lg bg-yellow-500/10 hover:bg-yellow-500/20 border border-yellow-500/20 text-yellow-300 text-xs font-medium transition-colors" %>
        </div>
      <% end %>

      <h1 class="text-2xl font-bold text-white mb-8">Developer Dashboard</h1>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <% [
          { label: "Profile status", value: @profile.listed? ? "Listed" : "Not listed", color: @profile.listed? ? "green" : "zinc" },
          { label: "Identity", value: current_user.identity_status.capitalize, color: current_user.identity_status == "verified" ? "green" : "yellow" },
          { label: "Stripe Connect", value: @profile.connect_onboarding_status.capitalize, color: @profile.connect_onboarding_status == "active" ? "green" : "yellow" },
        ].each do |card| %>
          <div class="rounded-2xl border border-white/5 bg-white/2 p-5">
            <div class="text-xs text-zinc-500 mb-1"><%= card[:label] %></div>
            <div class="text-sm font-semibold text-<%= card[:color] %>-400"><%= card[:value] %></div>
          </div>
        <% end %>
      </div>

      <div class="rounded-2xl border border-white/5 bg-white/2 p-6">
        <h2 class="text-sm font-semibold text-white mb-4">Portfolio submissions</h2>
        <% if @submissions.any? %>
          <div class="space-y-3">
            <% @submissions.each do |sub| %>
              <div class="flex items-center justify-between text-sm">
                <span class="text-zinc-300"><%= sub.title %></span>
                <span class="px-2.5 py-1 rounded-full text-xs
                  <%= sub.status == 'approved' ? 'bg-green-500/10 text-green-400' :
                      sub.status == 'rejected' ? 'bg-red-500/10 text-red-400' :
                                                 'bg-yellow-500/10 text-yellow-400' %>">
                  <%= sub.status.capitalize %>
                </span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-zinc-500 text-sm">No portfolio submissions yet. <%= link_to "Add one →", onboarding_portfolio_path, class: "text-violet-400 hover:text-violet-300" %></p>
        <% end %>
      </div>

    <% elsif current_user.customer? %>
      <h1 class="text-2xl font-bold text-white mb-8">Client Dashboard</h1>
      <div class="rounded-2xl border border-white/5 bg-white/2 p-8 text-center text-zinc-400 text-sm">
        Browse developers and request a quote to get started.
      </div>
    <% end %>

  </div>
</div>