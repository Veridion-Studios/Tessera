<%= render layout: "shared/auth_shell" do %>
  <div class="w-full max-w-md text-center mb-10">
    <p class="text-zinc-600 text-xs mb-1">Signed in as <span class="text-zinc-400"><%= current_user.email %></span></p>
    <h1 class="font-geist-sans text-2xl font-semibold text-white">Where are you headed?</h1>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 w-full max-w-md">
    <% if current_user.developer? %>
      <%= button_to switch_dashboard_path, params: { role: "developer" },
          class: "group rounded-2xl border border-white/8 bg-white/2 hover:border-primary/30 hover:bg-primary/5 p-6 text-left transition-all w-full" do %>
        <div class="w-10 h-10 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center mb-4 text-xl">⌨️</div>
        <div class="text-white font-semibold mb-1">Developer</div>
        <div class="text-zinc-500 text-sm leading-relaxed">
          <%= current_user.developer_profile&.fully_verified? ? "Manage projects, milestones, and earnings." : "Continue your onboarding to go live." %>
        </div>
        <div class="mt-4 text-primary text-xs font-medium group-hover:translate-x-1 transition-transform inline-block">Enter →</div>
      <% end %>
    <% elsif current_user.can_add_developer_role? %>
      <%= button_to add_role_path, params: { role: "developer" },
          class: "group rounded-2xl border border-dashed border-white/8 hover:border-primary/20 hover:bg-primary/3 p-6 text-left transition-all w-full" do %>
        <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center mb-4 text-xl">⌨️</div>
        <div class="text-zinc-300 font-semibold mb-1">Add Developer profile</div>
        <div class="text-zinc-600 text-sm leading-relaxed">You're verified as a client. Unlock a developer profile.</div>
        <div class="mt-4 text-primary text-xs font-medium group-hover:translate-x-1 transition-transform inline-block">Unlock →</div>
      <% end %>
    <% else %>
      <div class="rounded-2xl border border-dashed border-white/5 p-6 text-left opacity-40 cursor-not-allowed">
        <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center mb-4 text-xl">⌨️</div>
        <div class="text-zinc-500 font-semibold mb-1">Developer</div>
        <div class="text-zinc-600 text-sm">Complete client verification to unlock.</div>
      </div>
    <% end %>

    <% if current_user.customer? %>
      <%= button_to switch_dashboard_path, params: { role: "customer" },
          class: "group rounded-2xl border border-white/8 bg-white/2 hover:border-primary/30 hover:bg-primary/5 p-6 text-left transition-all w-full" do %>
        <div class="w-10 h-10 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center mb-4 text-xl">💼</div>
        <div class="text-white font-semibold mb-1">Client</div>
        <div class="text-zinc-500 text-sm leading-relaxed">Browse developers, request quotes, and manage projects.</div>
        <div class="mt-4 text-primary text-xs font-medium group-hover:translate-x-1 transition-transform inline-block">Enter →</div>
      <% end %>
    <% elsif current_user.can_add_customer_role? %>
      <%= button_to add_role_path, params: { role: "customer" },
          class: "group rounded-2xl border border-dashed border-white/8 hover:border-primary/20 hover:bg-primary/3 p-6 text-left transition-all w-full" do %>
        <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center mb-4 text-xl">💼</div>
        <div class="text-zinc-300 font-semibold mb-1">Add Client profile</div>
        <div class="text-zinc-600 text-sm leading-relaxed">Hire developers alongside your developer profile.</div>
        <div class="mt-4 text-primary text-xs font-medium group-hover:translate-x-1 transition-transform inline-block">Unlock →</div>
      <% end %>
    <% end %>
  </div>

  <div class="mt-8 flex items-center gap-4 text-xs text-zinc-600">
    <%= link_to "Account settings", account_settings_path, class: "hover:text-zinc-400 transition-colors" %>
    <span>·</span>
    <%= button_to "Sign out", destroy_user_session_path, method: :delete,
        class: "text-xs text-zinc-600 hover:text-zinc-400 transition-colors bg-transparent border-0 cursor-pointer p-0",
        form: { class: "inline" } %>
  </div>
<% end %>