<%= render layout: "shared/auth_shell" do %>

  <%# Ambient glow %>
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full bg-primary/5 blur-[120px]"></div>
  </div>

  <div class="w-full max-w-lg">

    <div class="text-center mb-12">
      <p class="text-[11px] font-bold uppercase tracking-widest text-zinc-500 mb-3">Tessera</p>
      <h1 class="font-geist-sans text-3xl font-semibold text-white tracking-tight mb-2">Where are you headed?</h1>
      <p class="text-zinc-400 text-sm">Signed in as <span class="text-zinc-300"><%= current_user.email %></span></p>
    </div>

    <div class="flex flex-col gap-3">

      <%# Developer row %>
      <% if current_user.developer? %>
        <%= button_to switch_dashboard_path, params: { role: "developer" },
            class: "group w-full rounded-xl border border-white/8 bg-zinc-900 hover:border-primary/25 hover:bg-zinc-800/80 p-5 text-left transition-all" do %>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 shrink-0 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-lg">⌨️</div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-0.5">
                <span class="text-zinc-100 font-semibold text-sm">Developer</span>
                <% if current_user.developer_profile&.fully_verified? %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-[10px] font-medium">
                    <span class="h-1 w-1 rounded-full bg-primary"></span>Live
                  </span>
                <% else %>
                  <span class="px-2 py-0.5 rounded-full bg-yellow-500/10 border border-yellow-500/20 text-yellow-400 text-[10px] font-medium">Setup needed</span>
                <% end %>
              </div>
              <p class="text-zinc-500 text-xs truncate">
                <%= current_user.developer_profile&.fully_verified? ? "Manage projects, milestones, and earnings." : "Continue your onboarding to go live." %>
              </p>
            </div>
            <svg class="w-4 h-4 text-zinc-600 group-hover:text-primary group-hover:translate-x-0.5 transition-all shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        <% end %>
      <% elsif current_user.can_add_developer_role? %>
        <%= button_to add_role_path, params: { role: "developer" },
            class: "group w-full rounded-xl border border-dashed border-white/8 hover:border-primary/20 hover:bg-zinc-900 p-5 text-left transition-all" do %>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 shrink-0 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-lg opacity-60">⌨️</div>
            <div class="flex-1 min-w-0">
              <div class="text-zinc-300 font-semibold text-sm mb-0.5">Add Developer profile</div>
              <p class="text-zinc-500 text-xs">Unlock a developer profile alongside your client account.</p>
            </div>
            <svg class="w-4 h-4 text-zinc-600 group-hover:text-primary group-hover:translate-x-0.5 transition-all shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
          </div>
        <% end %>
      <% else %>
        <div class="w-full rounded-xl border border-dashed border-white/5 p-5 opacity-30 cursor-not-allowed">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 shrink-0 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-lg">⌨️</div>
            <div>
              <div class="text-zinc-500 font-semibold text-sm mb-0.5">Developer</div>
              <p class="text-zinc-600 text-xs">Complete client verification to unlock.</p>
            </div>
          </div>
        </div>
      <% end %>

      <%# Client row %>
      <% if current_user.customer? %>
        <%= button_to switch_dashboard_path, params: { role: "customer" },
            class: "group w-full rounded-xl border border-white/8 bg-zinc-900 hover:border-primary/25 hover:bg-zinc-800/80 p-5 text-left transition-all" do %>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 shrink-0 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-lg">💼</div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-0.5">
                <span class="text-zinc-100 font-semibold text-sm">Client</span>
                <% if current_user.customer_profile&.verified? %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-[10px] font-medium">
                    <span class="h-1 w-1 rounded-full bg-primary"></span>Verified
                  </span>
                <% else %>
                  <span class="px-2 py-0.5 rounded-full bg-yellow-500/10 border border-yellow-500/20 text-yellow-400 text-[10px] font-medium">Verify identity</span>
                <% end %>
              </div>
              <p class="text-zinc-500 text-xs">Browse developers, request quotes, and manage projects.</p>
            </div>
            <svg class="w-4 h-4 text-zinc-600 group-hover:text-primary group-hover:translate-x-0.5 transition-all shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        <% end %>
      <% elsif current_user.can_add_customer_role? %>
        <%= button_to add_role_path, params: { role: "customer" },
            class: "group w-full rounded-xl border border-dashed border-white/8 hover:border-primary/20 hover:bg-zinc-900 p-5 text-left transition-all" do %>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 shrink-0 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-lg opacity-60">💼</div>
            <div class="flex-1 min-w-0">
              <div class="text-zinc-300 font-semibold text-sm mb-0.5">Add Client profile</div>
              <p class="text-zinc-500 text-xs">Hire developers alongside your developer account.</p>
            </div>
            <svg class="w-4 h-4 text-zinc-600 group-hover:text-primary group-hover:translate-x-0.5 transition-all shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
          </div>
        <% end %>
      <% end %>

    </div>

    <div class="mt-8 flex items-center justify-center gap-4 text-xs text-zinc-600">
      <%= link_to "Account settings", account_settings_path, class: "hover:text-zinc-400 transition-colors" %>
      <span class="text-zinc-800">·</span>
      <%= button_to "Sign out", destroy_user_session_path, method: :delete,
          class: "text-xs text-zinc-600 hover:text-zinc-400 transition-colors bg-transparent border-0 cursor-pointer p-0",
          form: { class: "inline" } %>
    </div>

  </div>
<% end %>