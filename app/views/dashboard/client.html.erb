<div class="flex h-screen overflow-hidden bg-zinc-950" x-data="{ sidebarOpen: false }">

  <%= render "shared/sidebar", active_role: "customer", active_item: :overview %>

  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">

    <%# Mobile top bar %>
    <div class="lg:hidden flex items-center justify-between px-4 py-3 border-b border-white/8 bg-zinc-950/95 backdrop-blur-sm">
      <button @click="sidebarOpen = true" class="text-zinc-400 hover:text-white transition-colors p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
      <span class="font-geist-sans text-sm font-semibold text-white">Tessera</span>
      <span class="w-7 h-7 rounded-full bg-violet-500/20 border border-violet-500/30 flex items-center justify-center text-violet-300 text-xs font-bold">
        <%= current_user.email[0].upcase %>
      </span>
    </div>

    <main class="flex-1 overflow-y-auto">
      <div class="relative min-h-full px-6 lg:px-10 py-10">

        <div class="pointer-events-none fixed top-0 right-0 w-[500px] h-[400px] rounded-full bg-primary/5 blur-[120px] -z-10"></div>

        <div class="max-w-4xl mx-auto">

          <% unless @profile.verified? %>
            <div class="rounded-xl border border-yellow-500/20 bg-yellow-500/5 p-4 mb-10 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
              <div>
                <div class="text-yellow-400 font-semibold text-sm mb-0.5">Verify your identity</div>
                <p class="text-zinc-400 text-sm">Required before you can request a quote or make a payment.</p>
              </div>
              <%= link_to "Verify now →", onboarding_client_identity_path, class: "shrink-0 self-start sm:self-auto px-4 py-2 rounded-lg bg-yellow-500/10 hover:bg-yellow-500/20 border border-yellow-500/20 text-yellow-300 text-xs font-medium transition-colors" %>
            </div>
          <% end %>

          <div class="flex items-start justify-between mb-10">
            <div>
              <p class="text-[11px] font-bold uppercase tracking-widest text-zinc-500 mb-2">Client</p>
              <h1 class="font-geist-sans text-3xl font-semibold text-white tracking-tight">Overview</h1>
              <p class="text-zinc-400 text-sm mt-1">Welcome back<% if current_user.email.present? %>, <span class="text-zinc-300"><%= current_user.email.split("@").first %></span><% end %>.</p>
            </div>
            <% if @profile.verified? %>
              <span class="mt-1 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-medium">
                <span class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>Verified
              </span>
            <% else %>
              <span class="mt-1 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-zinc-800 border border-white/8 text-zinc-400 text-xs font-medium">
                <span class="h-1.5 w-1.5 rounded-full bg-zinc-500"></span>Unverified
              </span>
            <% end %>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
            <% [
              { label: "Identity",        value: @profile.identity_status.capitalize, ok: @profile.verified?, path: onboarding_client_identity_path },
              { label: "Active projects", value: "0",     ok: false, path: "#" },
              { label: "Total spent",     value: "$0.00", ok: false, path: "#" },
            ].each do |card| %>
              <%= link_to card[:path], class: "group rounded-xl border #{card[:ok] ? 'border-primary/20 bg-primary/5' : 'border-white/8 bg-zinc-900'} p-5 hover:bg-white/5 transition-colors" do %>
                <div class="flex items-center justify-between mb-3">
                  <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500"><%= card[:label] %></span>
                  <span class="h-1.5 w-1.5 rounded-full <%= card[:ok] ? 'bg-primary' : 'bg-zinc-600' %>"></span>
                </div>
                <div class="font-geist-sans text-xl font-semibold <%= card[:ok] ? 'text-primary' : 'text-zinc-300' %>"><%= card[:value] %></div>
              <% end %>
            <% end %>
          </div>

          <div class="rounded-xl border border-white/8 bg-zinc-900 p-6 mb-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div>
              <h2 class="text-sm font-semibold text-zinc-100 mb-1">Find a developer</h2>
              <p class="text-zinc-400 text-sm">Browse verified developers and request a quote for your project.</p>
            </div>
            <%= link_to "Browse gallery →", "#", class: "shrink-0 btn btn-primary btn-sm" %>
          </div>

          <div class="rounded-xl border border-white/8 bg-zinc-900 p-5 mb-4">
            <h2 class="text-sm font-semibold text-zinc-100 mb-1">Active projects</h2>
            <p class="text-xs text-zinc-500 mt-0.5 mb-3">Projects currently in progress</p>
            <p class="text-zinc-400 text-sm">No active projects. Request a quote from a developer to get started.</p>
          </div>

          <div class="rounded-xl border border-white/8 bg-zinc-900 p-5">
            <h2 class="text-sm font-semibold text-zinc-100 mb-1">Past projects</h2>
            <p class="text-xs text-zinc-500 mt-0.5 mb-3">Completed and closed engagements</p>
            <p class="text-zinc-400 text-sm">Completed projects will appear here.</p>
          </div>

        </div>
      </div>
    </main>
  </div>
</div>