<div class="flex h-screen overflow-hidden bg-zinc-950" x-data="{ sidebarOpen: false }">
  <%= render "shared/sidebar", active_role: "customer", active_item: :overview %>

  <div class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <div class="lg:hidden flex items-center justify-between px-4 py-3 border-b border-white/[0.06] bg-zinc-950">
      <button @click="sidebarOpen = true" class="text-zinc-500 hover:text-white p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
      </button>
      <span class="font-geist-sans text-sm font-semibold text-white">Tessera</span>
      <span class="w-7 h-7 rounded-full bg-primary/20 flex items-center justify-center text-primary text-xs font-bold"><%= current_user.email[0].upcase %></span>
    </div>

    <main class="flex-1 overflow-y-auto p-4 lg:p-6">
      <div class="h-full rounded-2xl border border-white/[0.05] bg-zinc-900/50 backdrop-blur-sm overflow-auto">
        <div class="max-w-4xl mx-auto px-6 lg:px-10 py-10">

          <div class="pointer-events-none fixed top-1/3 right-1/4 w-96 h-96 rounded-full bg-primary/4 blur-[100px] -z-10"></div>

          <% unless @profile.verified? %>
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 px-5 py-4 rounded-xl bg-yellow-500/5 border border-yellow-500/15 mb-8">
              <div>
                <div class="text-yellow-400 font-semibold text-sm mb-0.5">Verify your identity</div>
                <p class="text-zinc-400 text-sm">Required before you can request a quote or make payments.</p>
              </div>
              <%= link_to "Verify now →", onboarding_identity_path, class: "shrink-0 self-start sm:self-auto px-4 py-2 rounded-lg bg-yellow-500/10 hover:bg-yellow-500/20 border border-yellow-500/20 text-yellow-300 text-xs font-medium transition-colors" %>
            </div>
          <% end %>

          <div class="flex items-start justify-between mb-8">
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1.5">Client</p>
              <h1 class="font-geist-sans text-2xl font-semibold text-white tracking-tight">Overview</h1>
              <p class="text-zinc-500 text-sm mt-1">Welcome back, <span class="text-zinc-300"><%= current_user.email.split("@").first %></span>.</p>
            </div>
            <% if @profile.verified? %>
              <span class="flex items-center gap-1.5 text-[11px] font-medium text-primary">
                <span class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>Verified
              </span>
            <% else %>
              <span class="flex items-center gap-1.5 text-[11px] font-medium text-zinc-600">
                <span class="h-1.5 w-1.5 rounded-full bg-zinc-700"></span>Unverified
              </span>
            <% end %>
          </div>

          <%# Stats %>
          <% active_projects = Project.where(customer: current_user, status: "active") %>
          <% total_spent = Project.where(customer: current_user).sum(:amount_released) %>
          <div class="grid grid-cols-3 gap-3 mb-8">
            <div class="p-4 rounded-xl bg-white/[0.03]">
              <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-2.5">Active projects</div>
              <div class="text-2xl font-semibold text-white font-geist-sans"><%= active_projects.count %></div>
            </div>
            <div class="p-4 rounded-xl bg-white/[0.03]">
              <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-2.5">In escrow</div>
              <div class="text-2xl font-semibold text-white font-geist-sans">$<%= Project.where(customer: current_user).sum(:amount_held).to_i %></div>
            </div>
            <div class="p-4 rounded-xl bg-white/[0.03]">
              <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-2.5">Total spent</div>
              <div class="text-2xl font-semibold text-white font-geist-sans">$<%= total_spent.to_i %></div>
            </div>
          </div>

          <%# Active projects list %>
          <div class="mb-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-sm font-semibold text-white">Active projects</h2>
              <%= link_to "All projects →", client_projects_path, class: "text-xs text-primary hover:text-primary/70 transition-colors" %>
            </div>
            <% if active_projects.any? %>
              <div class="space-y-2">
                <% active_projects.limit(3).each do |project| %>
                  <%= link_to client_project_path(project), class: "flex items-center justify-between gap-4 p-4 rounded-xl bg-white/[0.03] hover:bg-white/[0.06] transition-colors" do %>
                    <div class="min-w-0">
                      <div class="text-sm font-medium text-white truncate"><%= project.title %></div>
                      <div class="text-xs text-zinc-500 mt-0.5">
                        with <%= project.developer.developer_profile&.display_name || project.developer.email.split("@").first %>
                        · <%= project.milestones.where(status: "paid").count %>/<%= project.milestones.count %> milestones
                      </div>
                    </div>
                    <div class="shrink-0 text-right">
                      <div class="text-xs font-medium text-zinc-400"><%= project.completion_percentage %>%</div>
                      <div class="mt-1 w-16 h-1 rounded-full bg-white/10 overflow-hidden">
                        <div class="h-full bg-primary rounded-full" style="width:<%= project.completion_percentage %>%"></div>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <div class="flex items-center justify-between p-4 rounded-xl bg-white/[0.03]">
                <div>
                  <div class="text-sm font-medium text-white mb-0.5">No active projects</div>
                  <div class="text-xs text-zinc-500">Browse verified developers and send a quote request.</div>
                </div>
                <%= link_to "Browse gallery →", gallery_path, class: "shrink-0 text-xs font-medium text-primary hover:text-primary/70 transition-colors" %>
              </div>
            <% end %>
          </div>

          <%# Quote requests %>
          <div>
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-sm font-semibold text-white">Your quotes</h2>
              <%= link_to "View all →", client_quotes_path, class: "text-xs text-primary hover:text-primary/70 transition-colors" %>
            </div>
            <% active_quotes = current_user.sent_quote_requests.where(status: %w[submitted viewed]).count %>
            <% if active_quotes > 0 %>
              <div class="flex items-center gap-4 p-4 rounded-xl bg-white/[0.03]">
                <span class="font-geist-sans text-2xl font-semibold text-zinc-200"><%= active_quotes %></span>
                <div>
                  <div class="text-sm font-medium text-white">Open quote<%= active_quotes == 1 ? "" : "s" %></div>
                  <div class="text-xs text-zinc-500">Awaiting developer response</div>
                </div>
                <%= link_to "View →", client_quotes_path, class: "ml-auto text-xs font-medium text-primary hover:text-primary/70 transition-colors" %>
              </div>
            <% else %>
              <p class="text-zinc-600 text-sm">No active quotes. <%= link_to "Browse developers →", gallery_path, class: "text-primary hover:text-primary/70 transition-colors" %></p>
            <% end %>
          </div>

        </div>
      </div>
    </main>
  </div>
</div>