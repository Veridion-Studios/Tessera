<% active_role = "customer" %>
<%= render "shared/app_navbar", active_role: active_role %>

<div class="mx-auto max-w-7xl px-6 sm:px-12 flex min-h-[calc(100vh-57px)]">
  <%= render "shared/sidebar", active_role: active_role, active_item: :overview %>

  <main class="flex-1 py-10 pl-10 min-w-0">

    <% unless @profile.verified? %>
      <div class="rounded-xl border border-yellow-500/20 bg-yellow-500/5 p-4 mb-8 flex items-start justify-between gap-4">
        <div>
          <div class="text-yellow-400 font-semibold text-sm mb-0.5">Verify your identity</div>
          <p class="text-zinc-400 text-sm">Required before submitting a quote request or making a payment.</p>
        </div>
        <%= link_to "Verify now →", client_identity_path, class: "shrink-0 px-4 py-2 rounded-lg bg-yellow-500/10 hover:bg-yellow-500/20 border border-yellow-500/20 text-yellow-300 text-xs font-medium transition-colors" %>
      </div>
    <% end %>

    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-xl font-semibold text-white">Overview</h1>
        <p class="text-zinc-500 text-sm mt-0.5">Your client dashboard</p>
      </div>
      <% if @profile.verified? %>
        <span class="px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-medium">● Verified</span>
      <% else %>
        <span class="px-3 py-1 rounded-full bg-zinc-800 border border-white/5 text-zinc-500 text-xs font-medium">● Unverified</span>
      <% end %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
      <% [
        { label: "Identity",        value: @profile.identity_status.capitalize, ok: @profile.verified? },
        { label: "Active projects", value: "0",    ok: false },
        { label: "Total spent",     value: "$0.00", ok: false },
      ].each do |card| %>
        <div class="rounded-xl border border-white/5 bg-white/2 p-4">
          <div class="text-xs text-zinc-500 mb-2"><%= card[:label] %></div>
          <div class="text-sm font-semibold <%= card[:ok] ? 'text-primary' : 'text-zinc-300' %>"><%= card[:value] %></div>
        </div>
      <% end %>
    </div>

    <div class="rounded-xl border border-white/5 bg-white/2 p-5 mb-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <h2 class="text-sm font-semibold text-white mb-0.5">Find a developer</h2>
        <p class="text-zinc-400 text-sm">Browse verified developers and request a quote for your project.</p>
      </div>
      <%= link_to "Browse gallery →", "#", class: "shrink-0 btn btn-primary btn-sm" %>
    </div>

    <div class="rounded-xl border border-white/5 bg-white/2 p-5 mb-4">
      <h2 class="text-sm font-semibold text-white mb-3">Active projects</h2>
      <p class="text-zinc-500 text-sm">No active projects. Request a quote from a developer to get started.</p>
    </div>

    <div class="rounded-xl border border-white/5 bg-white/2 p-5">
      <h2 class="text-sm font-semibold text-white mb-3">Past projects</h2>
      <p class="text-zinc-500 text-sm">Completed projects will appear here.</p>
    </div>

  </main>
</div>