<div class="px-6 lg:px-10 py-10">
  <div class="pointer-events-none fixed top-1/3 right-1/4 w-96 h-96 rounded-full bg-red-500/3 blur-[100px] -z-10"></div>

  <div class="flex items-start justify-between mb-8">
    <div>
      <p class="text-[10px] font-bold uppercase tracking-widest text-red-500/70 mb-1.5">Admin</p>
      <h1 class="font-geist-sans text-2xl font-semibold text-white tracking-tight">Overview</h1>
    </div>
    <span class="flex items-center gap-1.5 text-[11px] font-medium text-red-400">
      <span class="h-1.5 w-1.5 rounded-full bg-red-500 animate-pulse"></span>Admin access
    </span>
  </div>

  <%# Stat strip %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-8">
    <% [
      { label: "Total users",     value: @total_users,         alert: false },
      { label: "Developers",      value: @total_developers,    alert: false },
      { label: "Clients",         value: @total_customers,     alert: false },
      { label: "Pending reviews", value: @pending_submissions, alert: @pending_submissions > 0 },
    ].each do |s| %>
      <div class="p-4 rounded-xl <%= s[:alert] ? 'bg-yellow-500/5' : 'bg-white/[0.03]' %>">
        <div class="text-[10px] font-bold uppercase tracking-widest <%= s[:alert] ? 'text-yellow-500' : 'text-zinc-600' %> mb-2.5"><%= s[:label] %></div>
        <div class="font-geist-sans text-2xl font-semibold <%= s[:alert] ? 'text-yellow-400' : 'text-white' %>"><%= s[:value] %></div>
      </div>
    <% end %>
  </div>

  <%# Active projects + escrow snapshot %>
  <% active_project_count = Project.active.count %>
  <% total_escrow = Project.sum(:amount_held) %>
  <div class="grid grid-cols-2 gap-3 mb-8">
    <div class="p-4 rounded-xl bg-white/[0.03]">
      <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-2.5">Active projects</div>
      <div class="font-geist-sans text-2xl font-semibold text-white"><%= active_project_count %></div>
    </div>
    <div class="p-4 rounded-xl bg-white/[0.03]">
      <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-2.5">Funds in escrow</div>
      <div class="font-geist-sans text-2xl font-semibold text-primary">$<%= number_with_delimiter(total_escrow.to_i) %></div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">

    <%# Recent submissions %>
    <div class="rounded-xl overflow-hidden bg-white/[0.02]">
      <div class="px-5 py-3.5 border-b border-white/[0.06] flex items-center justify-between">
        <h2 class="text-sm font-semibold text-white">Portfolio submissions</h2>
        <%= link_to "View all →", admin_portfolio_submissions_path, class: "text-xs text-red-400 hover:text-red-300 transition-colors" %>
      </div>
      <% if @recent_submissions.any? %>
        <% @recent_submissions.each do |sub| %>
          <%= link_to admin_portfolio_submission_path(sub), class: "flex items-center justify-between px-5 py-3 border-b border-white/[0.04] last:border-0 hover:bg-white/[0.03] transition-colors" do %>
            <div class="min-w-0">
              <div class="text-sm text-zinc-200 font-medium truncate"><%= sub.title %></div>
              <div class="text-xs text-zinc-600 truncate"><%= sub.user.email %></div>
            </div>
            <span class="shrink-0 ml-3 text-[10px] font-semibold uppercase tracking-wide
              <%= sub.status == 'approved' ? 'text-primary' : sub.status == 'rejected' ? 'text-red-400' : 'text-yellow-500' %>">
              <%= sub.status %>
            </span>
          <% end %>
        <% end %>
      <% else %>
        <p class="px-5 py-4 text-zinc-600 text-sm">No submissions yet.</p>
      <% end %>
    </div>

    <%# Recent users %>
    <div class="rounded-xl overflow-hidden bg-white/[0.02]">
      <div class="px-5 py-3.5 border-b border-white/[0.06] flex items-center justify-between">
        <h2 class="text-sm font-semibold text-white">Recent users</h2>
        <%= link_to "View all →", admin_users_path, class: "text-xs text-red-400 hover:text-red-300 transition-colors" %>
      </div>
      <% if @recent_users.any? %>
        <% @recent_users.each do |user| %>
          <%= link_to admin_user_path(user), class: "flex items-center gap-3 px-5 py-3 border-b border-white/[0.04] last:border-0 hover:bg-white/[0.03] transition-colors" do %>
            <span class="w-6 h-6 shrink-0 rounded-full bg-primary/20 flex items-center justify-center text-primary text-xs font-bold"><%= user.email[0].upcase %></span>
            <div class="min-w-0 flex-1">
              <div class="text-sm text-zinc-200 font-medium truncate"><%= user.email %></div>
              <div class="text-xs text-zinc-600"><%= user.created_at.strftime("%b %d") %></div>
            </div>
            <span class="shrink-0 text-[10px] font-semibold uppercase tracking-wide
              <%= user.identity_status == 'verified' ? 'text-primary' : 'text-zinc-600' %>">
              <%= user.identity_status.tr("_", " ") %>
            </span>
          <% end %>
        <% end %>
      <% else %>
        <p class="px-5 py-4 text-zinc-600 text-sm">No users yet.</p>
      <% end %>
    </div>

  </div>
</div>