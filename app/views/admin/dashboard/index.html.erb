<div class="max-w-5xl mx-auto">
  <div class="mb-10">
    <p class="text-[11px] font-bold uppercase tracking-widest text-red-500 mb-2">Admin</p>
    <h1 class="font-geist-sans text-3xl font-semibold text-white tracking-tight">Overview</h1>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
    <% [
      { label: "Total users",      value: @total_users },
      { label: "Developers",       value: @total_developers },
      { label: "Clients",          value: @total_customers },
      { label: "Pending reviews",  value: @pending_submissions, alert: @pending_submissions > 0 },
    ].each do |s| %>
      <div class="rounded-xl border <%= s[:alert] ? 'border-yellow-500/20 bg-yellow-500/5' : 'border-white/8 bg-zinc-900' %> p-5">
        <div class="text-[10px] font-bold uppercase tracking-widest <%= s[:alert] ? 'text-yellow-500' : 'text-zinc-500' %> mb-2"><%= s[:label] %></div>
        <div class="font-geist-sans text-3xl font-semibold <%= s[:alert] ? 'text-yellow-400' : 'text-white' %>"><%= s[:value] %></div>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="rounded-xl border border-white/8 bg-zinc-900 overflow-hidden">
      <div class="px-5 py-4 border-b border-white/8 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-zinc-100">Recent submissions</h2>
        <%= link_to "View all →", admin_portfolio_submissions_path, class: "text-xs text-red-400 hover:text-red-300 transition-colors" %>
      </div>
      <% if @recent_submissions.any? %>
        <% @recent_submissions.each do |sub| %>
          <%= link_to admin_portfolio_submission_path(sub), class: "flex items-center justify-between px-5 py-3 border-b border-white/5 last:border-b-0 hover:bg-white/3 transition-colors" do %>
            <div class="min-w-0">
              <div class="text-sm text-zinc-200 font-medium truncate"><%= sub.title %></div>
              <div class="text-xs text-zinc-500 truncate"><%= sub.user.email %></div>
            </div>
            <span class="shrink-0 ml-3 px-2 py-0.5 rounded-full text-[10px] font-semibold
              <%= sub.status == 'approved' ? 'bg-green-500/10 text-green-400 border border-green-500/20' :
                  sub.status == 'rejected' ? 'bg-red-500/10 text-red-400 border border-red-500/20' :
                                             'bg-yellow-500/10 text-yellow-400 border border-yellow-500/20' %>">
              <%= sub.status.capitalize %>
            </span>
          <% end %>
        <% end %>
      <% else %>
        <p class="px-5 py-4 text-zinc-500 text-sm">No submissions yet.</p>
      <% end %>
    </div>

    <div class="rounded-xl border border-white/8 bg-zinc-900 overflow-hidden">
      <div class="px-5 py-4 border-b border-white/8 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-zinc-100">Recent users</h2>
        <%= link_to "View all →", admin_users_path, class: "text-xs text-red-400 hover:text-red-300 transition-colors" %>
      </div>
      <% if @recent_users.any? %>
        <% @recent_users.each do |user| %>
          <%= link_to admin_user_path(user), class: "flex items-center gap-3 px-5 py-3 border-b border-white/5 last:border-b-0 hover:bg-white/3 transition-colors" do %>
            <span class="w-7 h-7 shrink-0 rounded-full bg-violet-500/20 border border-violet-500/30 flex items-center justify-center text-violet-300 text-xs font-bold"><%= user.email[0].upcase %></span>
            <div class="min-w-0 flex-1">
              <div class="text-sm text-zinc-200 font-medium truncate"><%= user.email %></div>
              <div class="text-xs text-zinc-500"><%= user.created_at.strftime("%b %d, %Y") %></div>
            </div>
            <span class="shrink-0 px-2 py-0.5 rounded-full text-[10px] font-semibold
              <%= user.identity_status == 'verified' ? 'bg-green-500/10 text-green-400 border border-green-500/20' : 'bg-zinc-800 text-zinc-500 border border-white/8' %>">
              <%= user.identity_status.capitalize %>
            </span>
          <% end %>
        <% end %>
      <% else %>
        <p class="px-5 py-4 text-zinc-500 text-sm">No users yet.</p>
      <% end %>
    </div>
  </div>
</div>