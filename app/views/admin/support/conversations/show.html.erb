<div class="max-w-3xl mx-auto">
  <%= link_to "← All tickets", admin_support_index_path, class: "text-xs text-zinc-500 hover:text-zinc-300 transition-colors mb-8 inline-block" %>

  <%# Header %>
  <div class="flex items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="font-geist-sans text-2xl font-semibold text-white"><%= @conversation.subject %></h1>
      <div class="flex items-center gap-2 mt-1.5">
        <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold border <%= @conversation.status_color %>"><%= @conversation.status.capitalize %></span>
        <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold border <%= @conversation.priority_color %>"><%= @conversation.priority %></span>
        <span class="text-xs text-zinc-500"><%= @conversation.user.email %></span>
      </div>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <% if @conversation.open? %>
        <%= button_to "Close", close_admin_support_path(@conversation), method: :post,
            class: "px-3 py-1.5 rounded-lg bg-zinc-800 hover:bg-zinc-700 border border-white/10 text-zinc-300 text-xs font-medium transition-colors cursor-pointer" %>
      <% else %>
        <%= button_to "Reopen", reopen_admin_support_path(@conversation), method: :post,
            class: "px-3 py-1.5 rounded-lg bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 text-green-400 text-xs font-medium transition-colors cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <%# Thread %>
  <div class="space-y-3 mb-6">
    <% @messages.each do |msg| %>
      <% is_admin_msg = msg.from_admin? %>
      <div class="rounded-xl border <%= msg.internal? ? 'border-yellow-500/20 bg-yellow-500/3' : is_admin_msg ? 'border-primary/15 bg-primary/3' : 'border-white/8 bg-zinc-900' %> p-4">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <span class="text-xs font-medium <%= is_admin_msg ? 'text-primary' : 'text-zinc-300' %>">
              <%= msg.author.email.split("@").first %>
            </span>
            <% if is_admin_msg %>
              <span class="px-1.5 py-0.5 rounded text-[9px] font-bold bg-primary/10 text-primary border border-primary/20">STAFF</span>
            <% end %>
            <% if msg.internal? %>
              <span class="px-1.5 py-0.5 rounded text-[9px] font-bold bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">INTERNAL</span>
            <% end %>
            <% if msg.source == "email" %>
              <span class="px-1.5 py-0.5 rounded text-[9px] text-zinc-600 border border-white/8">email</span>
            <% end %>
          </div>
          <span class="text-xs text-zinc-600"><%= msg.created_at.strftime("%b %d %H:%M") %></span>
        </div>
        <div class="text-sm text-zinc-300 leading-relaxed"><%= msg.body %></div>
      </div>
    <% end %>
  </div>

  <%# Reply form %>
  <div class="rounded-xl border border-white/8 bg-zinc-900 p-5">
    <h2 class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-4">Reply</h2>
    <%= form_with url: admin_support_messages_path(@conversation), method: :post do |f| %>
      <textarea name="message[body]" rows="4" placeholder="Type your reply to the user…"
                class="w-full px-4 py-2.5 rounded-xl bg-zinc-800 border border-white/10 text-zinc-100 placeholder-zinc-600 text-sm focus:outline-none focus:border-primary/50 transition-colors resize-none mb-3"></textarea>
      <div class="flex items-center justify-between">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" name="message[internal]" value="1" class="rounded border-white/20 bg-zinc-800 text-primary">
          <span class="text-xs text-zinc-400">Internal note <span class="text-zinc-600">(not visible to user)</span></span>
        </label>
        <%= f.submit "Send reply →", class: "px-5 py-2.5 rounded-xl btn btn-primary text-sm font-medium cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>