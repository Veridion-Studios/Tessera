<div class="px-6 lg:px-10 py-10">
  <div class="flex items-start justify-between mb-8">
    <div>
      <p class="text-[10px] font-bold uppercase tracking-widest text-red-500/70 mb-1.5">Admin</p>
      <h1 class="font-geist-sans text-2xl font-semibold text-white tracking-tight">Users</h1>
      <p class="text-zinc-500 text-sm mt-1"><%= @users.count %> total</p>
    </div>
  </div>

  <%= form_with url: admin_users_path, method: :get, class: "flex flex-wrap gap-3 mb-6", data: { turbo: false } do |f| %>
    <div class="relative">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-zinc-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
      <%= f.text_field :q, value: params[:q], placeholder: "Search email…",
          class: "pl-8 pr-4 py-2 rounded-xl bg-white/[0.05] text-zinc-200 placeholder-zinc-600 text-sm focus:outline-none focus:ring-1 focus:ring-primary/30 w-52" %>
    </div>
    <%= f.select :role, [["All roles", ""], ["Developer", "developer"], ["Client", "customer"], ["Admin", "admin"]],
        { selected: params[:role] },
        class: "px-3 py-2 rounded-xl bg-white/[0.05] text-zinc-300 text-sm focus:outline-none" %>
    <%= f.select :status, [["All statuses", ""], ["Verified", "verified"], ["Unverified", "unverified"]],
        { selected: params[:status] },
        class: "px-3 py-2 rounded-xl bg-white/[0.05] text-zinc-300 text-sm focus:outline-none" %>
    <%= f.submit "Filter", class: "px-4 py-2 rounded-xl bg-white/[0.06] hover:bg-white/[0.09] text-zinc-300 text-sm font-medium cursor-pointer transition-colors" %>
    <% if params[:q].present? || params[:role].present? || params[:status].present? %>
      <%= link_to "Clear", admin_users_path, class: "px-4 py-2 rounded-xl text-zinc-600 hover:text-zinc-400 text-sm transition-colors" %>
    <% end %>
  <% end %>

  <% if @users.any? %>
    <div class="space-y-0">
      <% @users.each do |user| %>
        <%= link_to admin_user_path(user), class: "flex items-center gap-4 py-3.5 border-b border-white/[0.04] last:border-0 hover:bg-white/[0.02] -mx-2 px-2 rounded-lg transition-colors" do %>
          <span class="w-8 h-8 shrink-0 rounded-full bg-primary/15 flex items-center justify-center text-primary text-xs font-bold"><%= user.email[0].upcase %></span>
          <div class="min-w-0 flex-1">
            <div class="text-sm font-medium text-white truncate"><%= user.email %></div>
            <div class="flex items-center gap-2 mt-0.5">
              <% user.roles.each do |role| %>
                <span class="text-[10px] font-semibold uppercase tracking-wide
                  <%= role.name == 'admin' ? 'text-red-400' : role.name == 'developer' ? 'text-primary' : 'text-zinc-400' %>">
                  <%= role.name %>
                </span>
              <% end %>
              <% if user.suspended_at? %>
                <span class="text-[10px] font-semibold text-red-400">· Suspended</span>
              <% end %>
            </div>
          </div>
          <div class="shrink-0 flex items-center gap-4 text-right">
            <span class="text-[10px] font-semibold uppercase tracking-wide hidden sm:block
              <%= user.identity_status == 'verified' ? 'text-primary' : 'text-zinc-600' %>">
              <%= user.identity_status.tr("_"," ") %>
            </span>
            <span class="text-xs text-zinc-700 hidden lg:block"><%= user.created_at.strftime("%b %d") %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-zinc-600 text-sm py-10 text-center">No users match these filters.</p>
  <% end %>
</div>