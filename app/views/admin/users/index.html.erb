<div class="max-w-6xl mx-auto">
  <div class="flex items-start justify-between mb-8">
    <div>
      <p class="text-[11px] font-bold uppercase tracking-widest text-red-500 mb-2">Admin</p>
      <h1 class="font-geist-sans text-3xl font-semibold text-white tracking-tight">Users</h1>
      <p class="text-zinc-400 text-sm mt-1"><%= @users.count %> total</p>
    </div>
  </div>

  <%# Filters %>
  <%= form_with url: admin_users_path, method: :get, class: "flex flex-wrap gap-3 mb-6" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Search email…",
        class: "px-4 py-2 rounded-lg bg-zinc-900 border border-white/10 text-zinc-200 placeholder-zinc-600 text-sm focus:outline-none focus:border-red-500/40 transition-colors w-56" %>
    <%= f.select :role, [["All roles", ""], ["Developer", "developer"], ["Client", "customer"], ["Admin", "admin"]],
        { selected: params[:role] },
        class: "px-3 py-2 rounded-lg bg-zinc-900 border border-white/10 text-zinc-200 text-sm focus:outline-none" %>
    <%= f.select :status, [["All statuses", ""], ["Verified", "verified"], ["Unverified", "unverified"]],
        { selected: params[:status] },
        class: "px-3 py-2 rounded-lg bg-zinc-900 border border-white/10 text-zinc-200 text-sm focus:outline-none" %>
    <%= f.submit "Filter", class: "px-4 py-2 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-sm font-medium cursor-pointer hover:bg-red-500/20 transition-colors" %>
    <% if params[:q].present? || params[:role].present? || params[:status].present? %>
      <%= link_to "Clear", admin_users_path, class: "px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-zinc-400 text-sm font-medium hover:bg-white/10 transition-colors" %>
    <% end %>
  <% end %>

  <div class="rounded-xl border border-white/8 bg-zinc-900 overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-white/8">
          <th class="text-left px-5 py-3 text-[10px] font-bold uppercase tracking-widest text-zinc-500">User</th>
          <th class="text-left px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-zinc-500 hidden sm:table-cell">Roles</th>
          <th class="text-left px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-zinc-500 hidden md:table-cell">Identity</th>
          <th class="text-left px-4 py-3 text-[10px] font-bold uppercase tracking-widest text-zinc-500 hidden lg:table-cell">Joined</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="border-b border-white/5 last:border-b-0 hover:bg-white/2 transition-colors">
            <td class="px-5 py-3.5">
              <div class="flex items-center gap-3">
                <span class="w-8 h-8 shrink-0 rounded-full bg-violet-500/20 border border-violet-500/30 flex items-center justify-center text-violet-300 text-xs font-bold"><%= user.email[0].upcase %></span>
                <div>
                  <div class="text-zinc-200 font-medium"><%= user.email %></div>
                  <div class="text-zinc-500 text-xs font-geist-mono"><%= user.id.to_s.first(8) %>…</div>
                  <% if user.suspended_at? %>
                    <span class="inline-flex items-center gap-1 mt-0.5 px-1.5 py-0.5 rounded bg-red-500/15 text-red-400 text-[10px] font-semibold">⚠ Suspended</span>
                  <% end %>
                </div>
              </div>
            </td>
            <td class="px-4 py-3.5 hidden sm:table-cell">
              <div class="flex flex-wrap gap-1">
                <% user.roles.each do |role| %>
                  <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold border
                    <%= role.name == 'admin' ? 'bg-red-500/10 text-red-400 border-red-500/20' :
                        role.name == 'developer' ? 'bg-violet-500/10 text-violet-400 border-violet-500/20' :
                                                   'bg-blue-500/10 text-blue-400 border-blue-500/20' %>">
                    <%= role.name.capitalize %>
                  </span>
                <% end %>
              </div>
            </td>
            <td class="px-4 py-3.5 hidden md:table-cell">
              <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold border
                <%= user.identity_status == 'verified' ? 'bg-green-500/10 text-green-400 border-green-500/20' : 'bg-zinc-800 text-zinc-500 border-white/8' %>">
                <%= user.identity_status.capitalize %>
              </span>
            </td>
            <td class="px-4 py-3.5 text-zinc-500 text-xs hidden lg:table-cell">
              <%= user.created_at.strftime("%b %d, %Y") %>
            </td>
            <td class="px-4 py-3.5 text-right">
              <%= link_to "View →", admin_user_path(user), class: "text-xs text-red-400 hover:text-red-300 transition-colors font-medium" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @users.empty? %>
      <p class="px-5 py-8 text-zinc-500 text-sm text-center">No users match these filters.</p>
    <% end %>
  </div>
</div>