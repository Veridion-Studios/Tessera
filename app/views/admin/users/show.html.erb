<div class="max-w-4xl mx-auto">

  <%# Back %>
  <%= link_to "← All users", admin_users_path, class: "text-xs text-zinc-500 hover:text-zinc-300 transition-colors mb-8 inline-block" %>

  <%# Header %>
  <div class="flex items-start gap-4 mb-8">
    <span class="w-12 h-12 rounded-full bg-violet-500/20 border border-violet-500/30 flex items-center justify-center text-violet-300 text-lg font-bold"><%= @user.email[0].upcase %></span>
    <div class="flex-1 min-w-0">
      <h1 class="font-geist-sans text-2xl font-semibold text-white tracking-tight truncate"><%= @user.email %></h1>
      <p class="text-zinc-500 text-xs font-geist-mono mt-0.5">ID: <%= @user.id %></p>
      <div class="flex flex-wrap gap-1.5 mt-2">
        <% @user.roles.each do |role| %>
          <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold border
            <%= role.name == 'admin' ? 'bg-red-500/10 text-red-400 border-red-500/20' :
                role.name == 'developer' ? 'bg-violet-500/10 text-violet-400 border-violet-500/20' :
                                           'bg-blue-500/10 text-blue-400 border-blue-500/20' %>">
            <%= role.name.capitalize %>
          </span>
        <% end %>
        <% if @user.suspended_at? %>
          <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold bg-red-500/15 text-red-400 border border-red-500/25">⚠ Suspended</span>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">

    <%# Identity card %>
    <div class="rounded-xl border border-white/8 bg-zinc-900 p-5">
      <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-3">Identity</div>
      <div class="flex items-center gap-2 mb-4">
        <span class="h-2 w-2 rounded-full <%= @user.identity_status == 'verified' ? 'bg-green-500' : 'bg-zinc-600' %>"></span>
        <span class="text-sm font-semibold <%= @user.identity_status == 'verified' ? 'text-green-400' : 'text-zinc-400' %>"><%= @user.identity_status.capitalize %></span>
      </div>
      <% if @user.identity_revoked_at? %>
        <p class="text-xs text-red-400 mb-3">Revoked <%= @user.identity_revoked_at.strftime("%b %d %Y") %></p>
      <% end %>
      <div class="flex flex-col gap-2">
        <% if @user.identity_status == "verified" %>
          <%= button_to "Revoke identity", revoke_identity_admin_user_path(@user),
              method: :post,
              class: "w-full py-2 rounded-lg bg-red-500/10 hover:bg-red-500/20 border border-red-500/20 text-red-400 text-xs font-medium transition-colors cursor-pointer",
              data: { confirm: "Revoke identity verification for #{@user.email}?" } %>
        <% else %>
          <%= button_to "Manually verify", verify_identity_admin_user_path(@user),
              method: :post,
              class: "w-full py-2 rounded-lg bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 text-green-400 text-xs font-medium transition-colors cursor-pointer" %>
        <% end %>
      </div>
    </div>

    <%# Stripe Connect %>
    <div class="rounded-xl border border-white/8 bg-zinc-900 p-5">
      <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-3">Stripe Connect</div>
      <% if @developer_profile %>
        <div class="flex items-center gap-2 mb-2">
          <span class="h-2 w-2 rounded-full <%= @developer_profile.connect_onboarding_status == 'active' ? 'bg-green-500' : 'bg-zinc-600' %>"></span>
          <span class="text-sm font-semibold text-zinc-300"><%= @developer_profile.connect_onboarding_status.capitalize %></span>
        </div>
        <% if @developer_profile.stripe_connect_id.present? %>
          <p class="text-xs text-zinc-500 font-geist-mono break-all mb-3"><%= @developer_profile.stripe_connect_id %></p>
        <% else %>
          <p class="text-xs text-zinc-600 mb-3">No Connect account yet</p>
        <% end %>
      <% else %>
        <p class="text-xs text-zinc-600">Not a developer</p>
      <% end %>
    </div>

    <%# Account status %>
    <div class="rounded-xl border border-white/8 bg-zinc-900 p-5">
      <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-3">Account status</div>
      <div class="flex items-center gap-2 mb-4">
        <span class="h-2 w-2 rounded-full <%= @user.suspended_at? ? 'bg-red-500' : 'bg-green-500' %>"></span>
        <span class="text-sm font-semibold <%= @user.suspended_at? ? 'text-red-400' : 'text-green-400' %>"><%= @user.suspended_at? ? "Suspended" : "Active" %></span>
      </div>
      <% if @user.suspended_at? %>
        <p class="text-xs text-zinc-500 mb-3">Reason: <%= @user.suspension_reason.presence || "No reason given" %></p>
        <%= button_to "Reinstate user", unsuspend_admin_user_path(@user),
            method: :post,
            class: "w-full py-2 rounded-lg bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 text-green-400 text-xs font-medium transition-colors cursor-pointer" %>
      <% else %>
        <div x-data="{ open: false }">
          <button @click="open = !open" class="w-full py-2 rounded-lg bg-red-500/10 hover:bg-red-500/20 border border-red-500/20 text-red-400 text-xs font-medium transition-colors">
            Suspend user
          </button>
          <div x-show="open" class="mt-2 space-y-2" style="display:none">
            <%= form_with url: suspend_admin_user_path(@user), method: :post do |f| %>
              <%= f.text_field :reason, placeholder: "Reason (optional)",
                  class: "w-full px-3 py-2 rounded-lg bg-zinc-800 border border-white/10 text-zinc-200 placeholder-zinc-600 text-xs focus:outline-none" %>
              <%= f.submit "Confirm suspend",
                  class: "w-full mt-1.5 py-2 rounded-lg bg-red-600 hover:bg-red-500 text-white text-xs font-medium cursor-pointer transition-colors" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

  </div>

  <%# Admin role & notes %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div class="rounded-xl border border-white/8 bg-zinc-900 p-5">
      <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-3">Admin access</div>
      <% if @user.admin? %>
        <p class="text-sm text-red-400 mb-3 font-medium">Has admin role</p>
        <% if @user != current_user %>
          <%= button_to "Revoke admin", revoke_admin_admin_user_path(@user),
              method: :post,
              class: "w-full py-2 rounded-lg bg-red-500/10 hover:bg-red-500/20 border border-red-500/20 text-red-400 text-xs font-medium transition-colors cursor-pointer",
              data: { confirm: "Revoke admin for #{@user.email}?" } %>
        <% else %>
          <p class="text-xs text-zinc-600">You cannot revoke your own admin role.</p>
        <% end %>
      <% else %>
        <p class="text-sm text-zinc-400 mb-3">Not an admin</p>
        <%= button_to "Grant admin", grant_admin_admin_user_path(@user),
            method: :post,
            class: "w-full py-2 rounded-lg bg-yellow-500/10 hover:bg-yellow-500/20 border border-yellow-500/20 text-yellow-400 text-xs font-medium transition-colors cursor-pointer",
            data: { confirm: "Grant admin access to #{@user.email}?" } %>
      <% end %>
    </div>

    <div class="rounded-xl border border-white/8 bg-zinc-900 p-5">
      <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-3">Admin notes</div>
      <%= form_with url: admin_user_path(@user), method: :patch do |f| %>
        <%= f.text_area :admin_notes, value: @user.admin_notes, rows: 3,
            placeholder: "Internal notes about this user…",
            class: "w-full px-3 py-2.5 rounded-lg bg-zinc-800 border border-white/10 text-zinc-200 placeholder-zinc-600 text-sm focus:outline-none resize-none mb-2" %>
        <%= f.submit "Save notes", class: "px-4 py-1.5 rounded-lg bg-white/8 hover:bg-white/12 border border-white/10 text-zinc-300 text-xs font-medium cursor-pointer transition-colors" %>
      <% end %>
    </div>
  </div>

  <%# Developer profile %>
  <% if @developer_profile %>
    <div class="rounded-xl border border-white/8 bg-zinc-900 p-5 mb-4">
      <div class="text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-4">Developer profile</div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-4 text-sm">
        <div><p class="text-zinc-500 text-xs mb-1">Verification</p><p class="text-zinc-200 font-medium"><%= @developer_profile.verification_status %></p></div>
        <div><p class="text-zinc-500 text-xs mb-1">Onboarding step</p><p class="text-zinc-200 font-medium"><%= @developer_profile.onboarding_step_name %></p></div>
        <div><p class="text-zinc-500 text-xs mb-1">GitHub</p><p class="text-zinc-200 font-medium"><%= @developer_profile.github_username.presence || "—" %></p></div>
        <div><p class="text-zinc-500 text-xs mb-1">Listed</p><p class="<%= @developer_profile.fully_verified? ? 'text-green-400' : 'text-zinc-500' %> font-medium"><%= @developer_profile.fully_verified? ? "Yes" : "No" %></p></div>
      </div>
    </div>
  <% end %>

  <%# Portfolio submissions %>
  <% if @submissions.any? %>
    <div class="rounded-xl border border-white/8 bg-zinc-900 overflow-hidden mb-4">
      <div class="px-5 py-4 border-b border-white/8">
        <h2 class="text-sm font-semibold text-zinc-100">Portfolio submissions</h2>
      </div>
      <% @submissions.each do |sub| %>
        <div class="flex items-center justify-between px-5 py-3 border-b border-white/5 last:border-b-0">
          <div class="min-w-0">
            <div class="text-sm text-zinc-200 font-medium"><%= sub.title %></div>
            <div class="text-xs text-zinc-500 truncate"><%= sub.github_repo_url %></div>
          </div>
          <div class="flex items-center gap-3 shrink-0 ml-4">
            <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold border
              <%= sub.status == 'approved' ? 'bg-green-500/10 text-green-400 border-green-500/20' :
                  sub.status == 'rejected' ? 'bg-red-500/10 text-red-400 border-red-500/20' :
                                             'bg-yellow-500/10 text-yellow-400 border-yellow-500/20' %>">
              <%= sub.status.capitalize %>
            </span>
            <%= link_to "Review →", admin_portfolio_submission_path(sub), class: "text-xs text-red-400 hover:text-red-300 transition-colors font-medium" %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Recent notifications sent %>
  <% if @notifications.any? %>
    <div class="rounded-xl border border-white/8 bg-zinc-900 overflow-hidden">
      <div class="px-5 py-4 border-b border-white/8">
        <h2 class="text-sm font-semibold text-zinc-100">Notifications sent</h2>
      </div>
      <% @notifications.each do |notif| %>
        <div class="flex items-center justify-between px-5 py-3 border-b border-white/5 last:border-b-0">
          <div class="min-w-0">
            <div class="text-sm text-zinc-300 truncate"><%= notif.message rescue notif.type %></div>
            <div class="text-xs text-zinc-500"><%= notif.created_at.strftime("%b %d, %Y %H:%M") %></div>
          </div>
          <% unless notif.read? %>
            <span class="h-1.5 w-1.5 rounded-full bg-primary shrink-0 ml-3"></span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

</div>