<div class="px-6 lg:px-10 py-10">
  <%= link_to "← Users", admin_users_path, class: "text-xs text-zinc-600 hover:text-zinc-400 transition-colors mb-8 inline-block" %>

  <div class="flex items-start gap-4 mb-8">
    <span class="w-12 h-12 rounded-full bg-primary/15 flex items-center justify-center text-primary text-lg font-bold"><%= @user.email[0].upcase %></span>
    <div class="flex-1 min-w-0">
      <h1 class="font-geist-sans text-xl font-semibold text-white truncate"><%= @user.email %></h1>
      <p class="font-geist-mono text-xs text-zinc-600 mt-0.5"><%= @user.id %></p>
      <div class="flex flex-wrap gap-2 mt-2">
        <% @user.roles.each do |role| %>
          <span class="text-[10px] font-bold uppercase tracking-widest
            <%= role.name == 'admin' ? 'text-red-400' : role.name == 'developer' ? 'text-primary' : 'text-zinc-400' %>">
            <%= role.name %>
          </span>
        <% end %>
        <% if @user.suspended_at? %>
          <span class="text-[10px] font-bold uppercase tracking-widest text-red-400">· Suspended</span>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">

    <div class="p-5 rounded-xl bg-white/[0.03]">
      <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-3">Identity</p>
      <div class="flex items-center gap-2 mb-4">
        <span class="h-1.5 w-1.5 rounded-full <%= @user.identity_status == 'verified' ? 'bg-primary' : 'bg-zinc-600' %>"></span>
        <span class="text-sm font-semibold <%= @user.identity_status == 'verified' ? 'text-primary' : 'text-zinc-400' %>">
          <%= @user.identity_status.tr("_"," ").capitalize %>
        </span>
      </div>
      <div class="flex flex-col gap-2">
        <% if @user.identity_status == "verified" %>
          <%= button_to "Revoke identity", revoke_identity_admin_user_path(@user), method: :post,
              class: "w-full py-2 rounded-lg bg-red-500/10 hover:bg-red-500/20 text-red-400 text-xs font-medium transition-colors cursor-pointer",
              data: { confirm: "Revoke identity for #{@user.email}?" } %>
        <% else %>
          <%= button_to "Manually verify", verify_identity_admin_user_path(@user), method: :post,
              class: "w-full py-2 rounded-lg bg-primary/10 hover:bg-primary/20 text-primary text-xs font-medium transition-colors cursor-pointer" %>
        <% end %>
      </div>
    </div>

    <div class="p-5 rounded-xl bg-white/[0.03]">
      <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-3">Account status</p>
      <div class="flex items-center gap-2 mb-4">
        <span class="h-1.5 w-1.5 rounded-full <%= @user.suspended_at? ? 'bg-red-500' : 'bg-primary' %>"></span>
        <span class="text-sm font-semibold <%= @user.suspended_at? ? 'text-red-400' : 'text-primary' %>">
          <%= @user.suspended_at? ? "Suspended" : "Active" %>
        </span>
      </div>
      <% if @user.suspended_at? %>
        <p class="text-xs text-zinc-500 mb-3"><%= @user.suspension_reason.presence || "No reason given" %></p>
        <%= button_to "Reinstate", unsuspend_admin_user_path(@user), method: :post,
            class: "w-full py-2 rounded-lg bg-primary/10 hover:bg-primary/20 text-primary text-xs font-medium transition-colors cursor-pointer" %>
      <% else %>
        <div x-data="{ open: false }">
          <button @click="open = !open" class="w-full py-2 rounded-lg bg-red-500/10 hover:bg-red-500/20 text-red-400 text-xs font-medium transition-colors">Suspend</button>
          <div x-show="open" class="mt-2 space-y-2" style="display:none">
            <%= form_with url: suspend_admin_user_path(@user), method: :post do |f| %>
              <%= f.text_field :reason, placeholder: "Reason (optional)",
                  class: "w-full px-3 py-2 rounded-lg bg-white/[0.05] text-zinc-200 placeholder-zinc-600 text-xs focus:outline-none" %>
              <%= f.submit "Confirm", class: "w-full mt-1.5 py-2 rounded-lg bg-red-600 hover:bg-red-500 text-white text-xs font-medium cursor-pointer transition-colors" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="p-5 rounded-xl bg-white/[0.03]">
      <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-3">Admin access</p>
      <% if @user.admin? %>
        <p class="text-sm text-red-400 font-medium mb-3">Admin</p>
        <% if @user != current_user %>
          <%= button_to "Revoke admin", revoke_admin_admin_user_path(@user), method: :post,
              class: "w-full py-2 rounded-lg bg-red-500/10 hover:bg-red-500/20 text-red-400 text-xs font-medium transition-colors cursor-pointer",
              data: { confirm: "Revoke admin for #{@user.email}?" } %>
        <% end %>
      <% else %>
        <p class="text-sm text-zinc-500 mb-3">Not admin</p>
        <%= button_to "Grant admin", grant_admin_admin_user_path(@user), method: :post,
            class: "w-full py-2 rounded-lg bg-yellow-500/10 hover:bg-yellow-500/20 text-yellow-400 text-xs font-medium transition-colors cursor-pointer",
            data: { confirm: "Grant admin to #{@user.email}?" } %>
      <% end %>
    </div>
  </div>

  <% if @developer_profile %>
    <div class="p-5 rounded-xl bg-white/[0.03] mb-4">
      <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-4">Developer profile</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div><p class="text-[10px] text-zinc-600 mb-1">Verification</p><p class="text-sm text-zinc-200"><%= @developer_profile.verification_status %></p></div>
        <div><p class="text-[10px] text-zinc-600 mb-1">Onboarding</p><p class="text-sm text-zinc-200"><%= @developer_profile.onboarding_step_name %></p></div>
        <div><p class="text-[10px] text-zinc-600 mb-1">GitHub</p><p class="text-sm text-zinc-200"><%= @developer_profile.github_username.presence || "—" %></p></div>
        <div><p class="text-[10px] text-zinc-600 mb-1">Listed</p>
          <p class="text-sm <%= @developer_profile.fully_verified? ? 'text-primary' : 'text-zinc-600' %>">
            <%= @developer_profile.fully_verified? ? "Yes" : "No" %>
          </p>
        </div>
      </div>
    </div>
  <% end %>

  <div class="p-5 rounded-xl bg-white/[0.03] mb-4">
    <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-3">Admin notes</p>
    <%= form_with url: admin_user_path(@user), method: :patch do |f| %>
      <%= f.text_area :admin_notes, value: @user.admin_notes, rows: 3,
          placeholder: "Internal notes…",
          class: "w-full px-4 py-2.5 rounded-xl bg-white/[0.05] text-zinc-200 placeholder-zinc-600 text-sm focus:outline-none resize-none mb-2" %>
      <%= f.submit "Save", class: "px-4 py-1.5 rounded-lg bg-white/[0.06] hover:bg-white/[0.09] text-zinc-300 text-xs font-medium cursor-pointer transition-colors" %>
    <% end %>
  </div>

  <% if @submissions.any? %>
    <div class="rounded-xl overflow-hidden bg-white/[0.02] mb-4">
      <div class="px-5 py-3.5 border-b border-white/[0.06]">
        <h2 class="text-sm font-semibold text-white">Portfolio submissions</h2>
      </div>
      <% @submissions.each do |sub| %>
        <%= link_to admin_portfolio_submission_path(sub), class: "flex items-center justify-between px-5 py-3 border-b border-white/[0.04] last:border-0 hover:bg-white/[0.03] transition-colors" do %>
          <div class="min-w-0">
            <div class="text-sm text-zinc-200 font-medium truncate"><%= sub.title %></div>
            <div class="font-geist-mono text-[11px] text-zinc-600 truncate"><%= sub.github_repo_url.gsub("https://github.com/","") %></div>
          </div>
          <span class="shrink-0 ml-4 text-[10px] font-bold uppercase tracking-wide
            <%= sub.status == 'approved' ? 'text-primary' : sub.status == 'rejected' ? 'text-red-400' : 'text-yellow-500' %>">
            <%= sub.status %>
          </span>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>