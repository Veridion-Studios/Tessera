<div class="px-6 lg:px-10 py-10">
  <%= link_to "← Submissions", admin_portfolio_submissions_path, class: "text-xs text-zinc-600 hover:text-zinc-400 transition-colors mb-8 inline-block" %>

  <div class="flex items-start justify-between gap-4 mb-8">
    <div>
      <h1 class="font-geist-sans text-2xl font-semibold text-white tracking-tight mb-1"><%= @submission.title %></h1>
      <p class="text-zinc-500 text-sm"><%= @submission.user.email %> · <%= @submission.created_at.strftime("%b %d, %Y") %></p>
    </div>
    <span class="shrink-0 text-[10px] font-bold uppercase tracking-widest
      <%= @submission.status == 'approved' ? 'text-primary' : @submission.status == 'rejected' ? 'text-red-400' : 'text-yellow-500' %>">
      <%= @submission.status %>
    </span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-4">

      <div class="p-5 rounded-xl bg-white/[0.03] space-y-4">
        <div>
          <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1.5">Repository</p>
          <a href="<%= @submission.github_repo_url %>" target="_blank" class="font-geist-mono text-sm text-primary hover:text-primary/80 transition-colors"><%= @submission.github_repo_url %></a>
        </div>
        <% if @submission.project_demo_url.present? %>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1.5">Demo</p>
            <a href="<%= @submission.project_demo_url %>" target="_blank" class="text-sm text-primary hover:text-primary/80 transition-colors"><%= @submission.project_demo_url %></a>
          </div>
        <% end %>
        <% if @submission.description.present? %>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-1.5">Description</p>
            <p class="text-sm text-zinc-300 leading-relaxed"><%= @submission.description %></p>
          </div>
        <% end %>
        <% if @submission.tech_tags.any? %>
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-2">Stack</p>
            <div class="flex flex-wrap gap-x-3 gap-y-1">
              <% @submission.tech_tags.each do |tag| %>
                <span class="text-xs text-zinc-400"><%= tag %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <% if @submission.status == "pending" %>
        <div class="p-5 rounded-xl bg-white/[0.03]">
          <h2 class="text-sm font-semibold text-white mb-4">Review decision</h2>
          <div class="flex gap-3 flex-wrap">
            <%= button_to "Approve", approve_admin_portfolio_submission_path(@submission), method: :post,
                class: "px-5 py-2.5 rounded-xl bg-primary/10 hover:bg-primary/20 text-primary text-sm font-medium transition-colors cursor-pointer" %>
            <div x-data="{ open: false }">
              <button @click="open = !open" class="px-5 py-2.5 rounded-xl bg-red-500/10 hover:bg-red-500/20 text-red-400 text-sm font-medium transition-colors">
                Reject…
              </button>
              <div x-show="open" class="mt-3" style="display:none">
                <%= form_with url: reject_admin_portfolio_submission_path(@submission), method: :post do |f| %>
                  <%= f.text_area :admin_notes, rows: 3, placeholder: "Rejection reason (optional)…",
                      class: "w-full px-4 py-2.5 rounded-xl bg-white/[0.05] text-zinc-200 placeholder-zinc-600 text-sm focus:outline-none resize-none mb-2" %>
                  <%= f.submit "Confirm rejection", class: "px-4 py-2 rounded-xl bg-red-600 hover:bg-red-500 text-white text-sm font-medium cursor-pointer transition-colors" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <% if @submission.admin_notes.present? %>
        <div class="p-5 rounded-xl bg-white/[0.03]">
          <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-2">Admin notes</p>
          <p class="text-sm text-zinc-400"><%= @submission.admin_notes %></p>
        </div>
      <% end %>
    </div>

    <div class="space-y-4">
      <div class="p-5 rounded-xl bg-white/[0.03]">
        <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-3">Developer</p>
        <div class="flex items-center gap-3 mb-3">
          <span class="w-8 h-8 rounded-full bg-primary/15 flex items-center justify-center text-primary text-xs font-bold"><%= @submission.user.email[0].upcase %></span>
          <div>
            <div class="text-sm font-medium text-white"><%= @submission.user.email.split("@").first %></div>
            <div class="text-xs text-zinc-600"><%= @submission.user.email %></div>
          </div>
        </div>
        <%= link_to "View user →", admin_user_path(@submission.user), class: "text-xs text-primary hover:text-primary/70 transition-colors" %>
      </div>

      <% if @other_submissions.any? %>
        <div class="p-5 rounded-xl bg-white/[0.03]">
          <p class="text-[10px] font-bold uppercase tracking-widest text-zinc-600 mb-3">Other submissions</p>
          <div class="space-y-2">
            <% @other_submissions.each do |sub| %>
              <%= link_to admin_portfolio_submission_path(sub), class: "flex items-center justify-between py-2 hover:opacity-80 transition-opacity" do %>
                <span class="text-sm text-zinc-400 truncate"><%= sub.title %></span>
                <span class="shrink-0 ml-3 text-[10px] font-bold uppercase tracking-wide
                  <%= sub.status == 'approved' ? 'text-primary' : sub.status == 'rejected' ? 'text-red-400' : 'text-yellow-500' %>">
                  <%= sub.status %>
                </span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>