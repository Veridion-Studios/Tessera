<div class="px-6 lg:px-10 py-10">
  <div class="flex items-start justify-between mb-8">
    <div>
      <p class="text-[10px] font-bold uppercase tracking-widest text-red-500/70 mb-1.5">Admin</p>
      <h1 class="font-geist-sans text-2xl font-semibold text-white tracking-tight">Portfolio submissions</h1>
    </div>
    <span class="text-[11px] text-zinc-500"><%= @submissions.count %> shown</span>
  </div>

  <div class="flex gap-1 mb-6 border-b border-white/[0.06]">
    <% %w[pending approved rejected].each do |status| %>
      <%= link_to admin_portfolio_submissions_path(status: status),
          class: "px-4 py-2.5 text-sm font-medium border-b-2 transition-colors -mb-px #{@status == status ? 'border-primary text-white' : 'border-transparent text-zinc-500 hover:text-zinc-300'}" do %>
        <%= status.capitalize %>
      <% end %>
    <% end %>
  </div>

  <% if @submissions.any? %>
    <div class="space-y-1">
      <% @submissions.each do |sub| %>
        <%= link_to admin_portfolio_submission_path(sub), class: "flex items-center gap-4 py-4 border-b border-white/[0.04] last:border-0 hover:bg-white/[0.02] -mx-2 px-2 rounded-lg transition-colors" do %>
          <span class="w-8 h-8 shrink-0 rounded-full bg-primary/15 flex items-center justify-center text-primary text-xs font-bold"><%= sub.user.email[0].upcase %></span>
          <div class="min-w-0 flex-1">
            <div class="text-sm font-medium text-white truncate"><%= sub.title %></div>
            <div class="text-xs text-zinc-600"><%= sub.user.email %> · <%= sub.created_at.strftime("%b %d") %></div>
            <% if sub.tech_tags.any? %>
              <div class="flex gap-x-2.5 mt-1 flex-wrap">
                <% sub.tech_tags.first(4).each do |tag| %>
                  <span class="text-[10px] text-zinc-700"><%= tag %></span>
                <% end %>
              </div>
            <% end %>
          </div>
          <span class="shrink-0 text-[10px] font-semibold uppercase tracking-wide
            <%= sub.status == 'approved' ? 'text-primary' : sub.status == 'rejected' ? 'text-red-400' : 'text-yellow-500' %>">
            <%= sub.status %>
          </span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="flex flex-col items-center justify-center py-20 text-center">
      <p class="text-zinc-500 text-sm">No <%= @status %> submissions.</p>
    </div>
  <% end %>
</div>